<!-- Mobile Drawer -->
<div class="mobile-menu-backdrop"></div>
<div class="mobile-menu-drawer">
  <div class="mobile-drawer-header">
    <a href="/" class="logo-link">
      {% if logo_image %}
        <img src="{{ logo_image | img_url: '400x' }}" alt="{{ logo_text }}" class="logo-img">
      {% else %}
        {{ logo_text }}
      {% endif %}
    </a>
    <button class="mobile-drawer-close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  <nav>
    <ul class="mobile-nav-list">
      {% for link in main_menu.links %}
        {%- liquid
          assign has_mega = false
          assign mega_block = null
          for block in section.blocks
            assign trigger = block.settings.trigger_label | downcase | strip
            assign link_title = link.title | downcase | strip
            if trigger == link_title
              assign has_mega = true
              assign mega_block = block
              break
            endif
          endfor

          assign is_link_active = false
          if link.active or link.child_active
            assign is_link_active = true
          endif

          # Manual Overrides for Mega Menu Parents
          assign current_path = request.path | downcase
          assign link_title_down = link.title | downcase
          
          if request.page_type == 'collection'
            if current_path contains '/vendors' or current_path contains '/brands' or request.query_string contains 'q='
              if link_title_down == 'brands'
                assign is_link_active = true
              else
                assign is_link_active = false
              endif
            else
              if link_title_down == 'collections'
                if collection.handle != 'all'
                  assign is_link_active = true
                else
                  assign is_link_active = false
                endif
              endif
            endif
          elsif request.page_type == 'product'
            if link_title_down == 'collections'
              assign is_link_active = true
            endif
          endif

          if link_title_down == 'shop'
            if link.active
              assign is_link_active = true
            else
              assign is_link_active = false
            endif
          endif
        -%}

        <li class="mobile-nav-item">
          <div class="mobile-nav-header js-mobile-toggle">
            <span class="mobile-nav-link{% if is_link_active %} active{% endif %}">{{ link.title }}</span>
            {% if has_mega %}
              <button class="mobile-toggle-btn" aria-label="Toggle Submenu">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
            {% else %}
               <a href="{{ link.url }}" class="mobile-nav-link-overlay"></a>
            {% endif %}
          </div>

          {% if has_mega %}
            <div class="mobile-nav-dropdown js-mobile-dropdown">
              <div class="mobile-nav-dropdown-inner">
              <!-- Column 1 Heading -->
              <h4 class="mobile-sub-heading">{{ mega_block.settings.col1_heading }}</h4>
              <ul class="mobile-sub-list">
                {% for block_item in section.blocks %}
                  {%- liquid
                    assign item_trigger = block_item.settings.trigger_label | downcase | strip
                    assign current_link_title = link.title | downcase | strip
                  -%}
                  {% if item_trigger == current_link_title and block_item.settings.column == '1' %}
                    {% if block_item.type == 'mega_item' or block_item.type == 'mega_brand_item' %}
                      {% assign coll = block_item.settings.collection %}
                      <li>
                        <a href="{{ coll.url }}" class="mobile-sub-link">
                          {{ block_item.settings.custom_title | default: coll.title }}
                        </a>
                      </li>
                    {% elsif block_item.type == 'mega_manual_brand' %}
                      {% assign vendor_list_raw = block_item.settings.vendor_names | newline_to_br | split: '<br />' %}
                      {% for vendor_item in vendor_list_raw %}
                        {% assign brands_by_comma = vendor_item | split: ',' %}
                        {% for vendor_name_raw in brands_by_comma %}
                          {% assign vendor_name = vendor_name_raw | strip_html | strip %}
                          {% if vendor_name != blank %}
                            <li>
                              <a href="/collections/vendors?q={{ vendor_name | url_encode }}" class="mobile-sub-link">{{ vendor_name }}</a>
                            </li>
                          {% endif %}
                        {% endfor %}
                      {% endfor %}
                    {% elsif block_item.type == 'mega_tag_item' %}
                      {%- liquid
                        assign tag = block_item.settings.tag_name
                        assign coll_context = block_item.settings.collection
                        assign tag_handle = tag | handleize
                        if coll_context != blank
                          assign item_url = coll_context.url | append: '/' | append: tag_handle
                        else
                          assign item_url = '/collections/all/' | append: tag_handle
                        endif
                      -%}
                      <li>
                        <a href="{{ item_url }}" class="mobile-sub-link">
                          {{ block_item.settings.custom_title | default: tag }}
                        </a>
                      </li>
                    {% endif %}
                  {% endif %}
                {% endfor %}
              </ul>

              <!-- Column 2 Heading -->
              <h4 class="mobile-sub-heading">{{ mega_block.settings.col2_heading }}</h4>
              <ul class="mobile-sub-list">
                {% for block_item in section.blocks %}
                  {%- liquid
                    assign item_trigger = block_item.settings.trigger_label | downcase | strip
                    assign current_link_title = link.title | downcase | strip
                  -%}
                  {% if item_trigger == current_link_title and block_item.settings.column == '2' %}
                    {% if block_item.type == 'mega_item' or block_item.type == 'mega_brand_item' %}
                      {% assign coll = block_item.settings.collection %}
                      <li>
                        <a href="{{ coll.url }}" class="mobile-sub-link">
                          {{ block_item.settings.custom_title | default: coll.title }}
                        </a>
                      </li>
                    {% elsif block_item.type == 'mega_manual_brand' %}
                      {% assign vendor_list_raw = block_item.settings.vendor_names | newline_to_br | split: '<br />' %}
                      {% for vendor_item in vendor_list_raw %}
                        {% assign brands_by_comma = vendor_item | split: ',' %}
                        {% for vendor_name_raw in brands_by_comma %}
                          {% assign vendor_name = vendor_name_raw | strip_html | strip %}
                          {% if vendor_name != blank %}
                            <li>
                              <a href="/collections/vendors?q={{ vendor_name | url_encode }}" class="mobile-sub-link">{{ vendor_name }}</a>
                            </li>
                          {% endif %}
                        {% endfor %}
                      {% endfor %}
                    {% elsif block_item.type == 'mega_tag_item' %}
                      {%- liquid
                        assign tag = block_item.settings.tag_name
                        assign coll_context = block_item.settings.collection
                        assign tag_handle = tag | handleize
                        if coll_context != blank
                          assign item_url = coll_context.url | append: '/' | append: tag_handle
                        else
                          assign item_url = '/collections/all/' | append: tag_handle
                        endif
                      -%}
                      <li>
                        <a href="{{ item_url }}" class="mobile-sub-link">
                          {{ block_item.settings.custom_title | default: tag }}
                        </a>
                      </li>
                    {% endif %}
                  {% endif %}
                {% endfor %}
              </ul>

              <!-- Column 3 Heading -->
               <h4 class="mobile-sub-heading">{{ mega_block.settings.col3_heading }}</h4>
              <ul class="mobile-sub-list">
                {% for block_item in section.blocks %}
                  {%- liquid
                    assign item_trigger = block_item.settings.trigger_label | downcase | strip
                    assign current_link_title = link.title | downcase | strip
                  -%}
                  {% if item_trigger == current_link_title and block_item.settings.column == '3' %}
                    {% if block_item.type == 'mega_item' or block_item.type == 'mega_brand_item' %}
                      {% assign coll = block_item.settings.collection %}
                      <li>
                        <a href="{{ coll.url }}" class="mobile-sub-link">
                          {{ block_item.settings.custom_title | default: coll.title }}
                        </a>
                      </li>
                    {% elsif block_item.type == 'mega_manual_brand' %}
                      {% assign vendor_list_raw = block_item.settings.vendor_names | newline_to_br | split: '<br />' %}
                      {% for vendor_item in vendor_list_raw %}
                        {% assign brands_by_comma = vendor_item | split: ',' %}
                        {% for vendor_name_raw in brands_by_comma %}
                          {% assign vendor_name = vendor_name_raw | strip_html | strip %}
                          {% if vendor_name != blank %}
                            <li>
                              <a href="/collections/vendors?q={{ vendor_name | url_encode }}" class="mobile-sub-link">{{ vendor_name }}</a>
                            </li>
                          {% endif %}
                        {% endfor %}
                      {% endfor %}
                    {% elsif block_item.type == 'mega_tag_item' %}
                      {%- liquid
                        assign tag = block_item.settings.tag_name
                        assign coll_context = block_item.settings.collection
                        assign tag_handle = tag | handleize
                        if coll_context != blank
                          assign item_url = coll_context.url | append: '/' | append: tag_handle
                        else
                          assign item_url = '/collections/all/' | append: tag_handle
                        endif
                      -%}
                      <li>
                        <a href="{{ item_url }}" class="mobile-sub-link">
                          {{ block_item.settings.custom_title | default: tag }}
                        </a>
                      </li>
                    {% endif %}
                  {% endif %}
                {% endfor %}
              </ul>

              <!-- Featured Item -->
              {% assign featured_product = mega_block.settings.featured_product %}
              {% if featured_product != blank or mega_block.settings.featured_image != blank %}
                <div class="mobile-mega-featured">
                  <img 
                    src="{% if mega_block.settings.featured_image != blank %}{{ mega_block.settings.featured_image | img_url: '300x300', crop: 'center' }}{% else %}{{ featured_product.featured_image | img_url: '300x300', crop: 'center' }}{% endif %}" 
                    class="mobile-mega-featured-img" 
                    alt="{{ mega_block.settings.featured_title | default: featured_product.title }}"
                  >
                  <div style="font-size: 11px; color: #999; letter-spacing: 1px; text-transform: uppercase;">{{ mega_block.settings.featured_subtitle }}</div>
                  <h5 style="font-family: 'Playfair Display', serif; font-size: 18px; margin: 5px 0 15px;">{{ mega_block.settings.featured_title | default: featured_product.title }}</h5>
                  <a href="{{ mega_block.settings.featured_link | default: featured_product.url }}" class="mobile-sub-link" style="text-decoration: underline; font-weight: 600;">
                    {{ mega_block.settings.featured_button_text | default: 'SHOP NOW' }}
                  </a>
                </div>
              {% endif %}
              </div>
            </div>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </nav>
</div>

<!-- Cart Drawer -->
<div class="cart-drawer-overlay"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-drawer-header">
    <h2 class="cart-drawer-title">{{ section.settings.cart_drawer_title | default: 'Cart' }} <span>{{ cart.item_count }}</span></h2>
    <button class="cart-drawer-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="cart-drawer-content js-cart-items-container">
    {% if cart.item_count > 0 %}
      {% for item in cart.items %}
        <div class="cart-drawer-item" data-id="{{ item.id }}" data-index="{{ forloop.index }}">
          <div class="cart-drawer-item-image">
            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}">
          </div>
          <div class="cart-drawer-item-info">
            <a href="{{ item.url }}" class="cart-drawer-item-title">{{ item.product.title }}</a>
            <div class="cart-drawer-item-variant">{{ item.variant.title }}</div>
            <div class="cart-drawer-item-bundle">{{ item.vendor }}</div>
            <div class="cart-drawer-item-price">
              {{ item.final_price | money }}
              {% if item.original_price > item.final_price %}
                <s>{{ item.original_price | money }}</s>
              {% endif %}
            </div>
            
            <div class="cart-drawer-item-bottom">
              <div class="cart-drawer-quantity">
                <button type="button" class="qty-btn" onclick="adjustCartQty('{{ item.key }}', -1, this)">−</button>
                <input type="number" class="qty-input" value="{{ item.quantity }}" readonly>
                <button type="button" class="qty-btn" onclick="adjustCartQty('{{ item.key }}', 1, this)">+</button>
              </div>
              <div class="cart-drawer-item-subtotal" data-price="{{ item.price }}">{{ item.final_line_price | money }}</div>
            </div>
          </div>
          <div class="cart-drawer-item-remove" onclick="updateCartQty('{{ item.key }}', 0, this)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <div style="text-align:center; padding: 50px 0;">
        <div style="margin-bottom: 20px;">Your cart is empty</div>
        <a href="{{ routes.all_products_collection_url }}" class="continue-shopping-btn">Continue Shopping</a>
      </div>
    {% endif %}
  </div>

  <div class="cart-drawer-footer">
    <div class="drawer-summary-row">
      <span>SUBTOTAL</span>
      <span class="js-cart-subtotal">{{ cart.total_price | money }}</span>
    </div>
    <div class="drawer-summary-row discount js-discount-toggle">
      <span>DISCOUNT</span>
      <span class="toggle-icon">+</span>
    </div>
    <div class="drawer-discount-content js-discount-content">
      <div class="discount-input-wrap">
        <input type="text" class="discount-input" placeholder="Coupon code">
        <button type="button" class="discount-apply-btn js-discount-apply">Apply</button>
      </div>
    </div>
    <div class="drawer-summary-row total">
      <span>ESTIMATED TOTAL</span>
      <span class="js-cart-total">{{ cart.total_price | money }}</span>
    </div>
    <div class="drawer-disclaimer">
      {{ section.settings.cart_disclaimer | default: 'DUTIES AND TAXES INCLUDED. SHIPPING IS CALCULATED AT CHECKOUT.' }}
    </div>
    <div class="drawer-actions">
      <a href="/cart" class="drawer-btn drawer-btn-secondary">{{ section.settings.view_order_label | default: 'View Order' }}</a>
      <a href="/checkout" class="drawer-btn drawer-btn-primary">{{ section.settings.checkout_label | default: 'Proceed To Checkout' }}</a>
    </div>
  </div>
</div>

<script>
  // Wishlist Count Logic
  function updateWishlistCount() {
    const badge = document.querySelector('.wishlist-count-badge');
    if (!badge) return;
    
    try {
      const items = JSON.parse(localStorage.getItem('roshas_wishlist')) || [];
      const count = items.length;
      badge.textContent = count;
      
      if (count > 0) {
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    } catch(e) {
      badge.classList.add('hidden');
    }
  }

  document.addEventListener('DOMContentLoaded', updateWishlistCount);
  document.addEventListener('wishlist:updated', updateWishlistCount);

  function updateHeaderHeight() {
    const header = document.querySelector('.custom-header');
    const announcement = document.querySelector('.header-announcements') || document.querySelector('[class*="announcement-bar-"]');
    let totalHeight = 0;
    
    if (header) {
      totalHeight += header.offsetHeight;
    }
    if (announcement) {
      totalHeight += announcement.offsetHeight;
    }
    
    document.documentElement.style.setProperty('--header-total-height', totalHeight + 'px');
  }

  window.addEventListener('load', updateHeaderHeight);
  window.addEventListener('resize', updateHeaderHeight);
  document.addEventListener('shopify:section:load', updateHeaderHeight);
  updateHeaderHeight();

  // Search Toggle Logic
  document.addEventListener('DOMContentLoaded', () => {
    const searchTrigger = document.querySelector('.search-trigger-btn');
    const searchClose = document.querySelector('.search-close-btn');
    const searchOverlay = document.querySelector('.search-bar-overlay');
    const searchInput = document.querySelector('.search-bar-input');

    if (searchTrigger && searchOverlay) {
      searchTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        searchOverlay.classList.add('is-active');
        setTimeout(() => searchInput.focus(), 100);
      });
    }

    if (searchClose && searchOverlay) {
      searchClose.addEventListener('click', () => {
        searchOverlay.classList.remove('is-active');
      });
    }
    
    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchOverlay.classList.contains('is-active')) {
        searchOverlay.classList.remove('is-active');
      }
    });

    // Mobile Menu Logic
    const mobileTrigger = document.querySelector('.mobile-nav-trigger');
    const mobileDrawer = document.querySelector('.mobile-menu-drawer');
    const mobileBackdrop = document.querySelector('.mobile-menu-backdrop');
    const mobileClose = document.querySelector('.mobile-drawer-close');

    function toggleMobileMenu() {
      mobileDrawer.classList.toggle('active');
      mobileBackdrop.classList.toggle('active');
      document.body.style.overflow = mobileDrawer.classList.contains('active') ? 'hidden' : '';
    }

    if (mobileTrigger) mobileTrigger.addEventListener('click', toggleMobileMenu);
    if (mobileClose) mobileClose.addEventListener('click', toggleMobileMenu);
    if (mobileBackdrop) mobileBackdrop.addEventListener('click', toggleMobileMenu);

    // Mobile Accordion Logic
    document.querySelectorAll('.js-mobile-toggle').forEach(header => {
      header.addEventListener('click', () => {
        const btn = header.querySelector('.mobile-toggle-btn');
        if(!btn) return;
        const dropdown = header.closest('.mobile-nav-item').querySelector('.js-mobile-dropdown');
        btn.classList.toggle('active');
        dropdown.classList.toggle('active');
      });
    });
    // Sticky scroll header logic
    const stickyHeader = document.querySelector('.custom-header');
    if (stickyHeader) {
      // Create placeholder to prevent layout jump
      let placeholder = document.querySelector('.custom-header-placeholder');
      if (!placeholder) {
        placeholder = document.createElement('div');
        placeholder.className = 'custom-header-placeholder';
        stickyHeader.parentNode.insertBefore(placeholder, stickyHeader.nextSibling);
      }

      const updateSticky = () => {
        const scrollY = window.scrollY;
        const threshold = 100;
        
        if (scrollY > threshold) {
          if (!stickyHeader.classList.contains('is-sticky')) {
            placeholder.style.height = stickyHeader.offsetHeight + 'px';
            stickyHeader.classList.add('is-sticky');
            placeholder.classList.add('is-active');
          }
        } else {
          if (stickyHeader.classList.contains('is-sticky')) {
            stickyHeader.classList.remove('is-sticky');
            placeholder.classList.remove('is-active');
            placeholder.style.height = '0';
          }
        }
      };

      window.addEventListener('scroll', updateSticky, { passive: true });
      window.addEventListener('resize', updateSticky);
      // Initialize
      updateSticky();
    }

    // Cart Drawer Logic
    const cartTrigger = document.querySelector('.cart-trigger-btn');
    const cartDrawer = document.getElementById('cartDrawer');
    const cartOverlay = document.querySelector('.cart-drawer-overlay');
    const cartClose = document.querySelector('.cart-drawer-close');

    window.toggleCartDrawer = function(open = true) {
      if(open) {
        cartDrawer.classList.add('active');
        cartOverlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      } else {
        cartDrawer.classList.remove('active');
        cartOverlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    if (cartTrigger) {
      cartTrigger.addEventListener('click', (e) => {
        e.preventDefault();
        window.toggleCartDrawer(true);
      });
    }
    if (cartClose) cartClose.addEventListener('click', () => window.toggleCartDrawer(false));
    if (cartOverlay) cartOverlay.addEventListener('click', () => window.toggleCartDrawer(false));

    // Format money dynamically removed - relying on server exactly.

    window.adjustCartQty = function(key, delta, el) {
      const container = el.closest('.cart-drawer-quantity') || el.closest('.quantity-box');
      const input = container.querySelector('input');
      const currentQty = parseInt(input.value) || 0;
      const newQty = Math.max(0, currentQty + delta);
      
      updateCartQty(key, newQty, el);
    };

    let updateTimer;
    let pendingQtyUpdate = null;
    window.updateCartQty = function(key, qty, el) {
      // Optimistic Update UI (keep this instant)
      if (el) {
        const itemContainer = el.closest('.cart-drawer-item') || el.closest('tr') || el.closest('.cart-mobile-item');
        const input = itemContainer.querySelector('.qty-input') || itemContainer.querySelector('.quantity-input');
        const lineSubtotal = itemContainer.querySelector('.cart-drawer-item-subtotal') || itemContainer.querySelector('.line-price-value');
        
        if (qty > 0) {
          if (input) input.value = qty;
          if (lineSubtotal && !lineSubtotal.classList.contains('price-updating')) {
            // Use existing text to preserve exact currency symbol and format
            lineSubtotal.setAttribute('data-value', lineSubtotal.textContent.trim());
            lineSubtotal.classList.add('price-updating');
          }
        } else {
          itemContainer.style.opacity = '0.5';
          itemContainer.style.pointerEvents = 'none';
        }
      }

      // Animate all global totals
      document.querySelectorAll('.js-cart-subtotal, .js-cart-total').forEach(totalEl => {
        if (!totalEl.classList.contains('price-updating')) {
          totalEl.setAttribute('data-value', totalEl.textContent.trim());
          totalEl.classList.add('price-updating');
        }
      });

      // Store latest qty and debounce - always fires, no lock check
      pendingQtyUpdate = { key, qty };
      clearTimeout(updateTimer);
      updateTimer = setTimeout(() => {
        const { key: k, qty: q } = pendingQtyUpdate;
        pendingQtyUpdate = null;

        fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: k, quantity: q })
        })
        .then(response => response.json())
        .then(() => { updateCartState(); })
        .catch(() => {
          document.querySelectorAll('.price-updating').forEach(e => {
            e.classList.remove('price-updating');
            e.removeAttribute('data-value');
          });
        });
      }, 400);
    };

    // Discount Accordion & Apply Logic
    const discountToggle = document.querySelector('.js-discount-toggle');
    const discountContent = document.querySelector('.js-discount-content');
    const discountInput = document.querySelector('.discount-input');
    const discountApplyBtn = document.querySelector('.js-discount-apply');
    const checkoutBtn = document.querySelector('.drawer-btn-primary');

    if (discountToggle && discountContent) {
      discountToggle.addEventListener('click', () => {
        discountToggle.classList.toggle('active');
        discountContent.classList.toggle('active');
      });
    }

    if (discountApplyBtn && discountInput && checkoutBtn) {
      discountApplyBtn.addEventListener('click', () => {
        const code = discountInput.value.trim();
        if (code !== "") {
          const originalHref = "/checkout";
          checkoutBtn.href = `${originalHref}?discount=${encodeURIComponent(code)}`;
          discountApplyBtn.textContent = 'APPLIED';
          discountApplyBtn.style.background = '#4CAF50';
          setTimeout(() => {
            discountApplyBtn.textContent = 'APPLY';
            discountApplyBtn.style.background = '#000';
          }, 2000);
        }
      });
    }

    // Global AJAX Add to Cart Handler
    document.addEventListener('submit', (e) => {
      const form = e.target;
      if (form.matches('form[action^="/cart/add"]')) {
        e.preventDefault();
        
        const formData = new FormData(form);
        const submitBtn = form.querySelector('[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(item => {
          // Instant local update for better UX
          document.querySelectorAll('.cart-count-badge').forEach(badge => {
            let count = parseInt(badge.textContent) || 0;
            badge.textContent = count + (parseInt(formData.get('quantity')) || 1);
          });

          // Sync with server state
          window.updateCartState();
          // Open drawer
          window.toggleCartDrawer(true);
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
        })
        .finally(() => {
          if (submitBtn) submitBtn.disabled = false;
        });
      }
    });

    let isUpdatingCart = false;
    window.updateCartState = function() {
      // Request both sections in one call
      const sectionsParam = 'custom-header,main-cart';
      fetch(`${window.location.pathname}?sections=${sectionsParam}`)
      .then(response => {
        if (!response.ok) throw new Error('Refresh failed');
        return response.json();
      })
      .then(sections => {
        const parser = new DOMParser();

        // Update header/drawer from custom-header section
        if (sections['custom-header']) {
          const doc = parser.parseFromString(sections['custom-header'], 'text/html');

          const newBadge = doc.querySelector('.cart-count-badge');
          if (newBadge) {
            document.querySelectorAll('.cart-count-badge').forEach(b => b.textContent = newBadge.textContent);
          }
          const newDrawerCount = doc.querySelector('.cart-drawer-title span');
          if (newDrawerCount) {
            document.querySelectorAll('.cart-drawer-title span').forEach(s => s.textContent = newDrawerCount.textContent);
          }
          const newDrawerContent = doc.querySelector('.js-cart-items-container');
          if (newDrawerContent) {
            document.querySelector('.js-cart-items-container').innerHTML = newDrawerContent.innerHTML;
          }
          const newFooter = doc.querySelector('.cart-drawer-footer');
          if (newFooter) {
            document.querySelector('.cart-drawer-footer').innerHTML = newFooter.innerHTML;
          }
        }

        // Update main cart page from main-cart section
        if (sections['main-cart'] && document.querySelector('.cart-main-container')) {
          const doc2 = parser.parseFromString(sections['main-cart'], 'text/html');
          const newMainCart = doc2.querySelector('.cart-main-container');
          if (newMainCart) {
            document.querySelector('.cart-main-container').innerHTML = newMainCart.innerHTML;
          }
        }
      })
      .catch(error => {
        console.warn('Cart update failed. Falling back to reload...', error);
        location.reload(); // Reliable backup
      })
      .finally(() => {
        document.querySelectorAll('.price-updating').forEach(el => {
          el.classList.remove('price-updating');
          el.removeAttribute('data-value');
        });
        isUpdatingCart = false;
      });
    }
  });
</script>


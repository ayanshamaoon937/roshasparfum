{%- liquid
  assign main_menu = section.settings.menu
  assign logo_image = section.settings.logo_image
  assign logo_text = section.settings.logo_text | default: shop.name
-%}

{% style %}
  .custom-header {
    background: #ffffff;
    border-bottom: 1px solid #f0f0f0;
    position: relative;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 15px 0;
    transition: padding 0.3s ease, box-shadow 0.3s ease;
  }

  .custom-header.is-sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 10px 0;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
    background: #ffffff;
    z-index: 2005;
    animation: slideDownCustom 0.4s ease forwards;
  }

  @keyframes slideDownCustom {
    from { transform: translateY(-100%); }
    to { transform: translateY(0); }
  }

  .custom-header-placeholder {
    display: none;
  }

  .custom-header-placeholder.is-active {
    display: block;
  }

  @keyframes slideDown {
    from { transform: translateY(-100%); }
    to { transform: translateY(0); }
  }

  body {
    padding-top: 0;
  }

  .mobile-nav-trigger {
    display: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #000;
  }

  .mobile-nav-trigger svg {
    width: 24px;
    height: 24px;
  }


  .header-container {
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-margin);
  }

  /* Logo */
  .header-logo {
    flex: 0 0 200px;
  }

  .logo-link {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 500;
    color: #000;
    text-decoration: none;
    letter-spacing: 4px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
  }

  .logo-img {
    max-height: {{ section.settings.logo_max_height_mobile | default: 80 }}px;
    max-width: {{ section.settings.logo_max_width_mobile | default: 80 }}px;
    margin-left: {{ section.settings.logo_margin_left_mobile | default: 0 }}px;
    width: auto;
  }

  @media screen and (min-width: 991px) {
    .logo-img {
      max-height: {{ section.settings.logo_max_height_desktop | default: 50 }}px;
      max-width: {{ section.settings.logo_max_width_desktop | default: 200 }}px;
      margin-left: {{ section.settings.logo_margin_left_desktop | default: 0 }}px;
      margin-right: 0;
    }
  }

  /* Navigation */
  .header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    gap: 35px;
    margin: 0;
    padding: 0;
    list-style: none !important;
  }

  .nav-list li {
    list-style: none !important;
    display: flex;
    align-items: center;
  }


  .nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #808080;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 10px 0 5px 2px;
    display: flex;
    align-items: center;
    gap: 6px;
    position: relative;
    pointer-events: auto;
  }

  /* Hover Bridge for Mega Menu - Widened to cover gaps between links */
  .nav-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: -17.5px;
    width: calc(100% + 35px);
    height: 70px; /* Briding the gap to the mega menu more robustly */
    background: transparent;
    z-index: 10;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: #000000;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after,
  .nav-link.is-active::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link:hover,
  .nav-link.is-active,
  .nav-link.active {
    color: #000000;
  }

  .nav-link .chevron {
    width: 16px;
    height: 16px;
    opacity: 0.6;
    transition: transform 0.3s ease;
  }

  .nav-item:hover .chevron {
    transform: rotate(180deg);
  }

  /* Icons */
  .header-icons {
    flex: 0 0 200px;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 24px;
  }

  .header-icon-link {
    color: #000;
    text-decoration: none;
    position: relative;
    display: flex;
    align-items: center;
    transition: opacity 0.3s ease;
  }

  .header-icon-link:hover {
    opacity: 0.7;
  }

  .header-icon-link svg {
    width: 20px;
    height: 20px;
  }

  .cart-count-badge,
  .wishlist-count-badge {
    position: absolute;
    top: -8px;
    right: -10px;
    background: #000000;
    color: #fff;
    font-size: 10px;
    font-weight: 600;
    min-width: 16px;
    min-height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wishlist-count-badge.hidden {
    display: none;
  }

  /* Mega Menu Container */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    width: 100%;
    background: #fff;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border-top: 1px solid #f5f5f5;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: 10;
  }

  .nav-item:hover .mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mega-menu-content {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 60px var(--page-margin);
  }

  .mega-columns-wrap {
    display: grid;
    grid-template-columns: 320px 1fr 1fr;
    gap: 80px;
    align-items: flex-start;
  }

  /* Featured Column Styling */
  .mega-featured-col {
    background: #fcfcfc;
    padding: 40px;
    border: 1px solid #f2f2f2;
    text-align: center;
  }

  .mega-featured-image-wrap {
    width: 200px;
    height: 200px;
    margin: 0 auto 25px;
    background: #fff;
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mega-featured-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .mega-featured-title {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 500;
    font-style: italic;
    color: #1a1a1a;
    margin-bottom: 10px;
  }

  .mega-featured-subtitle {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 30px;
    font-weight: 500;
  }

  /* Mega Menu Vendor Styles */
  .mega-vendor-link {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #666;
    transition: color 0.3s ease;
  }
  .mega-menu-list li {
    margin-bottom: 12px;
    list-style: none !important;
  }

  .mega-featured-btn {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #000;
    text-decoration: none;
    padding-bottom: 5px;
    border-bottom: 1px solid #000;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }

  .mega-featured-btn:hover {
    color: #808080;
    border-color: #808080;
  }

  .mega-featured-shop-now {
    background: #808080;
    color: #fff;
    padding: 14px 35px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.4s ease;
  }

  .mega-featured-shop-now::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: #000000;
    transition: width 0.4s ease;
    z-index: -1;
  }

  .mega-featured-shop-now:hover::before {
    width: 100%;
  }

  .mega-featured-shop-now:hover {
    color: #ffffff;
  }

  /* List Columns */
  .mega-column-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: #1a1a1a;
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #f0f0f0;
  }

  .mega-menu-list {
    list-style: none !important;
    padding: 0;
    margin: 0;
    padding-inline-start: 0 !important;
  }

  .mega-menu-list li {
    margin-bottom: 15px;
    list-style: none !important;
  }

  .mega-menu-list li::marker {
    display: none !important;
    content: none !important;
  }

  .mega-menu-list a {
    color: #808080;
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.2;
    transition: color 0.3s ease;
    display: block;
  }

  .mega-menu-list a:hover {
    color: #121212;
  }

  .collection-title {
    display: block;
    margin-bottom: 2px;
  }

  .mega-menu-list span.desc {
    display: block;
    font-size: 11px;
    color: #808080;
    margin-top: 4px;
    font-weight: 400;
    letter-spacing: 0.3px;
    text-transform: none;
  }
   .mega-menu-list a:hover span.desc {
    color: #121212;
   }

  /* Bottom Bar */
  .mega-bottom-bar {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 20px var(--page-margin);
    border-top: 1px solid #f5f5f5;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .mega-bottom-disclaimer {
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #999;
  }

  .mega-bottom-view-all {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #808080;
    text-decoration: none;
    font-weight: 600;

  }

  .mega-bottom-view-all:hover {
    text-decoration: underline;
    color: #121212;
    text-underline-offset: 3px;
  }

  /* Grid Layout Fix */
  .mega-columns-wrap {
    display: flex;
    gap: 30px;
    flex: 1;
  }

  /* Search Bar Overlay */
  .search-bar-overlay {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: #fff;
    z-index: 10;
    display: flex;
    align-items: center;
    padding: 30px 40px;
    transform: translateY(-100%);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    visibility: hidden;
    border-bottom: 1px solid #f0f0f0;
    @media screen and (max-width: 989px) {
      padding: 15px 16px;
    }
  }


  .search-bar-overlay.is-active {
    transform: translateY(0);
    visibility: visible;
  }

  .search-bar-form {
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    position: relative;
    padding: 0;
    @media screen and (max-width: 989px) {
      padding: 0;
    }
  }

  .search-bar-input {
    width: 100%;
    border: none;
    border-bottom: 2px solid #e0e0e0;
    padding: 10px 0;
    font-size: 32px;
    font-family: 'Playfair Display', serif;
    color: #000;
    background: transparent;
    outline: none;
    border-radius:0;
    @media screen and (max-width: 989px) {
      font-size: 20px;
    }
  }

  .search-bar-input::placeholder {
    color: #ccc;
  }

  .search-close-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 1px;
    padding-bottom: 4px;
    border-bottom: 1px solid #000;
    position: absolute;
    right: 0;
    top: 0%;
    transform: translateY(0%);
    background: none;
    border: none;
    color: #000;
    font-family: 'Jost', sans-serif;
  }

  .search-close-btn svg {
    width: 16px;
    height: 16px;
  }

  .search-arrow-btn {
    display: none;
    @media screen and (max-width: 989px) {
      display: block;
      position: absolute;
      right: 0;
      bottom: 15px;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
    }
  }

  .search-arrow-btn svg {
    width: 24px;
    height: 24px;
    color: #000;
  }

  @media screen and (max-width: 989px) {
    .search-close-btn {
      position: absolute;
      top: -45px;
      right: 0;
      border: none;
      padding: 0;
    }
    .search-close-btn span {
      display: none;
    }
    .search-close-btn svg {
      width: 24px;
      height: 24px;
    }
    .search-bar-overlay {
      padding-top: 60px !important;
    }
  }

  /* Mobile Responsive */
  @media screen and (max-width: 990px) {
    .header-nav {
      display: none;
    }
    .mobile-nav-trigger {
      display: block;
      flex: 0 0 40px;
    }
    .header-logo {
      flex: 1;
      display: flex;
      justify-content: center;
    }
    .header-icons {
      flex: 0 0 auto;
      gap: 15px;
    }
    .header-icons a[href="/account"] {
      display: none;
    }
    .logo-link {
      font-size: 24px;
      letter-spacing: 2px;
    }
    .header-container {
      padding: 0 16px;
    }
    .header-icon-link svg {
      width: 20px;
      height: 20px;
    }
  }

  /* Mobile Drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: -100%;
    width: 85%;
    max-width: 400px;
    height: 100%;
    background: #fff;
    z-index: 99999;
    transition: left 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    padding: 20px 20px;
    box-shadow: 10px 0 30px rgba(0,0,0,0.1);
  }

  .mobile-menu-drawer nav {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 0px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .mobile-menu-drawer nav::-webkit-scrollbar {
    display: none;
  }

  .mobile-menu-drawer.active {
    left: 0;
  }

  .mobile-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .mobile-drawer-header .logo-link img{
    margin-left:0
  }

  .mobile-drawer-close {
    background: none;
    border: none;
    padding: 0px;
    cursor: pointer;
    color:#000;
  }


  .mobile-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .mobile-nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #000;
    text-decoration: none;
    display: block;
    position: relative;
    padding-bottom: 4px;
  }

  .mobile-nav-link.active {
    color: #000000;
  }

  .mobile-nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 30px;
    height: 1px;
    background: transparent;
  }

  .mobile-menu-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    z-index: 1999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .mobile-menu-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  /* Mobile Accordion Styles */
  .mobile-nav-item {
    border-bottom: 1px solid #f5f5f5;
  }

  .mobile-nav-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    position: relative;
    cursor: pointer;
  }

  .mobile-nav-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .mobile-nav-link {
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #000;
    text-decoration: none;
    flex: 1;
  }

  .mobile-toggle-btn {
    background: none;
    border: none;
    padding: 0px;
    cursor: pointer;
    display: flex;
    align-items: center;
    color: #999;
    transition: transform 0.3s ease;
  }

  .mobile-toggle-btn.active {
    transform: rotate(180deg);
  }

  .mobile-nav-dropdown {
    display: grid;
    grid-template-rows: 0fr;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    overflow: hidden;
    padding-left: 0px;
    opacity: 0;
  }

  .mobile-nav-dropdown.active {
    grid-template-rows: 1fr;
    padding-bottom: 20px;
    opacity: 1;
  }

  .mobile-nav-dropdown-inner {
    min-height: 0;
  }

  .mobile-sub-heading {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    margin: 20px 0 10px;
    color: #000;
  }

  .mobile-sub-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-sub-list li {
    margin-bottom: 12px;
  }

  .mobile-sub-link {
    font-size: 14px;
    color: #666;
    text-decoration: none;
    display: block;
  }

  .mobile-mega-featured {
    margin-top: 25px;
    padding: 20px;
    background: #fcfcfc;
    border: 1px solid #f2f2f2;
    text-align: center;
  }

  .mobile-mega-featured-img {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin: 0 auto 15px;
  }
  /* Cart Drawer Styles */
  .cart-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }
  .cart-drawer-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: -100%;
    width: 450px;
    max-width: 95%;
    height: 100%;
    background: #fff;
    z-index: 2001;
    transition: right 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -10px 0 30px rgba(0,0,0,0.1);
  }
  .cart-drawer.active {
    right: 0;
  }

  .cart-drawer-header {
    padding: 15px 10px 15px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #f5f5f5;
  }
  .cart-drawer-title {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    color: #000;
    margin-bottom:0;
  }
  .cart-drawer-title span {
    color: #999;
    font-weight: 400;
    margin-left: 10px;
    font-family: var(--font-body--family);
  }
  .cart-drawer-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    color: #000;
  }

  .cart-drawer-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px 15px;
    background: #fcfcfc;
  }

  .cart-drawer-item {
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 0px;
    padding: 15px;
    margin-bottom: 15px;
    display: flex;
    gap: 15px;
    position: relative;
  }
  .cart-drawer-item-image {
    width: 100px;
    height: 100px;
    border-radius: 0px;
    overflow: hidden;
    background: #f9f9f9;
    flex-shrink: 0;
  }
  .cart-drawer-item-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .cart-drawer-item-info {
    flex-grow: 1;
  }
  .cart-drawer-item-title {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 0;
    display: block;
    color: #000;
    text-decoration: none;
    line-height: 1.4;
    padding-right: 20px;
  }
  .cart-drawer-item-variant {
    font-size: 12px;
    color: #999;
    margin-bottom: 0;
    text-transform: uppercase;
  }
  .cart-drawer-item-bundle {
    font-size: 12px;
    color: #666;
    margin-bottom: 0;
  }
  .cart-drawer-item-price {
    font-size: 14px;
    font-weight: 500;
    color: #000;
  }
  .cart-drawer-item-price s {
    color: #ccc;
    font-weight: 400;
    margin-left: 8px;
  }

  .cart-drawer-item-remove {
    position: absolute;
    top: 15px;
    right: 15px;
    color: #999;
    cursor: pointer;
    transition: color 0.2s;
  }
  .cart-drawer-item-remove:hover {
    color: #000;
  }

  .js-cart-subtotal, .js-cart-total, .cart-drawer-item-subtotal {
    /* Base styles */
  }
  .price-updating {
    --shimmer-text-color: rgb(0 0 0 / 0.5);
    --shimmer-color-light: rgb(0 0 0 / 0.1);
    --shimmer-speed: 1.25s;
    color: transparent !important;
    position: relative;
    display: inline-block;
  }
  .price-updating::after {
    content: attr(data-value);
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: linear-gradient(-85deg, var(--shimmer-text-color) 10%, var(--shimmer-color-light) 50%, var(--shimmer-text-color) 90%);
    background-clip: text;
    -webkit-background-clip: text;
    background-size: 200% 100%;
    animation: text-shimmer var(--shimmer-speed) infinite linear;
  }

  .cart-drawer-item-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
  }
  .cart-drawer-quantity {
    display: flex;
    align-items: center;
    border: 1px solid #f0f0f0;
    height: 32px;
    border-radius: 0;
  }
  .qty-btn {
    width: 32px;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color:#000;
  }
  .qty-input {
    width: 35px;
    border: none;
    font-size: 13px;
    height: 100%;
    padding: 0;
    text-align: center;
    background: transparent;
    -moz-appearance: textfield;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-drawer-item-subtotal {
    font-size: 11px;
    font-weight: 500;
    color: #000;
  }

  .cart-drawer-footer {
    padding: 20px 15px;
    background: #fff;
    border-top: 1px solid #f5f5f5;
  }
  .drawer-summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 13px;
    text-transform: uppercase;
    color: #666;
    letter-spacing: 0.5px;
  }
  .drawer-summary-row span:last-child {
    color: #000;
    font-weight: 500;
    text-transform: none;
  }
  .drawer-summary-row.discount {
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    margin-bottom: 0;
    padding: 12px 0;
  }
  .drawer-summary-row.discount .toggle-icon {
    font-size: 18px;
    font-weight: 300;
    transition: transform 0.3s ease;
  }
  .drawer-summary-row.discount.active .toggle-icon {
    transform: rotate(45deg);
  }

  .drawer-discount-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .drawer-discount-content.active {
    max-height: 100px;
    margin-bottom: 20px;
    transition: 0.2s all ease-in-out;
  }
  .discount-input-wrap {
    display: flex;
    gap: 10px;
    padding-top: 10px;
  }
  .discount-input {
    flex: 1;
    height: 40px;
    border: 1px solid #e0e0e0;
    padding: 0 12px;
    font-size: 13px;
    border-radius: 0;
    outline: none;
    transition: border-color 0.2s;
  }
  .discount-input:focus {
    border-color: #000;
  }
  .discount-apply-btn {
    background: #000;
    color: #fff;
    border: none;
    padding: 0 15px;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
  }
  .drawer-summary-row.total {
    margin-top: 20px;
    font-size: 15px;
    font-weight: 600;
    color: #000;
  }
  .drawer-summary-row.total span:last-child {
    font-size: 16px;
  }
  .drawer-disclaimer {
    font-size: 11px;
    color: #999;
    margin-bottom: 25px;
    line-height: 1.5;
    text-transform: uppercase;
  }
  .drawer-actions {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 15px;
  }
  .drawer-btn {
    padding: 18px 0;
    text-align: center;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    border-radius: 0;
    transition: all 0.3s ease;
  }
  .drawer-btn-secondary {
    border:1px solid #333;
    color: #333;
  }
  .drawer-btn-primary {
    background: #000;
    color: #fff;
  }
  .drawer-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  @media screen and (max-width: 480px) {
    .cart-drawer {
      width: 100%;
    }
  }

  /* Mobile Search Bar */
  .mobile-drawer-search {
    padding: 0 20px 20px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 20px;
  }
  .mobile-search-form {
    display: flex;
    align-items: center;
    background: #f9f9f9;
    padding: 0 12px;
    height: 44px;
    border-radius: 4px;
  }
  .mobile-search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    outline: none;
    padding: 0;
  }
  .mobile-search-submit {
    background: none;
    border: none;
    padding: 0;
    margin-left: 8px;
    display: flex;
    align-items: center;
    color: #000;
  }
{% endstyle %}

<header class="custom-header">
  <div class="search-bar-overlay">
    <form action="/search" method="get" class="search-bar-form">
      <input type="text" name="q" placeholder="Type something" class="search-bar-input" autocomplete="off">
      <button type="submit" class="search-arrow-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </button>
      <button type="button" class="search-close-btn">
        <span>Close</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </form>
  </div>
  <div class="header-container">
    <!-- Mobile Trigger -->
    <button type="button" class="mobile-nav-trigger" aria-label="Menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>

    <!-- Logo -->
    <div class="header-logo">
      <a href="/" class="logo-link">
        {% if logo_image %}
          <img src="{{ logo_image | img_url: '400x' }}" alt="{{ logo_text }}" class="logo-img">
        {% else %}
          {{ logo_text }}
        {% endif %}
      </a>
    </div>

    <!-- Navigation -->
    <nav class="header-nav">
      <ul class="nav-list">
        {% for link in main_menu.links %}
          {%- liquid
            assign has_mega = false
            assign mega_block = null
            for block in section.blocks
              assign trigger = block.settings.trigger_label | downcase | strip
              assign link_title = link.title | downcase | strip
              if trigger == link_title
                assign has_mega = true
                assign mega_block = block
                break
              endif
            endfor

            assign is_link_active = false
            if link.active or link.child_active
              assign is_link_active = true
            endif

            # Manual Overrides for Mega Menu Parents
            assign current_path = request.path | downcase
            assign link_title = link.title | downcase
            
            if request.page_type == 'collection'
              if current_path contains '/vendors' or current_path contains '/brands' or request.query_string contains 'q='
                # Highlighting Brands only
                if link_title == 'brands'
                  assign is_link_active = true
                else
                  assign is_link_active = false
                endif
              else
                # Highlighting Collections only
                # Only highlight 'Collections' parent if we are NOT on the 'all' collection (which belongs to 'Shop')
                if link_title == 'collections'
                  if collection.handle != 'all'
                    assign is_link_active = true
                  else
                    assign is_link_active = false
                  endif
                endif
              endif
            elsif request.page_type == 'product'
              if link_title == 'collections'
                assign is_link_active = true
              endif
            endif

            # Specific check for 'Shop' to avoid highlight on sub-collections
            if link_title == 'shop'
              if link.active
                assign is_link_active = true
              else
                assign is_link_active = false
              endif
            endif
          -%}

          <li class="nav-item">
            <a href="{{ link.url }}" class="nav-link{% if is_link_active %} is-active active{% endif %}">
              {{ link.title }}
              {% if has_mega %}
                <span class="chevron">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </span>
              {% endif %}
            </a>

            {% if has_mega %}
              <div class="mega-menu">
                <div class="mega-menu-content">
                  <!-- Navigation Columns Wrap (3 Columns) -->
                  <div class="mega-columns-wrap">
                    <!-- Column 1: Featured Highlight -->
                    {%- assign featured_product = mega_block.settings.featured_product -%}
                    <div class="mega-column mega-featured-col" style="flex: 0.7;">
                      <div class="mega-featured-highlight" style="margin-bottom: 12px;">
                        <span class="star">★</span> FEATURED HIGHLIGHT
                      </div>
                      <div class="mega-featured-card-internal">
                        {%- if featured_product != blank or mega_block.settings.featured_image != blank -%}
                          <div class="mega-featured-image-wrap">
                            <img 
                              src="{% if mega_block.settings.featured_image != blank %}{{ mega_block.settings.featured_image | img_url: '400x400', crop: 'center' }}{% else %}{{ featured_product.featured_image | img_url: '400x400', crop: 'center' }}{% endif %}" 
                              class="mega-featured-image" 
                              alt="{{ mega_block.settings.featured_title | default: featured_product.title }}"
                            >
                          </div>
                        {%- endif -%}
                        <h3 class="mega-featured-title" style="margin: 12px 0 4px;">{{ mega_block.settings.featured_title | default: featured_product.title }}</h3>
                        <p class="mega-featured-subtitle">{{ mega_block.settings.featured_subtitle }}</p>
                        
                        {% if mega_block.type == 'collections_mega' %}
                          <a href="{{ mega_block.settings.featured_link | default: featured_product.url }}" class="mega-featured-shop-now">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-bag w-5 h-5 stroke-[1.5]"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                            {{ mega_block.settings.featured_button_text | default: 'SHOP NOW' }}
                          </a>
                        {% else %}
                          <a href="{{ mega_block.settings.featured_link | default: featured_product.url }}" class="mega-featured-btn">
                            {{ mega_block.settings.featured_button_text | default: 'EXPLORE THE ATELIER' }}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                          </a>
                        {% endif %}
                      </div>
                    </div>

                    <!-- Column 2: First Collection List -->
                    <div class="mega-column" style="flex: 1;">
                      <h4 class="mega-column-title">{{ mega_block.settings.col1_heading }}</h4>
                      <ul class="mega-menu-list">
                        <!-- Block-based Items (Single entries) -->
                        {%- for block_item in section.blocks -%}
                          {%- liquid
                            assign item_trigger = block_item.settings.trigger_label | downcase | strip
                            assign current_link_title = link.title | downcase | strip
                          -%}
                          {%- if item_trigger == current_link_title and block_item.settings.column == '1' -%}
                            {%- liquid
                              if block_item.type == 'mega_item'
                                assign coll = block_item.settings.collection
                                assign item_url = coll.url
                                assign title = block_item.settings.custom_title | default: coll.title
                                assign desc = block_item.settings.custom_description | default: coll.description
                                render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: false
                              elsif block_item.type == 'mega_brand_item'
                                assign coll = block_item.settings.collection
                                assign item_url = coll.url
                                assign title = block_item.settings.custom_title | default: coll.title
                                assign desc = block_item.settings.custom_description
                                render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: true
                              elsif block_item.type == 'mega_manual_brand'
                                assign vendor_list_raw = block_item.settings.vendor_names | newline_to_br | split: '<br />'
                                for vendor_item in vendor_list_raw
                                  assign brands_by_comma = vendor_item | split: ','
                                  for vendor_name_raw in brands_by_comma
                                    assign vendor_name = vendor_name_raw | strip_html | strip
                                    if vendor_name != blank
                                      assign vendor_encoded = vendor_name | url_encode
                                      assign item_url = "/collections/vendors?q=" | append: vendor_encoded
                                      render 'mega-menu-item-link', item_url: item_url, title: vendor_name, is_vendor: true
                                    endif
                                  endfor
                                endfor
                              elsif block_item.type == 'mega_tag_item'
                                assign tag = block_item.settings.tag_name
                                assign coll_context = block_item.settings.collection
                                assign tag_handle = tag | handleize
                                if coll_context != blank
                                  assign item_url = coll_context.url | append: '/' | append: tag_handle
                                else
                                  assign item_url = '/collections/all/' | append: tag_handle
                                endif
                                assign title = block_item.settings.custom_title | default: tag
                                assign desc = block_item.settings.custom_description
                                render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: false
                              endif
                            -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    </div>

                    <!-- Column 3: Second Collection List -->
                    <div class="mega-column" style="flex: 1;">
                      <h4 class="mega-column-title">{{ mega_block.settings.col2_heading }}</h4>
                      <ul class="mega-menu-list">
                        <!-- Block-based Items (Single entries) -->
                        {%- for block_item in section.blocks -%}
                          {%- liquid
                            assign item_trigger = block_item.settings.trigger_label | downcase | strip
                            assign current_link_title = link.title | downcase | strip
                          -%}
                          {%- if item_trigger == current_link_title and block_item.settings.column == '2' -%}
                            {%- liquid
                              if block_item.type == 'mega_item'
                                assign coll = block_item.settings.collection
                                assign item_url = coll.url
                                assign title = block_item.settings.custom_title | default: coll.title
                                assign desc = block_item.settings.custom_description | default: coll.description
                                render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: false
                              elsif block_item.type == 'mega_brand_item'
                                assign coll = block_item.settings.collection
                                assign item_url = coll.url
                                assign title = block_item.settings.custom_title | default: coll.title
                                assign desc = block_item.settings.custom_description
                                render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: true
                              elsif block_item.type == 'mega_manual_brand'
                                assign vendor_list_raw = block_item.settings.vendor_names | newline_to_br | split: '<br />'
                                for vendor_item in vendor_list_raw
                                  assign brands_by_comma = vendor_item | split: ','
                                  for vendor_name_raw in brands_by_comma
                                    assign vendor_name = vendor_name_raw | strip_html | strip
                                    if vendor_name != blank
                                      assign vendor_encoded = vendor_name | url_encode
                                      assign item_url = "/collections/vendors?q=" | append: vendor_encoded
                                      render 'mega-menu-item-link', item_url: item_url, title: vendor_name, is_vendor: true
                                    endif
                                  endfor
                                endfor
                              elsif block_item.type == 'mega_tag_item'
                                assign tag = block_item.settings.tag_name
                                assign coll_context = block_item.settings.collection
                                assign tag_handle = tag | handleize
                                if coll_context != blank
                                  assign item_url = coll_context.url | append: '/' | append: tag_handle
                                else
                                  assign item_url = '/collections/all/' | append: tag_handle
                                endif
                                assign title = block_item.settings.custom_title | default: tag
                                assign desc = block_item.settings.custom_description
                                render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: false
                              endif
                            -%}
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    </div>

                    {%- if mega_block.type == 'brands_mega' or mega_block.type == 'collections_mega' -%}
                      <!-- Column 4: Third Collection List -->
                      <div class="mega-column" style="flex: 1;">
                        <h4 class="mega-column-title">{{ mega_block.settings.col3_heading }}</h4>
                        <ul class="mega-menu-list">
                          <!-- Block-based Items (Single entries) -->
                          {%- for block_item in section.blocks -%}
                            {%- liquid
                              assign item_trigger = block_item.settings.trigger_label | downcase | strip
                              assign current_link_title = link.title | downcase | strip
                            -%}
                            {%- if item_trigger == current_link_title and block_item.settings.column == '3' -%}
                              {%- liquid
                                if block_item.type == 'mega_item'
                                  assign coll = block_item.settings.collection
                                  assign item_url = coll.url
                                  assign title = block_item.settings.custom_title | default: coll.title
                                  assign desc = block_item.settings.custom_description | default: coll.description
                                  render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: false
                                elsif block_item.type == 'mega_brand_item'
                                  assign coll = block_item.settings.collection
                                  assign item_url = coll.url
                                  assign title = block_item.settings.custom_title | default: coll.title
                                  assign desc = block_item.settings.custom_description
                                  render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: true
                                elsif block_item.type == 'mega_manual_brand'
                                  assign vendor_list_raw = block_item.settings.vendor_names | newline_to_br | split: '<br />'
                                  for vendor_item in vendor_list_raw
                                    assign brands_by_comma = vendor_item | split: ','
                                    for vendor_name_raw in brands_by_comma
                                      assign vendor_name = vendor_name_raw | strip_html | strip
                                      if vendor_name != blank
                                        assign vendor_encoded = vendor_name | url_encode
                                        assign item_url = "/collections/vendors?q=" | append: vendor_encoded
                                        render 'mega-menu-item-link', item_url: item_url, title: vendor_name, is_vendor: true
                                      endif
                                    endfor
                                  endfor
                                elsif block_item.type == 'mega_tag_item'
                                  assign tag = block_item.settings.tag_name
                                  assign coll_context = block_item.settings.collection
                                  assign tag_handle = tag | handleize
                                  if coll_context != blank
                                    assign item_url = coll_context.url | append: '/' | append: tag_handle
                                  else
                                    assign item_url = '/collections/all/' | append: tag_handle
                                  endif
                                  assign title = block_item.settings.custom_title | default: tag
                                  assign desc = block_item.settings.custom_description
                                  render 'mega-menu-item-link', item_url: item_url, title: title, desc: desc, is_vendor: false
                                endif
                              -%}
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                  </div>
                </div>

                <!-- Bottom Bar -->
                <div class="mega-bottom-bar">
                  <div class="mega-bottom-disclaimer">
                    {{ mega_block.settings.bottom_left_text | default: 'AUTHENTICITY GUARANTEED ON EVERY PURCHASE' }}
                  </div>
                  <a href="{{ mega_block.settings.bottom_right_link }}" class="mega-bottom-view-all">
                    {{ mega_block.settings.bottom_right_label | default: 'VIEW ALL' }}
                  </a>
                </div>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- Icons -->
    <div class="header-icons">
      <button type="button" class="header-icon-link search-trigger-btn" style="background:none; border:none; padding:0; cursor:pointer; color:inherit;">
        <svg viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.4625 11.6016L8.40469 7.54375C9.03438 6.72969 9.375 5.73438 9.375 4.6875C9.375 3.43438 8.88594 2.25937 8.00156 1.37344C7.11719 0.4875 5.93906 0 4.6875 0C3.43594 0 2.25781 0.489062 1.37344 1.37344C0.4875 2.25781 0 3.43438 0 4.6875C0 5.93906 0.489062 7.11719 1.37344 8.00156C2.25781 8.8875 3.43438 9.375 4.6875 9.375C5.73438 9.375 6.72813 9.03438 7.54219 8.40625L11.6 12.4625C11.6119 12.4744 11.626 12.4838 11.6416 12.4903C11.6571 12.4967 11.6738 12.5001 11.6906 12.5001C11.7075 12.5001 11.7241 12.4967 11.7397 12.4903C11.7552 12.4838 11.7694 12.4744 11.7812 12.4625L12.4625 11.7828C12.4744 11.7709 12.4838 11.7568 12.4903 11.7412C12.4967 11.7257 12.5001 11.709 12.5001 11.6922C12.5001 11.6754 12.4967 11.6587 12.4903 11.6431C12.4838 11.6276 12.4744 11.6135 12.4625 11.6016ZM7.1625 7.1625C6.5 7.82344 5.62187 8.1875 4.6875 8.1875C3.75313 8.1875 2.875 7.82344 2.2125 7.1625C1.55156 6.5 1.1875 5.62187 1.1875 4.6875C1.1875 3.75313 1.55156 2.87344 2.2125 2.2125C2.875 1.55156 3.75313 1.1875 4.6875 1.1875C5.62187 1.1875 6.50156 1.55 7.1625 2.2125C7.82344 2.875 8.1875 3.75313 8.1875 4.6875C8.1875 5.62187 7.82344 6.50156 7.1625 7.1625Z" fill="currentColor"/>
        </svg>
      </button>
      <a href="{{ section.settings.wishlist_link | default: '/apps/wishlist' }}" class="header-icon-link">
        <svg viewBox="0 0 20 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14.75 0.75C11.55 0.75 9.75 3.417 9.75 4.75C9.75 3.417 7.95 0.75 4.75 0.75C1.55 0.75 0.75 3.417 0.75 4.75C0.75 11.75 9.75 16.75 9.75 16.75C9.75 16.75 18.75 11.75 18.75 4.75C18.75 3.417 17.95 0.75 14.75 0.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="wishlist-count-badge hidden">0</span>
      </a>
      <a href="/account" class="header-icon-link">

{%- if template.name != 'search' and collection.handle != 'all' and collection.handle != 'vendors' -%}
<div class="custom-search-bar section-v-padding color-{{ section.settings.color_scheme }}">
  <div class="container--page-width">
    <div class="search-bar-wrapper">
      <form action="/search" method="get" class="search-form-inline">
        <div class="search-input-group">
          <input 
            type="text" 
            name="q" 
            placeholder="{{ section.settings.placeholder | default: 'Search for products...' }}" 
            class="search-inline-input"
            value="{{ search.terms | escape }}"
          >
          <button type="submit" class="search-inline-submit">
            <svg viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
              <path d="M12.4625 11.6016L8.40469 7.54375C9.03438 6.72969 9.375 5.73438 9.375 4.6875C9.375 3.43438 8.88594 2.25937 8.00156 1.37344C7.11719 0.4875 5.93906 0 4.6875 0C3.43594 0 2.25781 0.489062 1.37344 1.37344C0.4875 2.25781 0 3.43438 0 4.6875C0 5.93906 0.489062 7.11719 1.37344 8.00156C2.25781 8.8875 3.43438 9.375 4.6875 9.375C5.73438 9.375 6.72813 9.03438 7.54219 8.40625L11.6 12.4625C11.6119 12.4744 11.626 12.4838 11.6416 12.4903C11.6571 12.4967 11.6738 12.5001 11.6906 12.5001C11.7075 12.5001 11.7241 12.4967 11.7397 12.4903C11.7552 12.4838 11.7694 12.4744 11.7812 12.4625L12.4625 11.7828C12.4744 11.7709 12.4838 11.7568 12.4903 11.7412C12.4967 11.7257 12.5001 11.709 12.5001 11.6922C12.5001 11.6754 12.4967 11.6587 12.4903 11.6431C12.4838 11.6276 12.4744 11.6135 12.4625 11.6016ZM7.1625 7.1625C6.5 7.82344 5.62187 8.1875 4.6875 8.1875C3.75313 8.1875 2.875 7.82344 2.2125 7.1625C1.55156 6.5 1.1875 5.62187 1.1875 4.6875C1.1875 3.75313 1.55156 2.87344 2.2125 2.2125C2.875 1.55156 3.75313 1.1875 4.6875 1.1875C5.62187 1.1875 6.50156 1.55 7.1625 2.2125C7.82344 2.875 8.1875 3.75313 8.1875 4.6875C8.1875 5.62187 7.82344 6.50156 7.1625 7.1625Z" fill="currentColor"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
{%- endif -%}

{% style %}
  .search-bar-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .search-form-inline {
    background: #fff;
    border: 1px solid #e5e5e5;
    padding: 2px;
  }

  .search-input-group {
    display: flex;
    align-items: center;
    height: 50px;
  }

  .search-inline-input {
    flex: 1;
    border: none;
    padding: 0 20px;
    font-size: 14px;
    outline: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: transparent;
  }

  .search-inline-submit {
    background: none;
    border: none;
    padding: 0 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .search-inline-submit:hover {
    opacity: 0.6;
  }

  .section-v-padding {
    padding-top: 20px;
    padding-bottom: 20px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Search Bar Inline",
  "settings": [
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder Text",
      "default": "SEARCH FOR PRODUCTS..."
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 800
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Search Bar Inline"
    }
  ]
}
{% endschema %}

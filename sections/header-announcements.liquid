{%- liquid
  assign autoplay_enabled = section.settings.autoplay
  assign speed = section.settings.speed | default: 5
-%}

{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

{% style %}
  .announcement-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#000000' }};
    color: {{ section.settings.text_color | default: '#ffffff' }};
    border-bottom: {{ section.settings.divider_width | default: 0 }}px solid rgba(0,0,0,0.1);
    {% render 'spacing-padding', settings: section.settings %}
  }

  .announcement-bar-{{ section.id }} .announcement-bar__slider {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 40px;
  }

  .announcement-bar-{{ section.id }} .announcement-bar__slides {
    position: relative;
    height: 1.5em; /* Define a height for the vertical slide */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .announcement-bar-{{ section.id }} .announcement-bar__slide {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.6s ease;
    transform: translateY(100%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    width: 100%;
  }

  /* Active state */
  .announcement-bar-{{ section.id }} .announcement-bar__slide[aria-hidden="false"] {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* Exit state (moving up) */
  .announcement-bar-{{ section.id }} .announcement-bar__slide[aria-hidden="true"] {
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
  }

  /* Override text block styles to inherit colors */
  .announcement-bar-{{ section.id }} .announcement-bar__text {
    color: inherit !important;
    margin: 0;
  }

  .announcement-bar-{{ section.id }} .slideshow-control {
    color: {{ section.settings.text_color | default: '#ffffff' }};
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
{% endstyle %}

<aside class="announcement-bar-{{ section.id }}">
  <announcement-bar-component
    class="announcement-bar__slider"
    {% if autoplay_enabled and section.blocks.size > 1 %}
      autoplay="{{ speed }}" aria-live="polite"
    {% endif %}
  >
    {% if section.blocks.size > 1 %}
      <button class="slideshow-control slideshow-control--previous" on-click="/previous" aria-label="Previous">
        {% render 'icon', icon: 'chevron-left' %}
      </button>
    {% endif %}

    <div class="announcement-bar__slides">
      {% content_for 'blocks' %}
    </div>

    {% if section.blocks.size > 1 %}
      <button class="slideshow-control slideshow-control--next" on-click="/next" aria-label="Next">
        {% render 'icon', icon: 'chevron-right' %}
      </button>
    {% endif %}
  </announcement-bar-component>
</aside>

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay enabled",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar"
    }
  ]
}
{% endschema %}

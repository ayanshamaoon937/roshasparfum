

{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
  "
>
  {% style %}
    .custom-trending-header {
      margin-bottom: 50px;
    }

    .header--centered {
      text-align: center;
    }

    .trending-subtitle {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .header--centered .trending-subtitle {
      justify-content: center;
      gap: 15px;
    }

    .trending-subtitle .line {
      height: 1px;
      width: 30px;
      background-color: #e0e0e0;
    }

    .header--centered .trending-subtitle .line {
      width: 40px;
    }

    .trending-subtitle .subtitle-text {
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 0.25em;
      color: #808080;
      text-transform: uppercase;
      font-weight: 500;
    }

    .trending-title-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 20px;
      width: 100%;
    }

    .header--centered .trending-title-row {
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .trending-title {
      font-family: var(--font-display) !important;
      font-size: clamp(32px, 5vw, 48px) !important;
      font-weight: 500 !important;
      color: #1a1a1a !important;
      margin: 0 !important;
      line-height: 1.1;
      letter-spacing: -0.01em;
      text-align: left;
    }

    .header--centered .trending-title {
      text-align: center;
    }

    .trending-description {
      max-width: 650px;
      margin-top: 15px;
      font-family: var(--font-body);
      font-style: italic;
      font-size: 15px;
      line-height: 1.7;
      color: #757575;
      font-weight: 400;
      text-align: left;
    }

    .header--centered .trending-description {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .trending-description p {
      margin: 0;
    }

    /* Style for Section Nav Arrows */
    .trending-nav-wrap {
      display: flex;
      align-items: center;
    }

    .trending-nav-wrap slideshow-arrows {
      display: flex !important;
      gap: 10px !important;
      position: static !important;
    }

    .trending-nav-wrap .slideshow-control {
      width: 42px !important;
      height: 42px !important;
      background: #ffffff !important;
      border: 1px solid #e0e0e0 !important;
      color: #1a1a1a !important;
      border-radius: 0 !important; /* Square */
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      opacity: 1 !important;
      visibility: visible !important;
      transition: all 0.3s ease !important;
      padding: 0 !important;
    }

    .trending-nav-wrap .slideshow-control:hover {
      background: #1a1a1a !important;
      color: #ffffff !important;
      border-color: #1a1a1a !important;
    }

    .trending-nav-wrap .slideshow-control svg {
      width: 14px !important;
      height: 14px !important;
      transition: none !important;
    }

    .section-resource-list__footer {
      text-align: center;
      margin-top: 50px;
    }

    .trending-view-all {
      display: inline-block;
      padding: 16px 45px;
      border: 1px solid #1a1a1a;
      text-decoration: none !important;
      color: #ffffff !important;
      font-family: var(--font-body);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-weight: 500;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      background: #1a1a1a;
    }

    .trending-view-all:hover {
      background-color: transparent;
      color: #1a1a1a !important;
      border-color: #1a1a1a;
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .section-resource-list {
      padding-top: {{ section.settings.padding-block-start }}px !important;
      padding-bottom: {{ section.settings.padding-block-end }}px !important;
      background-color: #ffffff !important;
    }

    .section-background {
      display: none !important;
    }
    slideshow-slides[gutters*='start'] {
      padding-inline-start: 0 !important;
    }
  {% endstyle %}
  {% liquid
    assign is_carousel = false
    if section.settings.layout_type == 'carousel'
      assign is_carousel = true
    endif
  %}

  {% capture header_content %}
    <div class="section-resource-list__header custom-trending-header {% if section.settings.layout_type == 'grid' %}header--centered{% endif %}">
      <div class="trending-header__text">
        {% if section.settings.subtitle != blank %}
          <div class="trending-subtitle">
            <span class="line"></span>
            <span class="subtitle-text">{{ section.settings.subtitle }}</span>
            {% if section.settings.layout_type == 'grid' %}
              <span class="line"></span>
            {% endif %}
          </div>
        {% endif %}

        <div class="trending-title-row">
          {% if section.settings.title != blank %}
            <h2 class="trending-title">{{ section.settings.title }}</h2>
          {% endif %}

          {% if is_carousel %}
            <div class="trending-nav-wrap">
              {% render 'slideshow-arrows', icon_style: section.settings.icons_style, icon_shape: section.settings.icons_shape %}
            </div>
          {% endif %}
        </div>

        {% if section.settings.description != blank %}
          <div class="trending-description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    </div>
  {% endcapture %}

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
          <div class="resource-list__item">
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>
          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div class="resource-list__item">
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>
        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
    if section.settings.section_width == 'page-width'
      assign slideshow_gutters = 'start end'
    endif
  %}

  {% if is_carousel %}
    <slideshow-component
      initial-slide="0"
      infinite
      style="--slideshow-timeline: {% render 'timeline-scope', count: list_items_array.size, prefix: 'slide' %};"
    >
      {{ header_content }}
      
      <div class="resource-list resource-list__carousel force-full-width" 
        style="
          --resource-list-column-gap-desktop: {{ section.settings.columns_gap | default: 16 }}px;
          --column-count: {{ section.settings.columns | default: 4 }};
          --column-count-mobile: 1;
          --mobile-card-size: 60cqw;
          --gutter-slide-width: var(--util-page-margin-offset);
        ">
        <slideshow-container ref="slideshowContainer">
          <slideshow-slides
            tabindex="-1"
            ref="scroller"
            {% if slideshow_gutters %}gutters="{{ slideshow_gutters }}"{% endif %}
          >
            {% for item in list_items_array %}
              {% render 'slideshow-slide',
                index: forloop.index,
                children: item,
                class: 'resource-list__slide'
              %}
            {% endfor %}
          </slideshow-slides>
        </slideshow-container>
      </div>
    </slideshow-component>
  {% else %}
    {{ header_content }}
    {% render 'resource-list',
      list_items: list_items,
      list_items_array: list_items_array,
      settings: section.settings,
      slide_count: max_items,
      content_type: 'products',
      test_id: 'resource-list-grid'
    %}
  {% endif %}

  {% if section.settings.show_view_all %}
    <div class="section-resource-list__footer">
      <a href="{{ section.settings.collection.url }}" class="trending-view-all">
        {{ section.settings.view_all_text | default: 'Explore Global Trending' }}
      </a>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:names.product_list",
  "class": "ui-test-product-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MOST WANTED"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trending Now"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover the scents that are defining the modern era. Curated selections from the world's most prestigious ateliers.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Button Text",
      "default": "Explore Global Trending"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type != 'editorial' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.one_number"
        },
        {
          "value": "2",
          "label": "t:options.two_number"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "60cqw",
          "label": "t:options.one_number"
        },
        {
          "value": "44cqw",
          "label": "t:options.two_number"
        }
      ],
      "default": "60cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "chevron",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "square",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 80
    }
  ],



{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section-resource-list
    product-list-{{ section.id }}
    color-{{ section.settings.color_scheme }}
  "
>
  {% style %}

    


    .product-list-{{ section.id }} .custom-trending-header {
      margin-bottom: 50px;
    }

    .product-list-{{ section.id }} .header--centered {
      text-align: center;
    }

    .product-list-{{ section.id }} .trending-subtitle {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: {{ section.settings.subtitle_margin_bottom }}px;
    }

    .product-list-{{ section.id }} .header--centered .trending-subtitle {
      justify-content: center;
      gap: 15px;
    }

    .product-list-{{ section.id }} .trending-subtitle .line {
      height: 1px;
      width: 30px;
      background-color: {{ section.settings.text_color }};
    }

    .product-list-{{ section.id }} .header--centered .trending-subtitle .line {
      width: 40px;
    }

    .product-list-{{ section.id }} .trending-subtitle .subtitle-text {
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 0.25em;
      color: {{ section.settings.text_color }};
      text-transform: uppercase;
      font-weight: 500;
    }

    .product-list-{{ section.id }} .trending-title-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      width: 100%;
      margin-top: {{ section.settings.row_margin_top }}px;
    }

    .product-list-{{ section.id }} .header--centered .trending-title-row {
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .product-list-{{ section.id }} .trending-title {
      font-family: var(--font-display) !important;
      font-size: {{ section.settings.title_font_size_mobile }}px !important;
      font-weight: 500 !important;
      color: {{ section.settings.text_color }} !important;
      margin-bottom: {{ section.settings.title_margin_bottom }}px !important;
      line-height: 1.1;
      letter-spacing: -0.01em;
      text-align: left;
    }

    .product-list-{{ section.id }} .header--centered .trending-title {
      text-align: center;
    }

    .product-list-{{ section.id }} .trending-description {
      max-width: 650px;
      margin-top: {{ section.settings.description_margin_top }}px;
      font-family: var(--font-body);
      font-style: italic;
      font-size: 15px;
      line-height: 1.7;
      color: {{ section.settings.text_color }};
      opacity: 0.8;
      font-weight: 400;
      text-align: left;
    }

    .product-list-{{ section.id }} .header--centered .trending-description {
      margin-left: auto;
      margin-right: auto;
      text-align: center;
    }

    .product-list-{{ section.id }} .trending-description p {
      margin: 0;
    }

    /* Style for Section Nav Arrows */
    .trending-nav-wrap {
      display: flex;
      align-items: center;
    }

    .trending-nav-wrap slideshow-arrows {
      display: flex !important;
      gap: 10px !important;
      position: static !important;
    }

    .trending-nav-wrap .slideshow-control {
      width: 42px !important;
      height: 42px !important;
      background: #ffffff !important;
      border: 1px solid #e0e0e0 !important;
      color: #1a1a1a !important;
      border-radius: 0 !important; /* Square */
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      opacity: 1 !important;
      visibility: visible !important;
      transition: all 0.3s ease !important;
      padding: 0 !important;
    }

    .trending-nav-wrap .slideshow-control:hover {
      background: #1a1a1a !important;
      color: #ffffff !important;
      border-color: #1a1a1a !important;
    }

    .trending-nav-wrap .slideshow-control svg {
      width: 14px !important;
      height: 14px !important;
      transition: none !important;
    }

    .product-list-{{ section.id }} .section-resource-list__footer {
      text-align: center;
      margin-top: {% if section.settings.layout_type == 'carousel' %}20px{% else %}50px{% endif %};
    }

    .trending-view-all {
      display: inline-block;
      padding: 16px 45px;
      border: 1px solid var(--color-primary-button-border);
      text-decoration: none !important;
      color: var(--color-primary-button-text) !important;
      font-family: var(--font-body);
      font-size: 12px;
      text-transform: capitalize;
      letter-spacing: 0.2em;
      font-weight: 500;
      transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      background: var(--color-primary-button-background);
    }

    @media (max-width: 768px) {
      .trending-view-all {
        padding: 12px 30px;
      }
      .pl-btn-{{ section.id }} {
        width: 30px !important;
        height: 30px !important;
      }
      .pl-btn-{{ section.id }} svg {
        width: 16px !important;
        height: 16px !important;
      }
    }

    .trending-view-all:hover {
      background-color: transparent;
      color: #1a1a1a !important;
      border-color: #1a1a1a;
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .product-list-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: 40 }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: 40 }}px !important;
      color: {{ section.settings.text_color }} !important;
      background-color: {{ section.settings.background_color | default: 'transparent' }} !important;
    }

    @media (min-width: 769px) {
      .product-list-{{ section.id }} .trending-title {
        font-size: {{ section.settings.title_font_size_desktop }}px !important;
      }
    }

    @media (min-width: 769px) {
      .product-list-{{ section.id }} {
        padding-top: {{ section.settings.padding_top_tablet | default: 60 }}px !important;
        padding-bottom: {{ section.settings.padding_bottom_tablet | default: 60 }}px !important;
      }
    }

    @media (min-width: 1025px) {
      .product-list-{{ section.id }} {
        padding-top: {{ section.settings.padding-block-start | default: 80 }}px !important;
        padding-bottom: {{ section.settings.padding-block-end | default: 80 }}px !important;
      }
    }
    .product-list-{{ section.id }} .product-list-container {
      max-width: var(--page-width);
      margin: 0 auto;
      padding: 0 var(--page-margin);
    }

    .section-background {
      display: none !important;
    }
    @media (max-width: 768px) {
      .product-list-{{ section.id }} .product-list-container {
        padding: 0 16px;
      }
    }
    .product-list-{{ section.id }} .resource-list__slide {
      flex-shrink: 0;
    }
    /* Custom Slick-like Slider */
    .pl-custom-slider-{{ section.id }} {
      overflow: hidden;
      position: relative;
    }
    .pl-custom-track-{{ section.id }} {
      display: flex;
      /* Make all slides equal height (match tallest card) */
      align-items: stretch;
      gap: {{ section.settings.columns_gap | default: 16 }}px;
      transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      will-change: transform;
    }
    .pl-custom-slide-{{ section.id }} {
      flex-shrink: 0;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      height: auto;
    }

    /* Ensure the card stretches to slide height and width */
    .product-list-{{ section.id }} .pl-custom-slide-{{ section.id }} .resource-list__item {
      display: flex;
      flex-direction: column;
      height: 100%;
      width: 100%;
    }

    .product-list-{{ section.id }} .pl-custom-slide-{{ section.id }} .product-card {
      display: flex;
      flex-direction: column;
      height: 100%;
      width: 100%;
    }

    .product-list-{{ section.id }} .pl-custom-slide-{{ section.id }} .product-card__content,
    .product-list-{{ section.id }} .pl-custom-slide-{{ section.id }} .product-card__meta {
      flex: 1 1 auto;
      display: flex !important;
      flex-direction: column !important;
      gap: 0px !important;
    }
    .pl-custom-nav-{{ section.id }} {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .pl-btn-{{ section.id }} {
      width: 42px;
      height: 42px;
      background: #ffffff;
      border: 1px solid #e0e0e0;
      color: #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      flex-shrink: 0;
    }
    .pl-btn-{{ section.id }}:hover {
      background: #1a1a1a;
      color: #ffffff;
      border-color: #1a1a1a;
    }
    .pl-btn-{{ section.id }} svg {
      width: 18px;
      height: 18px;
      pointer-events: none;
    }
    
  {% endstyle %}
  {% liquid
    assign is_carousel = false
    if section.settings.layout_type == 'carousel'
      assign is_carousel = true
    endif
  %}

  {% capture header_content %}
    <div class="section-resource-list__header custom-trending-header {% if section.settings.layout_type == 'grid' %}header--centered{% endif %}">
      <div class="trending-header__text">
        {% if section.settings.subtitle != blank %}
          <div class="trending-subtitle">
            <span class="line"></span>
            <span class="subtitle-text">{{ section.settings.subtitle }}</span>
            {% if section.settings.layout_type == 'grid' %}
              <span class="line"></span>
            {% endif %}
          </div>
        {% endif %}

        <div class="trending-title-row">
          {% if section.settings.title != blank %}
            <h2 class="trending-title">{{ section.settings.title }}</h2>
          {% endif %}

          {% if is_carousel %}
            <div class="pl-custom-nav-{{ section.id }}">
              <button class="pl-btn-{{ section.id }} pl-prev-{{ section.id }}" aria-label="Previous">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
              <button class="pl-btn-{{ section.id }} pl-next-{{ section.id }}" aria-label="Next">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            </div>
          {% endif %}
        </div>

        {% if section.settings.description != blank %}
          <div class="trending-description">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    </div>
  {% endcapture %}

  {% capture list_items %}
    {% if section.settings.collection != blank and shop.products_count != 0 %}
      {% paginate section.settings.collection.products by max_items %}
        {% for product in section.settings.collection.products limit: max_items %}
          <div class="resource-list__item">
            {% # theme-check-disable UniqueStaticBlockId %}
              {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
            {% # theme-check-enable UniqueStaticBlockId %}
          </div>
          {% unless forloop.last %}
            <!--@list/split-->
          {% endunless %}
        {% endfor %}
      {% endpaginate %}
    {% else %}
      {% for i in (1..max_items) %}
        <div class="resource-list__item">
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>
        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endif %}
  {% endcapture %}

  {% liquid
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
    if section.settings.section_width == 'page-width'
      assign slideshow_gutters = 'start end'
    endif
  %}

  <div class="product-list-container">
    {% if is_carousel %}
      {{ header_content }}
      <div class="pl-custom-slider-{{ section.id }}" id="pl-slider-{{ section.id }}">
        <div class="pl-custom-track-{{ section.id }}" id="pl-track-{{ section.id }}">
          {%- for item in list_items_array -%}
            <div class="pl-custom-slide-{{ section.id }}">
              {{ item }}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {% else %}
      {{ header_content }}
      {% render 'resource-list',
        list_items: list_items,
        list_items_array: list_items_array,
        settings: section.settings,
        slide_count: max_items,
        content_type: 'products',
        test_id: 'resource-list-grid'
      %}
    {% endif %}

    {% if section.settings.show_view_all %}
      <div class="section-resource-list__footer">
        <a href="{{ section.settings.collection.url }}" class="trending-view-all">
          {{ section.settings.view_all_text | default: 'Explore Global Trending' }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% if section.settings.layout_type == 'carousel' %}
<script>
(function() {
  function initPlSlider_{{ section.id | replace: '-', '_' }}() {
    var sliderId = 'pl-slider-{{ section.id }}';
    var trackId  = 'pl-track-{{ section.id }}';
    var sectionEl = document.querySelector('.product-list-{{ section.id }}');
    if (!sectionEl) return;
    var slider = sectionEl.querySelector('#' + sliderId);
    var track  = sectionEl.querySelector('#' + trackId);
    if (!slider || !track) return;

    var spvDefault   = parseInt('{{ section.settings.columns | default: 4 }}');
    var spvTablet    = parseInt('{{ section.settings.columns_tablet | default: 2 }}');
    var spvMobile    = parseInt('{{ section.settings.columns_mobile | default: 1 }}');
    var gapPx          = parseInt('{{ section.settings.columns_gap | default: 16 }}');
    var totalSlides    = {{ list_items_array.size }};
    var currentIndex   = 0;
    var isTransitioning = false;

    function getSpv() {
      if (window.innerWidth <= 768) return spvMobile;
      if (window.innerWidth <= 1024) return spvTablet;
      return spvDefault;
    }


    function setSlideWidths() {
      var slidesPerView = getSpv();
      var containerW = slider.offsetWidth;
      var slideW = (containerW - gapPx * (slidesPerView - 1)) / slidesPerView;
      var slides = track.querySelectorAll('.pl-custom-slide-{{ section.id }}');
      slides.forEach(function(s) {
        s.style.width = slideW + 'px';
      });
      goTo(currentIndex, false);
    }

    function goTo(index, animate) {
      if (animate === undefined) animate = true;
      var slidesPerView = getSpv();
      var containerW = slider.offsetWidth;
      var slideW = (containerW - gapPx * (slidesPerView - 1)) / slidesPerView;
      var offset = index * (slideW + gapPx);
      track.style.transition = animate ? 'transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94)' : 'none';
      track.style.transform = 'translateX(-' + offset + 'px)';
      currentIndex = index;
    }

    function next() {
      if (isTransitioning) return;
      var slidesPerView = getSpv();
      var lastPossible = totalSlides - slidesPerView;
      if (currentIndex >= lastPossible) {
        /* Loop back to start */
        isTransitioning = true;
        goTo(currentIndex + 1, true);
        setTimeout(function() {
          goTo(0, false);
          isTransitioning = false;
        }, 460);
      } else {
        goTo(currentIndex + 1);
      }
    }

    function prev() {
      if (isTransitioning) return;
      var slidesPerView = getSpv();
      if (currentIndex <= 0) {
        /* Loop to end */
        isTransitioning = true;
        goTo(-1, true);
        setTimeout(function() {
          goTo(totalSlides - slidesPerView, false);
          isTransitioning = false;
        }, 460);
      } else {
        goTo(currentIndex - 1);
      }
    }

    var prevBtn = sectionEl.querySelector('.pl-prev-{{ section.id }}');
    var nextBtn = sectionEl.querySelector('.pl-next-{{ section.id }}');
    if (prevBtn) prevBtn.addEventListener('click', prev);
    if (nextBtn) nextBtn.addEventListener('click', next);

    setSlideWidths();
    window.addEventListener('resize', setSlideWidths);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlSlider_{{ section.id | replace: '-', '_' }});
  } else {
    initPlSlider_{{ section.id | replace: '-', '_' }}();
  }
})();
</script>
{% endif %}

{% schema %}
{
  "name": "t:names.product_list",
  "class": "ui-test-product-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MOST WANTED"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Trending Now"
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size (Mobile)",
      "default": 22
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover the scents that are defining the modern era. Curated selections from the world's most prestigious ateliers.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Button Text",
      "default": "Explore Global Trending"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type != 'editorial' }}"
    },
    {
       "type": "range",
       "id": "columns_tablet",
       "min": 1,
       "max": 4,
       "step": 1,
       "label": "Slides to show on Tablet",
       "default": 2
    },
    {
       "type": "range",
       "id": "columns_mobile",
       "min": 1,
       "max": 3,
       "step": 1,
       "label": "Slides to show on Mobile",
       "default": 1
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "range",
      "id": "description_margin_top",
      "label": "Description Top Margin",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "subtitle_margin_bottom",
      "label": "Subtitle Bottom Margin",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    },

    {
      "type": "range",
      "id": "row_margin_top",
      "label": "Title Row Top Margin",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "label": "Title Bottom Margin",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "chevron",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "square",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",

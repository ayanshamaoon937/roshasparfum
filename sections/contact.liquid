{%- style -%}
  .contact-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .contact-container-{{ section.id }} {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .contact-header {
    text-align: center;
    margin: 0 auto 50px auto;
    max-width: 800px;
  }

  .contact-header .title {
    font-family: var(--font-heading--family), serif;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_font_size_mobile }}px;
    font-weight: {{ section.settings.title_font_weight }};
    margin: 0 0 {{ section.settings.title_margin_bottom }}px 0;
    line-height: 1.2;
  }

  .contact-header .description {
    font-family: var(--font-body--family), sans-serif;
    color: {{ section.settings.desc_color }};
    font-size: {{ section.settings.desc_font_size }}px;
    font-weight: {{ section.settings.desc_font_weight }};
    margin: 0 0 {{ section.settings.desc_margin_bottom }}px 0;
    line-height: 1.6;
  }

  .contact-form-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  .contact-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .contact-field {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
  }

  .contact-field label {
    margin-bottom: 8px;
    font-size: 14px;
    font-weight: {{ section.settings.label_font_weight }};
    color: {{ section.settings.label_color }};
    font-family: var(--font-body--family), sans-serif;
  }

  .contact-field label span {
    color: {{ section.settings.required_color }};
  }

  .contact-field input, 
  .contact-field textarea {
    padding: 15px;
    border: 1px solid #dfdfdf;
    border-radius: 0;
    font-size: 14px;
    font-family: var(--font-body--family), sans-serif;
    background: transparent;
  }
  .contact-field input::placeholder, 
  .contact-field textarea::placeholder {
    color: #888;
    opacity: 1; /* Firefox fix */
  }

  .contact-field input:focus, 
  .contact-field textarea:focus, 
  .contact-field input:focus-visible, 
  .contact-field textarea:focus-visible {
    outline: none;
    border-color: #000000;
    box-shadow: none;
  }
  .contact-field textarea {
    min-height: 180px;
    resize: vertical;
  }

  .contact-form-full {
    grid-column: span 2;
  }

  .contact-submit-wrap {
    text-align: center;
    margin-top: 30px;
  }

  .contact-submit-btn {
    display: inline-block;
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
    border: 1px solid {{ section.settings.btn_border_color }};
    padding: 15px 50px;
    font-size: {{ section.settings.btn_font_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 250px;
    font-family: var(--font-body--family), sans-serif;
    border-radius: 0;
  }

  .contact-submit-btn:hover {
    background-color: {{ section.settings.btn_hover_bg_color }};
    color: {{ section.settings.btn_hover_text_color }};
    border-color: {{ section.settings.btn_hover_border_color }};
  }

  @media screen and (min-width: 750px) {
    .contact-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
    .contact-header .title {
      font-size: {{ section.settings.title_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .contact-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .contact-header .title {
      font-size: {{ section.settings.title_font_size_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .contact-form-grid {
      grid-template-columns: 1fr;
    }
    .contact-form-full {
      grid-column: span 1;
    }
    .contact-container-{{ section.id }} {
      padding: 0 20px;
    }
    .contact-submit-btn {
      width: 100%;
    }
  }
{%- endstyle -%}

<section class="contact-section-{{ section.id }}">
  <div class="contact-container-{{ section.id }}">
    
    <div class="contact-header">
      <h2 class="title">{{ section.settings.title }}</h2>
      <div class="description">{{ section.settings.description }}</div>
    </div>

    <div class="contact-form-wrapper">
      {%- form 'contact' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success" style="text-align: center; color: green; margin-bottom: 20px;">
            {{ 'contact.form.post_success' | t }}
          </p>
        {%- elsif form.errors -%}
          <div class="form-errors" style="color: red; margin-bottom: 20px;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="contact-form-grid">
          <div class="contact-field">
            <label for="ContactFormName">Name <span>*</span></label>
            <input type="text"
              id="ContactFormName"
              name="contact[name]"
              placeholder="Your Name"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              required>
          </div>

          <div class="contact-field">
            <label for="ContactFormEmail">Email <span>*</span></label>
            <input type="email"
              id="ContactFormEmail"
              name="contact[email]"
              placeholder="Your Email"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              spellcheck="false"
              autocomplete="off"
              autocapitalize="off"
              required>
          </div>

          <div class="contact-field contact-form-full">
            <label for="ContactFormPhone">Phone <span>*</span></label>
            <input type="tel"
              id="ContactFormPhone"
              name="contact[phone]"
              placeholder="Your Phone Number"
              value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
          </div>

          <div class="contact-field contact-form-full">
            <label for="ContactFormMessage">Message <span>*</span></label>
            <textarea rows="10"
              id="ContactFormMessage"
              name="contact[note]"
              placeholder="Your Message"
              required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>
        </div>

        <div class="contact-submit-wrap">
          <button type="submit" class="contact-submit-btn">
            {% if section.settings.button_text != blank %}
              {{ section.settings.button_text }}
            {% else %}
              SUBMIT
            {% endif %}
          </button>
        </div>
      {%- endform -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Custom Contact Form",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",

{%- style -%}
  .new-hero-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - var(--header-total-height, 120px));
    display: flex;
    align-items: center;
    background-color: transparent;
  }

  @media screen and (min-width: 750px) {
    .new-hero-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      min-height: calc(100vh - var(--header-total-height, 120px));
    }
  }

  .new-hero-bg-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .new-hero-slide-item {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.8s ease-in-out, visibility 0.8s ease-in-out;
    z-index: 1;
  }

  .new-hero-slide-item.active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  .new-hero-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .new-hero-slide-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
  }

  .new-hero-slide-overlay.active {
    opacity: 1;
  }

  .new-hero-content-slider {
    position: relative;
    z-index: 4;
    width: 100%;
    max-width: 700px;
    padding: 0 20px;
    margin-left: 5%;
  }

  .new-hero-slide-content {
    display: none;
    animation: fadeInContent 0.8s ease-in-out;
  }

  .new-hero-slide-content.active {
    display: block;
  }

  @keyframes fadeInContent {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .new-hero-subtitle {
     font-family: var(--font-body--family), sans-serif;
     font-size: 14px;
     letter-spacing: 3px;
     text-transform: uppercase;
     color: #fff;
     margin-bottom: 20px;
     display: block;
     position: relative;
  }

  .new-hero-subtitle::before {
    content: '';
    display: block;
    width: 30px;
    height: 1px;
    background: #fff;
    margin-bottom: 10px;
  }

  .new-hero-heading {
    font-family: var(--font-heading--family), serif;
    line-height: var(--line-height--heading-tight);
    margin-bottom: 30px;
    color: #fff;
    font-size: {{ section.settings.heading_font_size_mobile }}px;
  }

  .new-hero-description {
    font-family: var(--font-body--family), sans-serif;
    line-height: var(--line-height--body-loose);
    margin-bottom: 40px;
    max-width: 450px;
    color: #fff;
    font-size: {{ section.settings.description_font_size_mobile }}px;
  }

  .new-hero-button {
    font-family: var(--font-body--family), sans-serif;
    display: inline-block;
    padding: 16px 45px;
    background: #fff;
    color: #000;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.2em;
    font-weight: 500;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid #fff;
  }

  .new-hero-button:hover {
    background: transparent;
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  @media screen and (min-width: 750px) {
    .new-hero-content-slider {
      margin-left: 8%;
    }
    .new-hero-heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
    .new-hero-description {
      font-size: {{ section.settings.description_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .new-hero-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
    .new-hero-description {
      font-size: {{ section.settings.description_font_size_desktop }}px;
    }
  }

  .new-hero-slider-thumbs {
    position: absolute;
    bottom: 40px;
    right: 40px;
    display: flex;
    gap: 15px;
    z-index: 10;
  }

  .new-hero-thumb {
    width: 80px;
    height: 120px;
    border: 1px solid rgba(255,255,255,0.3);
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .new-hero-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }

  .new-hero-thumb:hover img, .new-hero-thumb.active img {
    opacity: 1;
  }

  .new-hero-thumb.active {
    border: 2px solid #fff;
  }

  .new-hero-thumb-number {
    position: absolute;
    bottom: 5px;
    right: 5px;
    font-size: 10px;
    color: #fff;
    font-weight: bold;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
  }

  @media screen and (max-width: 749px) {
    .new-hero-{{ section.id }} {
      min-height: calc(100vh - var(--header-total-height, 120px));
      align-items: flex-start;
      padding-top: 50px;
    }
    .new-hero-slider-thumbs {
      right: 20px;
      bottom: 20px;
    }
    .new-hero-thumb {
      width: 60px;
      height: 90px;
    }
  }
{%- endstyle -%}

<section class="new-hero-{{ section.id }}" id="NewHero-{{ section.id }}">
  <div class="new-hero-bg-container" id="BgContainer-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- liquid
         assign slide_index = forloop.index0
         assign is_active = false
         if forloop.first
           assign is_active = true
         endif
      -%}
      
      <div class="new-hero-slide-item {% if is_active %}active{% endif %}" data-index="{{ slide_index }}">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image 
             | image_url: width: 3840 
             | image_tag: 
               loading: 'eager', 
               class: 'new-hero-bg-image',
               data-index: slide_index
          }}
        {%- else -%}
          <div class="new-hero-bg-image">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}

        {%- assign opacity = block.settings.overlay_opacity | divided_by: 100.0 -%}
        <div 
          class="new-hero-slide-overlay {% if is_active %}active{% endif %}" 
          style="background-color: {{ block.settings.overlay_color | default: '#000000' }}; opacity: {{ opacity }};"
          data-index="{{ slide_index }}"
        ></div>
      </div>
    {%- endfor -%}
  </div>

  <div class="new-hero-content-slider">
    {%- for block in section.blocks -%}
      <div 
        class="new-hero-slide-content {% if forloop.first %}active{% endif %}" 
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.subtitle != blank -%}
          <span class="new-hero-subtitle">{{ block.settings.subtitle }}</span>
        {%- endif -%}
        
        {%- if block.settings.heading != blank -%}
          <h2 class="new-hero-heading">{{ block.settings.heading }}</h2>
        {%- endif -%}

        {%- if block.settings.description != blank -%}
          <p class="new-hero-description">{{ block.settings.description }}</p>
        {%- endif -%}

        {%- if block.settings.button_label != blank -%}
          <a href="{{ block.settings.button_link }}" class="new-hero-button">
            {{ block.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="new-hero-slider-thumbs">
    {%- for block in section.blocks -%}
      <div 
        class="new-hero-thumb {% if forloop.first %}active{% endif %}" 
        data-index="{{ forloop.index0 }}"
      >
        {%- if block.settings.image != blank -%}
           <img src="{{ block.settings.image | image_url: width: 240 }}" alt="Slide Thumb">
        {%- else -%}
           {{ 'lifestyle-1' | placeholder_svg_tag: 'thumb-placeholder' }}
        {%- endif -%}
        <span class="new-hero-thumb-number">{{ forloop.index | prepend: '0' }}</span>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  function initNewHero() {
    const sections = document.querySelectorAll('[id^="NewHero-"]');
    
    sections.forEach(section => {
      // Avoid duplicated initialization
      if (section.dataset.initialized) return;
      section.dataset.initialized = "true";

      const thumbs = section.querySelectorAll('.new-hero-thumb');
      const bgImages = section.querySelectorAll('.new-hero-bg-image');
      const contents = section.querySelectorAll('.new-hero-slide-content');

      thumbs.forEach(thumb => {
        thumb.addEventListener('click', function(e) {
          e.preventDefault();
          const index = this.getAttribute('data-index');
          if (index === null) return;

          console.log('Slide switch to:', index);

          // Update thumbs
          thumbs.forEach(t => t.classList.remove('active'));
          this.classList.add('active');

          // Update bg items (images & slide overlays)
          const slideItems = section.querySelectorAll('.new-hero-slide-item');
          slideItems.forEach(item => item.classList.remove('active'));
          const targetItem = [...slideItems].find(item => item.getAttribute('data-index') === index);
          if (targetItem) targetItem.classList.add('active');

          // Update content
          contents.forEach(c => c.classList.remove('active'));
          const targetContent = [...contents].find(c => c.getAttribute('data-index') === index);
          if (targetContent) targetContent.classList.add('active');
        });
      });
    });
  }

  // Run on first load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNewHero);
  } else {
    initNewHero();
  }

  // Support Shopify Theme Editor re-loads
  document.addEventListener('shopify:section:load', initNewHero);
  document.addEventListener('shopify:section:reorder', initNewHero);
</script>


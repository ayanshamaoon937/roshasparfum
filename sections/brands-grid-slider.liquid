{%- liquid
  assign is_slider = false
  if section.settings.layout_type == 'slider'
    assign is_slider = true
  endif

  assign columns = section.settings.columns_desktop | default: 4
  assign columns_mobile = section.settings.columns_mobile | default: '1' | plus: 0
-%}

{%- style -%}
  .brands-grid-slider-{{ section.id }} {
    padding: 80px 0;
    background: {{ section.settings.bg_color | default: '#ffffff' }};
  }

  .brands-container {
    max-width: {{ section.settings.container_width | default: 1400 }}px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* Header Styles */
  .brands-header {
    text-align: center;
    margin-bottom: 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .brands-subtitle {
    display: flex;
    align-items: center;
    gap: 15px;
    color: #b59b61;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 15px;
  }

  .brands-subtitle .line {
    width: 30px;
    height: 1px;
    background: #b59b61;
    opacity: 0.5;
  }

  .brands-title {
    font-family: 'Playfair Display', serif;
    font-size: 60px;
    color: #1a1a1a;
    margin: 0 0 20px 0;
    line-height: 1.1;
  }

  .brands-desc {
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    color: #666;
    max-width: 600px;
    line-height: 1.6;
    margin: 0;
  }

  /* Brand Cards Styles */
  .brands-layout-wrap {
    position: relative;
  }

  .brands-grid {
    display: grid;
    grid-template-columns: repeat({{ columns }}, 1fr);
    gap: {{ section.settings.gap_desktop | default: 24 }}px;
  }

  .brand-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    border: 1px solid {{ section.settings.border_color | default: '#f0f0f0' }};
    background: #fff;
    text-decoration: none !important;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    height: 100%;
    position: relative;
    text-align: center;
  }

  .brand-logo-wrap {
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 120px;
    width: 100%;
  }

  .brand-logo-wrap img {
    max-width: {{ section.settings.logo_max_width | default: 120 }}px;
    height: auto;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .brand-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }

  .brand-location {
    font-size: {{ section.settings.loc_size }}px;
    font-weight: {{ section.settings.loc_weight }};
    color: {{ section.settings.loc_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1;
    transition: color 0.4s ease;
  }

  .brand-name {
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.name_size }}px;
    font-weight: {{ section.settings.name_weight }};
    color: {{ section.settings.name_color }};
    margin: 0;
    line-height: 1.2;
    transition: color 0.4s ease;
  }

  .brand-description {
    font-size: {{ section.settings.desc_size }}px;
    font-weight: {{ section.settings.desc_weight }};
    color: {{ section.settings.desc_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.4;
    max-width: 180px;
    transition: color 0.4s ease;
  }

  /* Hover Effects */
  .brand-card:hover {
    border-color: {{ section.settings.hover_border_color | default: '#b59b61' }};
    box-shadow: 0 10px 40px rgba(0,0,0,0.03);
    z-index: 10;
  }

  .brand-card:hover .brand-logo-wrap img {
    transform: scale(1.05);
  }

  .brand-card:hover .brand-location { 
    color: {{ section.settings.hover_content_color | default: '#b59b61' }}; 
  }
  .brand-card:hover .brand-name { 
    color: {{ section.settings.hover_content_color | default: '#b59b61' }}; 
  }
  .brand-card:hover .brand-description { 
    color: {{ section.settings.hover_content_color | default: '#b59b61' }}; 
  }

  /* Slider specific styles */
  .brands-grid-slider-{{ section.id }}  .slideshow-control {
    width: 42px !important;
    height: 42px !important;
    background: #ffffff !important;
    border: 1px solid #e0e0e0 !important;
    color: #1a1a1a !important;
    border-radius: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: all 0.3s ease !important;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
  }
  .brands-grid-slider-{{ section.id }}  .slideshow-control[on-click="/previous"] { left: -21px; }
  .brands-grid-slider-{{ section.id }}  .slideshow-control[on-click="/next"] { right: -21px; }

  .brands-grid-slider-{{ section.id }} .slideshow-control:hover {
    background: #1a1a1a !important;
    color: #ffffff !important;
    border-color: #1a1a1a !important;
  }

  .brands-grid-slider-{{ section.id }} .slideshow-control svg {
    width: 14px !important;
    height: 14px !important;
  }

  .brands-grid-slider-{{ section.id }} .resource-list__slide {
    flex-shrink: 0;
    width: calc((100% - {{ section.settings.gap_desktop | default: 24 }}px * ({{ columns }} - 1)) / {{ columns }});
  }

  @media (max-width: 1024px) {
    .brands-grid { grid-template-columns: repeat(3, 1fr); }
    .brands-grid-slider-{{ section.id }} .resource-list__slide { width: calc(100% / 3 - 20px); }
    .brands-title { font-size: 48px; }
  }

  @media (max-width: 768px) {
    .brands-grid { grid-template-columns: repeat({{ columns_mobile }}, 1fr); }
    .brands-grid-slider-{{ section.id }} .resource-list__slide { width: 80vw; }
    .brands-container { padding: 0 20px; }
    .brands-title { font-size: 36px; }
    .brands-grid-slider-{{ section.id }}  .slideshow-control { display: none !important; }
  }
{%- endstyle -%}

<div class="brands-grid-slider-{{ section.id }}">
  <div class="brands-container">
    {%- if section.settings.title != blank or section.settings.subtitle != blank or section.settings.description != blank -%}
      <div class="brands-header">
        {%- if section.settings.subtitle != blank -%}
          <div class="brands-subtitle">
            <span class="line"></span>
            {{ section.settings.subtitle }}
            <span class="line"></span>
          </div>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="brands-title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="brands-desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="brands-layout-wrap">
      {%- if is_slider -%}
        <slideshow-component
          infinite="false"
          initial-slide="0"
          style="--slideshow-timeline: {% render 'timeline-scope', count: section.blocks.size, prefix: 'brand' %};"
        >
          <slideshow-container ref="slideshowContainer">
            <slideshow-slides
              tabindex="-1"
              ref="scroller"
              gutters="start end"
              style="display: flex; gap: {{ section.settings.gap_desktop | default: 24 }}px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none;"
            >
              {%- for block in section.blocks -%}
                <div class="resource-list__slide" style="scroll-snap-align: start;" {{ block.shopify_attributes }}>
                  {%- render 'brand-card-item', block: block, section: section -%}
                </div>
              {%- endfor -%}
            </slideshow-slides>
          </slideshow-container>
          {%- render 'slideshow-arrows', icon_style: 'chevron', icon_shape: 'square' -%}
        </slideshow-component>
      {%- else -%}
        <div class="brands-grid">
          {%- for block in section.blocks -%}
            <div {{ block.shopify_attributes }}>
              {%- render 'brand-card-item', block: block, section: section -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{%- comment -%} Internal Snippet Inline for Brand Card to keep it clean {%- endcomment -%}

{% schema %}
{
  "name": "Brands Grid & Slider",
  "settings": [
    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout Type",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider (Carousel)" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns Desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns Mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 24
    },
    {

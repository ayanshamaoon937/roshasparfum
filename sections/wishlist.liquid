{%- style -%}
  .wishlist-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url }}');
      background-size: cover;
      background-position: center;
    {% endif %}
  }

  .wishlist-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media screen and (max-width: 768px) {
    .wishlist-container {
      padding: 0 20px;
    }
  }

  /* Wishlist Table/List Layout */
  .wishlist-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #f0f0f0;
    
  }

  .wishlist-item {
    display: flex;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid #f0f0f0;
    transition: all 0.3s ease;
    background: #fff;
    position: relative;
  }

  .wishlist-item:hover {
    background-color: #fcfcfc;
  }

  .wishlist-item:last-child {
    border-bottom: none;
  }

  .wishlist-remove {
    background: none;
    border: none;
    color: #cccccc;
    cursor: pointer;
    font-size: 20px;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 0;
    transition: color 0.3s ease;
    flex-shrink: 0;
    font-weight: 300;
  }

  .wishlist-remove:hover {
    color: #000;
  }

  .wishlist-image {
    width: 130px;
    margin-right: 30px;
    flex-shrink: 0;
  }

  .wishlist-image img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    background: #f8f8f8;
  }

  .wishlist-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-right: 20px;
  }

  .wishlist-title {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    color: #1a1a1a;
    margin: 0;
    text-decoration: none;
    display: block;
    font-weight: 500;
    line-height: 1.3;
  }

  .wishlist-variant {
    font-size: 12px;
    color: #777;
    font-family: 'Jost', sans-serif;
    letter-spacing: 0.5px;
  }

  .wishlist-price {
    font-weight: 500;
    color: #1a1a1a;
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    margin-top: 4px;
  }

  .wishlist-actions-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 15px;
    min-width: 180px;
  }

  .wishlist-stock {
    font-size: 11px;
    color: #999;
    font-family: 'Jost', sans-serif;
    text-transform: capitalize;
  }

  .wishlist-atc-btn {
    background: #000;
    color: #fff;
    border: none;
    padding: 12px 30px;
    font-size: 11px;
    text-transform: capitalize;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 160px;
    font-family: 'Jost', sans-serif;
    font-weight: 500;
  }

  .wishlist-atc-btn:hover {
    background: #333;
    letter-spacing: 2px;
  }

  /* Empty State Styling */
  .wishlist-empty-container {
    padding: 120px 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px;
  }

  .wishlist-empty-text {
    font-family: var(--font-body--family), sans-serif;
    font-size: 15px;
    color: #666;
    margin: 0;
  }

  .wishlist-continue-btn {
    background: #000;
    color: #fff;
    border: none;
    padding: 15px 40px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: opacity 0.3s ease;
    display: inline-block;
  }

  .wishlist-loader {
    text-align: center;
    padding: 100px 0;
    font-family: var(--font-body--family);
    color: #999;
  }

  @media screen and (min-width: 750px) {
    .wishlist-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .wishlist-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  @media screen and (max-width: 989px) {
    .wishlist-item {
      padding: 20px;
      flex-wrap: wrap;
      align-items: flex-start;
    }
    .wishlist-remove {
      position: absolute;
      top: 15px;
      right: 15px;
      justify-content: flex-end;
      width: 30px;
      height: 30px;
    }
    .wishlist-image {
      width: 90px;
      margin-right: 20px;
    }
    .wishlist-info {
      padding-right: 35px; /* Space for remove button */
    }
    .wishlist-actions-wrap {
      width: 100%;
      margin-top: 20px;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding-top: 20px;
      border-top: 1px dotted #f0f0f0;
    }
    .wishlist-atc-btn {
      min-width: 140px;
      padding: 10px 20px;
    }
  }
{%- endstyle -%}

<section class="wishlist-section-{{ section.id }}">
  <div class="wishlist-container">
    <div id="wishlist-grid" class="wishlist-grid">
      <div class="wishlist-loader">Loading...</div>
    </div>
  </div>
</section>

<script>
  (function() {
    // Manual money formatter since Shopify.formatMoney is not always available
    function formatMoney(cents, format) {
      if (typeof cents === 'string') cents = cents.replace('.', '');
      let value = '';
      const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
      const formatString = format || "${{amount}}";

      function formatWithDelimiters(number, precision, thousands, decimal) {
        precision = precision || 2;
        thousands = thousands || ',';
        decimal = decimal || '.';
        if (isNaN(number) || number == null) return 0;
        number = (number / 100.0).toFixed(precision);
        let parts = number.split('.'),
            dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands),
            cents = parts[1] ? decimal + parts[1] : '';
        return dollars + cents;
      }

      switch (formatString.match(placeholderRegex)[1]) {
        case 'amount': value = formatWithDelimiters(cents, 2); break;
        case 'amount_no_decimals': value = formatWithDelimiters(cents, 0); break;
        case 'amount_with_comma_separator': value = formatWithDelimiters(cents, 2, '.', ','); break;
        case 'amount_no_decimals_with_comma_separator': value = formatWithDelimiters(cents, 0, '.', ','); break;
      }
      return formatString.replace(placeholderRegex, value);
    }

    async function loadWishlist() {
      const container = document.getElementById('wishlist-grid');
      if (!container) return;
      
      const items = window.wishlist ? window.wishlist.get() : [];
      
      const emptyHtml = `
        <div class="wishlist-empty-container">
          <p class="wishlist-empty-text">Your list is empty.</p>
          <a href="{{ section.settings.continue_shopping_link | default: routes.all_products_collection_url }}" class="wishlist-continue-btn">
            Continue Shopping
          </a>
        </div>
      `;

      if (items.length === 0) {
        container.style.border = 'none';
        container.innerHTML = emptyHtml;
        return;
      }
      
      container.style.border = '1px solid #f0f0f0';
      container.innerHTML = '<div class="wishlist-loader">Updating your list...</div>';
      
      let html = '';
      const moneyFormat = "{{ shop.money_format }}";
      
      for (const handle of items) {
        try {
          const response = await fetch(`${window.Shopify.routes.root}products/${handle}.js`);
          if (!response.ok) {
             console.warn(`Product ${handle} could not be loaded.`);
             continue;
          }
          const product = await response.json();
          
          const title = product.title;
          const image = product.featured_image;
          const price = formatMoney(product.price, moneyFormat);
          const url = product.url;
          const availableText = product.available ? 'In stock' : 'Out of stock';
          const variantId = product.variants[0].id;
          
          let details = '';
          if (product.options && product.options[0]) {
             details = `${product.options[0].name}: ${product.options[0].values[0]}`;
             if (product.options[1]) {
                details += ` / ${product.options[1].name}: ${product.options[1].values[0]}`;
             }
          }

          html += `
            <div class="wishlist-item" data-wishlist-item="${handle}">
              <button class="wishlist-remove" title="Remove Item" onclick="window.wishlist.remove('${handle}', true)">
                <span aria-hidden="true">&times;</span>
              </button>
              
              <div class="wishlist-image">
                <a href="${url}"><img src="${image}" alt="${title}"></a>
              </div>
              
              <div class="wishlist-info">
                <a href="${url}" class="wishlist-title">${title}</a>
                <div class="wishlist-variant">${details}</div>
                <div class="wishlist-price">${price}</div>
              </div>
              
              <div class="wishlist-actions-wrap">
                <div class="wishlist-stock ${product.available ? 'in-stock' : ''}">${availableText}</div>
                <div class="wishlist-add">
                  <form method="post" action="/cart/add">
                    <input type="hidden" name="id" value="${variantId}">
                    <button type="submit" class="wishlist-atc-btn">Add to cart</button>
                  </form>
                </div>
              </div>
            </div>
          `;
        } catch (error) {
          console.error(`Error loading wishlist product ${handle}:`, error);
        }
      }
      
      container.innerHTML = (html === '') ? emptyHtml : html;
      if (html === '') container.style.border = 'none';
    }

    // Re-check for wishlist initialization if it's not ready yet
    if (window.wishlist) {
      loadWishlist();
    } else {
      setTimeout(loadWishlist, 500);
    }
    
    document.addEventListener('wishlist:updated', (e) => {
      if (e.detail.action === 'add') {
         loadWishlist();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Wishlist Page",
  "settings": [
    {
      "type": "url",
      "id": "continue_shopping_link",
      "label": "Continue Shopping Link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fcfcfc"

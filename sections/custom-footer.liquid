{%- liquid
  assign logo_image = section.settings.logo_image
  assign logo_text = section.settings.logo_text | default: shop.name
-%}

{% style %}
  .custom-footer {
    background: #000000;
    color: #ffffff;
    padding: 80px 0 30px;
    font-family: 'Jost', sans-serif;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .footer-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
  }

  /* Left Column Branding */
  .footer-branding {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .footer-logo {
    display: block;
  }

  .footer-logo-img {
    max-height: 50px;
    width: auto;
  }

  .footer-logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    color: #fff;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .footer-intro {
    font-size: 14px;
    line-height: 1.8;
    color: #cfcfcf;
    font-style: italic;
    max-width: 380px;
    margin: 0;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 15px;
    color: #cfcfcf;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .contact-item:hover {
    color: #ffffff;
  }

  .contact-icon {
    width: 36px;
    height: 36px;
    border: 1px solid #333;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s ease;
  }

  .contact-item:hover .contact-icon {
    border-color: #ffffff;
  }

  .contact-icon svg {
    width: 14px;
    height: 14px;
  }

  /* Social Icons */
  .footer-socials {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .social-link {
    width: 44px;
    height: 44px;
    border: 1px solid {{ section.settings.social_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.social_icon_color }};
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    border-color: {{ section.settings.social_hover_border_color }};
    color: {{ section.settings.social_hover_icon_color }};
    background-color: {{ section.settings.social_hover_bg_color }};
  }

  .social-link svg {
    width: 18px;
    height: 18px;
  }

  /* Link Columns */
  .footer-col-title {
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 30px;
    position: relative;
  }

  .footer-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav-list li {
    margin-bottom: 12px;
  }

  .footer-nav-list a {
    color: #cfcfcf;
    text-decoration: none;
    font-size: 14px;
    transition: all 0.30s ease;
    display: flex;
    align-items: center;
    gap:0.5rem;
    width: 100%;
  }

  .footer-nav-list a:hover {
    color: #fff;
    padding-left: 5px;
  }

  .footer-nav-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    opacity: 0.6;
  }

  .footer-nav-arrow svg {
    width: 12px;
    height: 12px;
  }

  .footer-nav-list a:hover .footer-nav-arrow {
    transform: rotate(-45deg);
    opacity: 1;
  }

  /* Bottom Bar */
  .footer-bottom {
    border-top: 1px solid #1a1a1a;
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copyright {
    font-size: 11px;
    color: #cfcfcf;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .footer-payments {
    display: flex;
    gap: 10px;
  }

  .payment-icon {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .payment-icon:hover {
    opacity: 1;
  }

  .payment-custom-img {
    height: 30px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .footer-row {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-branding {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-row {
      grid-template-columns: 1fr;
    }
    .footer-branding {
      grid-column: span 1;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
{% endstyle %}

<footer class="custom-footer">
  <div class="footer-container">
    <div class="footer-row">
      <!-- Left Column: Branding -->
      <div class="footer-branding">
        <a href="/" class="footer-logo">
          {% if logo_image %}
            <img src="{{ logo_image | img_url: '400x' }}" alt="{{ logo_text }}" class="footer-logo-img">
          {% else %}
            <span class="footer-logo-text">{{ logo_text }}</span>
          {% endif %}
        </a>
        
        {% if section.settings.footer_text != blank %}
          <p class="footer-intro">"{{ section.settings.footer_text }}"</p>
        {% endif %}

        <div class="footer-contact-info">
          {% if section.settings.contact_link != blank %}
            <a href="{{ section.settings.contact_link }}" class="contact-item">
              <span class="contact-icon">

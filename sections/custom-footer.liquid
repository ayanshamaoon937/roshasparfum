                  <path d="M15.125 4.5H15M13.75 9.75C13.75 10.8109 13.3286 11.8283 12.5784 12.5784C11.8283 13.3286 10.8109 13.75 9.75 13.75C8.68913 13.75 7.67172 13.3286 6.92157 12.5784C6.17143 11.8283 5.75 10.8109 5.75 9.75C5.75 8.68913 6.17143 7.67172 6.92157 6.92157C7.67172 6.17143 8.68913 5.75 9.75 5.75C10.8109 5.75 11.8283 6.17143 12.5784 6.92157C13.3286 7.67172 13.75 8.68913 13.75 9.75ZM15.25 4.5C15.25 4.5663 15.2237 4.62989 15.1768 4.67678C15.1299 4.72366 15.0663 4.75 15 4.75C14.9337 4.75 14.8701 4.72366 14.8232 4.67678C14.7763 4.62989 14.75 4.5663 14.75 4.5C14.75 4.4337 14.7763 4.37011 14.8232 4.32322C14.8701 4.27634 14.9337 4.25 15 4.25C15.0663 4.25 15.1299 4.27634 15.1768 4.32322C15.2237 4.37011 15.25 4.4337 15.25 4.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- elsif settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="social-link" target="_blank">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 9.75C0.75 5.507 0.75 3.386 2.068 2.068C3.386 0.75 5.508 0.75 9.75 0.75C13.992 0.75 16.114 0.75 17.432 2.068C18.75 3.386 18.75 5.508 18.75 9.75C18.75 13.992 18.75 16.114 17.432 17.432C16.114 18.75 13.992 18.75 9.75 18.75C5.508 18.75 3.386 18.75 2.068 17.432C0.75 16.114 0.75 13.992 0.75 9.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M15.125 4.5H15M13.75 9.75C13.75 10.8109 13.3286 11.8283 12.5784 12.5784C11.8283 13.3286 10.8109 13.75 9.75 13.75C8.68913 13.75 7.67172 13.3286 6.92157 12.5784C6.17143 11.8283 5.75 10.8109 5.75 9.75C5.75 8.68913 6.17143 7.67172 6.92157 6.92157C7.67172 6.17143 8.68913 5.75 9.75 5.75C10.8109 5.75 11.8283 6.17143 12.5784 6.92157C13.3286 7.67172 13.75 8.68913 13.75 9.75ZM15.25 4.5C15.25 4.5663 15.2237 4.62989 15.1768 4.67678C15.1299 4.72366 15.0663 4.75 15 4.75C14.9337 4.75 14.8701 4.72366 14.8232 4.67678C14.7763 4.62989 14.75 4.5663 14.75 4.5C14.75 4.4337 14.7763 4.37011 14.8232 4.32322C14.8701 4.27634 14.9337 4.25 15 4.25C15.0663 4.25 15.1299 4.27634 15.1768 4.32322C15.2237 4.37011 15.25 4.4337 15.25 4.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
              </a>
            {%- elsif settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_twitter != blank -%}
              <a href="{{ section.settings.social_twitter }}" class="social-link" target="_blank">
                <svg width="14" height="13" viewBox="0 0 14 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M11.025 0H13.172L8.482 5.374L14 12.688H9.68L6.294 8.253L2.424 12.688H0.275L5.291 6.938L0 0.000999987H4.43L7.486 4.054L11.025 0ZM10.27 11.4H11.46L3.78 1.221H2.504L10.27 11.4Z" fill="currentColor"/>
                </svg>
              </a>
            {%- elsif settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" class="social-link" target="_blank">
                <svg width="14" height="13" viewBox="0 0 14 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M11.025 0H13.172L8.482 5.374L14 12.688H9.68L6.294 8.253L2.424 12.688H0.275L5.291 6.938L0 0.000999987H4.43L7.486 4.054L11.025 0ZM10.27 11.4H11.46L3.78 1.221H2.504L10.27 11.4Z" fill="currentColor"/>
                </svg>
              </a>
{%- endif -%}

            {%- if section.settings.social_pinterest != blank -%}
              <a href="{{ section.settings.social_pinterest }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.27 2.68 7.89 6.46 9.31-.08-.8-.16-2.03.03-2.91l1.19-5.04s-.3-.6-.3-1.48c0-1.39.81-2.43 1.81-2.43.86 0 1.28.64 1.28 1.41 0 .86-.55 2.14-.83 3.33-.24.99.5 1.8 1.48 1.8 1.78 0 3.15-1.87 3.15-4.57 0-2.39-1.72-4.06-4.17-4.06-2.85 0-4.52 2.13-4.52 4.34 0 .86.33 1.78.74 2.28.08.1.09.19.07.29l-.27 1.11c-.04.18-.14.22-.33.14-1.24-.58-2.01-2.38-2.01-3.83 0-3.12 2.27-5.99 6.54-5.99 3.43 0 6.11 2.45 6.11 5.72 0 3.41-2.15 6.16-5.13 6.16-1.02 0-1.99-.54-2.32-1.17l-.63 2.4c-.23.88-.84 1.98-1.25 2.64C10.07 21.83 11 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"></path></svg>
              </a>
            {%- elsif settings.social_pinterest_link != blank -%}
              <a href="{{ settings.social_pinterest_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.27 2.68 7.89 6.46 9.31-.08-.8-.16-2.03.03-2.91l1.19-5.04s-.3-.6-.3-1.48c0-1.39.81-2.43 1.81-2.43.86 0 1.28.64 1.28 1.41 0 .86-.55 2.14-.83 3.33-.24.99.5 1.8 1.48 1.8 1.78 0 3.15-1.87 3.15-4.57 0-2.39-1.72-4.06-4.17-4.06-2.85 0-4.52 2.13-4.52 4.34 0 .86.33 1.78.74 2.28.08.1.09.19.07.29l-.27 1.11c-.04.18-.14.22-.33.14-1.24-.58-2.01-2.38-2.01-3.83 0-3.12 2.27-5.99 6.54-5.99 3.43 0 6.11 2.45 6.11 5.72 0 3.41-2.15 6.16-5.13 6.16-1.02 0-1.99-.54-2.32-1.17l-.63 2.4c-.23.88-.84 1.98-1.25 2.64C10.07 21.83 11 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"></path></svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_tiktok != blank -%}
              <a href="{{ section.settings.social_tiktok }}" class="social-link" target="_blank">
                <svg width="21" height="21" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 10.25C0.75 5.772 0.75 3.532 2.141 2.141C3.532 0.75 5.771 0.75 10.25 0.75C14.728 0.75 16.968 0.75 18.359 2.141C19.75 3.532 19.75 5.771 19.75 10.25C19.75 14.728 19.75 16.968 18.359 18.359C16.968 19.75 14.729 19.75 10.25 19.75C5.772 19.75 3.532 19.75 2.141 18.359C0.75 16.968 0.75 14.729 0.75 10.25Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M8.78589 9.26138C7.96589 9.14538 6.09589 9.33637 5.17989 11.0314C4.26389 12.7264 5.18689 14.4904 5.76389 15.1604C6.33289 15.7874 8.14189 16.9744 10.0609 15.8154C10.5369 15.5284 11.1299 15.3134 11.8019 13.0684L11.7239 4.23438C11.5939 5.20737 12.6689 7.48937 15.7279 7.75937" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- elsif settings.social_tiktok_link != blank -%}
              <a href="{{ settings.social_tiktok_link }}" class="social-link" target="_blank">
                <svg width="21" height="21" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0.75 10.25C0.75 5.772 0.75 3.532 2.141 2.141C3.532 0.75 5.771 0.75 10.25 0.75C14.728 0.75 16.968 0.75 18.359 2.141C19.75 3.532 19.75 5.771 19.75 10.25C19.75 14.728 19.75 16.968 18.359 18.359C16.968 19.75 14.729 19.75 10.25 19.75C5.772 19.75 3.532 19.75 2.141 18.359C0.75 16.968 0.75 14.729 0.75 10.25Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <path d="M8.78589 9.26138C7.96589 9.14538 6.09589 9.33637 5.17989 11.0314C4.26389 12.7264 5.18689 14.4904 5.76389 15.1604C6.33289 15.7874 8.14189 16.9744 10.0609 15.8154C10.5369 15.5284 11.1299 15.3134 11.8019 13.0684L11.7239 4.23438C11.5939 5.20737 12.6689 7.48937 15.7279 7.75937" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {% endif %}
      </div>

      <!-- Navigation Columns -->
      {% for block in section.blocks %}
        {% if block.type == 'link_list' %}
          <div class="footer-column" {{ block.shopify_attributes }}>
            <h4 class="footer-col-title">{{ block.settings.title }}</h4>
            <ul class="footer-nav-list">
              {% for link in block.settings.menu.links %}
                <li>
                  <a href="{{ link.url }}">
                    {{ link.title }}
                    <span class="footer-nav-arrow">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </span>
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        © {{ 'now' | date: "%Y" }} {{ section.settings.copyright_text | default: 'ROSHAS PARFUM. CURATED INTERNATIONALLY, DELIVERED REGIONALLY.' }}
      </div>
      
      {% if section.settings.show_payment %}
        <div class="footer-payments">
          {% if section.settings.payment_image %}
            <img src="{{ section.settings.payment_image | img_url: 'master' }}" alt="Payment Methods" class="payment-custom-img">
          {% else %}
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Footer Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text Overlay",
      "default": "ROSHAS"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Intro Text",
      "default": "An olfactory sanctuary dedicated to the world's most prestigious fragrances. Authenticity is our heritage, modern luxury is our signature."
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact Us Link"
    },
    {
      "type": "text",
      "id": "location_text",
      "label": "Location Text",
      "default": "AMMAN, JORDAN"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook Link"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter Link"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest Link"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok Link"
    },
    {
      "type": "color",
      "id": "social_border_color",
      "label": "Social Border Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Social Icon Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_hover_border_color",
      "label": "Social Hover Border Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_hover_bg_color",
      "label": "Social Hover Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_hover_icon_color",
      "label": "Social Hover Icon Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "ROSHAS PARFUM. CURATED INTERNATIONALLY, DELIVERED REGIONALLY."
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show Payment Icons",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Custom Payment Image (Optional)"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",

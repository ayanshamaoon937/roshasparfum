{%- liquid
  assign logo_image = section.settings.logo_image
  assign logo_text = section.settings.logo_text | default: shop.name
-%}

{% style %}
  .custom-footer {
    background: #000000;
    color: #ffffff;
    padding: 80px 0 30px;
    font-family: 'Jost', sans-serif;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .footer-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 60px;
  }

  /* Left Column Branding */
  .footer-branding {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .footer-logo {
    display: block;
  }

  .footer-logo-img {
    max-height: 50px;
    width: auto;
  }

  .footer-logo-text {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    color: #fff;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .footer-intro {
    font-size: 14px;
    line-height: 1.8;
    color: #cfcfcf;
    font-style: italic;
    max-width: 380px;
    margin: 0;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 15px;
    color: #cfcfcf;
    text-decoration: none;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .contact-item:hover {
    color: #ffffff;
  }

  .contact-icon {
    width: 36px;
    height: 36px;
    border: 1px solid #333;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s ease;
  }

  .contact-item:hover .contact-icon {
    border-color: #ffffff;
  }

  .contact-icon svg {
    width: 14px;
    height: 14px;
  }

  /* Social Icons */
  .footer-socials {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .social-link {
    width: 44px;
    height: 44px;
    border: 1px solid {{ section.settings.social_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.social_icon_color }};
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    border-color: {{ section.settings.social_hover_border_color }};
    color: {{ section.settings.social_hover_icon_color }};
    background-color: {{ section.settings.social_hover_bg_color }};
  }

  .social-link svg {
    width: 18px;
    height: 18px;
  }

  /* Link Columns */
  .footer-col-title {
    color: #ffffff;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 30px;
    position: relative;
  }

  .footer-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-nav-list li {
    margin-bottom: 12px;
  }

  .footer-nav-list a {
    color: #cfcfcf;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.30s ease;
    display: block;
  }

  .footer-nav-list a:hover {
    color: #fff;
    margin-left: 5px;
  }

  /* Bottom Bar */
  .footer-bottom {
    border-top: 1px solid #1a1a1a;
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copyright {
    font-size: 11px;
    color: #cfcfcf;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .footer-payments {
    display: flex;
    gap: 10px;
  }

  .payment-icon {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .payment-icon:hover {
    opacity: 1;
  }

  .payment-custom-img {
    height: 30px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .footer-row {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .footer-branding {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-row {
      grid-template-columns: 1fr;
    }
    .footer-branding {
      grid-column: span 1;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
{% endstyle %}

<footer class="custom-footer">
  <div class="footer-container">
    <div class="footer-row">
      <!-- Left Column: Branding -->
      <div class="footer-branding">
        <a href="/" class="footer-logo">
          {% if logo_image %}
            <img src="{{ logo_image | img_url: '400x' }}" alt="{{ logo_text }}" class="footer-logo-img">
          {% else %}
            <span class="footer-logo-text">{{ logo_text }}</span>
          {% endif %}
        </a>
        
        {% if section.settings.footer_text != blank %}
          <p class="footer-intro">"{{ section.settings.footer_text }}"</p>
        {% endif %}

        <div class="footer-contact-info">
          {% if section.settings.contact_link != blank %}
            <a href="{{ section.settings.contact_link }}" class="contact-item">
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </span>
              CONTACT US
            </a>
          {% endif %}

          {% if section.settings.location_text != blank %}
            <div class="contact-item">
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </span>
              {{ section.settings.location_text }}
            </div>
          {% endif %}
        </div>

        {% if section.settings.show_social %}
          <div class="footer-socials">
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
            {%- elsif settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_facebook != blank -%}
              <a href="{{ section.settings.social_facebook }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
              </a>
            {%- elsif settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_twitter != blank -%}
              <a href="{{ section.settings.social_twitter }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
              </a>
            {%- elsif settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_pinterest != blank -%}
              <a href="{{ section.settings.social_pinterest }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.27 2.68 7.89 6.46 9.31-.08-.8-.16-2.03.03-2.91l1.19-5.04s-.3-.6-.3-1.48c0-1.39.81-2.43 1.81-2.43.86 0 1.28.64 1.28 1.41 0 .86-.55 2.14-.83 3.33-.24.99.5 1.8 1.48 1.8 1.78 0 3.15-1.87 3.15-4.57 0-2.39-1.72-4.06-4.17-4.06-2.85 0-4.52 2.13-4.52 4.34 0 .86.33 1.78.74 2.28.08.1.09.19.07.29l-.27 1.11c-.04.18-.14.22-.33.14-1.24-.58-2.01-2.38-2.01-3.83 0-3.12 2.27-5.99 6.54-5.99 3.43 0 6.11 2.45 6.11 5.72 0 3.41-2.15 6.16-5.13 6.16-1.02 0-1.99-.54-2.32-1.17l-.63 2.4c-.23.88-.84 1.98-1.25 2.64C10.07 21.83 11 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"></path></svg>
              </a>
            {%- elsif settings.social_pinterest_link != blank -%}
              <a href="{{ settings.social_pinterest_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.27 2.68 7.89 6.46 9.31-.08-.8-.16-2.03.03-2.91l1.19-5.04s-.3-.6-.3-1.48c0-1.39.81-2.43 1.81-2.43.86 0 1.28.64 1.28 1.41 0 .86-.55 2.14-.83 3.33-.24.99.5 1.8 1.48 1.8 1.78 0 3.15-1.87 3.15-4.57 0-2.39-1.72-4.06-4.17-4.06-2.85 0-4.52 2.13-4.52 4.34 0 .86.33 1.78.74 2.28.08.1.09.19.07.29l-.27 1.11c-.04.18-.14.22-.33.14-1.24-.58-2.01-2.38-2.01-3.83 0-3.12 2.27-5.99 6.54-5.99 3.43 0 6.11 2.45 6.11 5.72 0 3.41-2.15 6.16-5.13 6.16-1.02 0-1.99-.54-2.32-1.17l-.63 2.4c-.23.88-.84 1.98-1.25 2.64C10.07 21.83 11 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"></path></svg>
              </a>
            {%- endif -%}

            {%- if section.settings.social_tiktok != blank -%}
              <a href="{{ section.settings.social_tiktok }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4h5a4 4 0 0 1-4 4"></path></svg>
              </a>
            {%- elsif settings.social_tiktok_link != blank -%}
              <a href="{{ settings.social_tiktok_link }}" class="social-link" target="_blank">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4h5a4 4 0 0 1-4 4"></path></svg>
              </a>
            {%- endif -%}
          </div>
        {% endif %}
      </div>

      <!-- Navigation Columns -->
      {% for block in section.blocks %}
        {% if block.type == 'link_list' %}
          <div class="footer-column" {{ block.shopify_attributes }}>
            <h4 class="footer-col-title">{{ block.settings.title }}</h4>
            <ul class="footer-nav-list">
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        © {{ 'now' | date: "%Y" }} {{ section.settings.copyright_text | default: 'ROSHAS PARFUM. CURATED INTERNATIONALLY, DELIVERED REGIONALLY.' }}
      </div>
      
      {% if section.settings.show_payment %}
        <div class="footer-payments">
          {% if section.settings.payment_image %}
            <img src="{{ section.settings.payment_image | img_url: 'master' }}" alt="Payment Methods" class="payment-custom-img">
          {% else %}
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Footer Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text Overlay",
      "default": "ROSHAS"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Intro Text",
      "default": "An olfactory sanctuary dedicated to the world's most prestigious fragrances. Authenticity is our heritage, modern luxury is our signature."
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact Us Link"
    },
    {
      "type": "text",
      "id": "location_text",
      "label": "Location Text",
      "default": "AMMAN, JORDAN"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook Link"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter Link"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest Link"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok Link"
    },
    {
      "type": "color",
      "id": "social_border_color",
      "label": "Social Border Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Social Icon Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_hover_border_color",
      "label": "Social Hover Border Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_hover_bg_color",
      "label": "Social Hover Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "social_hover_icon_color",
      "label": "Social Hover Icon Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "ROSHAS PARFUM. CURATED INTERNATIONALLY, DELIVERED REGIONALLY."
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show Payment Icons",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Custom Payment Image (Optional)"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Column",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "COLLECTIONS"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": { "title": "COLLECTIONS" }
        },
        {
          "type": "link_list",
          "settings": { "title": "EXPERIENCE" }
        },
        {
          "type": "link_list",
          "settings": { "title": "CLIENT CARE" }
        }
      ]
    }
  ]
}
{% endschema %}

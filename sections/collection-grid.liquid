{%- liquid
  assign section_padding_top = section.settings.padding_top
  assign section_padding_bottom = section.settings.padding_bottom
  assign bg_color = section.settings.background_color
-%}

{%- style -%}
  .collection-grid-{{ section.id }} {
    background-color: {{ bg_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .collection-grid-{{ section.id }} {
      padding-top: {{ section_padding_top }}px;
      padding-bottom: {{ section_padding_bottom }}px;
    }
  }

  .collection-grid-wrapper-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }
  @media (max-width: 768px) {
    .collection-grid-wrapper-{{ section.id }} {
      padding: 0 20px;
    }
  }

  @media screen and (min-width: 750px) {
    .collection-grid-wrapper-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(2, 300px); /* Adjust height as needed */
      height: 620px; /* Total height with gap */
    }
    .card-large-{{ section.id }} {
      grid-row: span 2;
      height: 100%;
    }
  }

  .collection-card-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    text-decoration: none;
    height: 350px; /* Mobile height */
    border-radius: 4px;
    transition: transform 0.3s ease;
  }

  @media screen and (min-width: 750px) {
    .collection-card-{{ section.id }} {
      height: 100%;
    }
  }

  .collection-card-{{ section.id }}:hover {
    transform: scale(1.01);
  }

  .collection-card-bg-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .collection-card-bg-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .collection-card-{{ section.id }}:hover .collection-card-bg-{{ section.id }} img {
    transform: scale(1.1);
  }

  .collection-card-overlay-{{ section.id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.7) 100%);
    z-index: 2;
  }

  .collection-card-content-{{ section.id }} {
    position: relative;
    z-index: 3;
    padding: 30px;
    width: 100%;
    color: #fff;
  }

  .collection-card-subtitle-{{ section.id }} {
    display: block;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 10px;
    margin-bottom: 10px;
    opacity: 0.9;
  }

  .collection-card-heading-{{ section.id }} {
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    line-height: 1.2;
    font-family: var(--font-heading--family);
    text-transform: capitalize;
  }

  @media screen and (min-width: 750px) {
    .collection-card-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .collection-card-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  .collection-card-description-{{ section.id }} {
    margin-bottom: {{ section.settings.desc_margin_bottom }}px;
    font-weight: {{ section.settings.desc_font_weight }};
    color: {{ section.settings.desc_color }};
    font-size: {{ section.settings.desc_font_size }}px;
    line-height: 1.5;
    max-width: 80%;
  }

  .collection-card-button-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    font-size: {{ section.settings.btn_font_size }}px;
    color: {{ section.settings.btn_color }};
    background-color: {{ section.settings.btn_bg_color }};
    border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
    padding: 8px 0; /* Padding focused on line and space */
    text-decoration: none;
    position: relative;
    transition: all 0.3s ease;
  }

  .collection-card-button-{{ section.id }} svg {
    width: 18px;
    height: 18px;
    margin-left: 10px;
    transition: transform 0.3s ease;
  }

  .collection-card-{{ section.id }}:hover .collection-card-button-{{ section.id }} svg {
    transform: translateX(5px);
  }

  .collection-card-{{ section.id }}:hover .collection-card-button-{{ section.id }} {
    color: {{ section.settings.btn_hover_color }};
  }
{%- endstyle -%}

<section class="collection-grid-{{ section.id }}">
  <div class="collection-grid-wrapper-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = collections[block.settings.collection]
        assign image = block.settings.image | default: collection.featured_image
        assign heading = block.settings.heading | default: collection.title
        assign subtitle = block.settings.subtitle
        assign description = block.settings.description | default: collection.description | strip_html | truncate: 150
      -%}

      <a href="{{ collection.url }}" class="collection-card-{{ section.id }} {% if forloop.first %}card-large-{{ section.id }}{% endif %}" {{ block.shopify_attributes }}>
        <div class="collection-card-bg-{{ section.id }}">
          {%- if image != blank -%}
             {{ image | image_url: width: 1500 | image_tag: loading: 'lazy', alt: heading }}
          {%- else -%}
             {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="collection-card-overlay-{{ section.id }}"></div>
        <div class="collection-card-content-{{ section.id }}">
          {%- if subtitle != blank -%}
            <span class="collection-card-subtitle-{{ section.id }}">{{ subtitle }}</span>
          {%- endif -%}
          <h3 class="collection-card-heading-{{ section.id }}">{{ heading }}</h3>
          {%- if description != blank -%}
            <p class="collection-card-description-{{ section.id }}">{{ description }}</p>
          {%- endif -%}
          <div class="collection-card-button-{{ section.id }}">
            Discover
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection Grid 3-Items",
  "settings": [
    {
      "type": "header",
      "content": "Section Styles"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Heading Styles"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "min": 20,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_font_size_tablet",
      "min": 18,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Tablet)",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 28
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 20
    },
    {
      "type": "header",
      "content": "Description Styles"
    },
    {
      "type": "range",
      "id": "desc_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 14
    },
    {
      "type": "select",
      "id": "desc_font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desc_margin_bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Button Styles"
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 12
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Text/Line Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "btn_border_width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Border Width",
      "default": 0
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Border Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "btn_hover_color",
      "label": "Button Hover Color",
      "default": "#808080"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (Optional)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "placeholder": "e.g. THE ART OF GIFTING"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading Override",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description Override",
          "info": "Leave blank to use collection description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid 3-Items",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

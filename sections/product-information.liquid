

{% liquid
  if section.settings.desktop_media_position == 'left'
    assign render_order = 'media,product-details'
  else
    assign render_order = 'product-details,media'
  endif

  assign product_has_media = true
  if closest.product.media.size == 0
    assign product_has_media = false
  endif

  assign product_grid_class = 'product-information__grid'

  if product_has_media == false
    assign product_grid_class = product_grid_class | append: ' product-information--media-none'
  elsif section.settings.desktop_media_position == 'right'
    assign product_grid_class = product_grid_class | append: ' product-information--media-right'
  else
    assign product_grid_class = product_grid_class | append: ' product-information--media-left'
  endif

  if section.settings.equal_columns
    assign product_grid_class = product_grid_class | append: ' product-information__grid--half'

    if section.settings.limit_details_width
      assign product_grid_class = product_grid_class | append: ' product-information__grid--limit-details'
    endif
  endif

  case section.settings.content_width
    when 'content-center-aligned'
      assign content_width = 'page-width'
    when 'content-full-width'
      assign content_width = 'full-width'
  endcase
%}

<script type="application/ld+json">
  {{ closest.product | structured_data }}
</script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const share = document.querySelector('.product-information__share');
    const bannerContent = document.querySelector('.onhow-shipping-banner .onhow-shipping-content');
    if (share && bannerContent && bannerContent.parentNode) {
      bannerContent.insertAdjacentElement('afterend', share);
    }

    document.querySelectorAll('[data-pi-tabs]').forEach((tabsRoot) => {
      const tabs = tabsRoot.querySelectorAll('.pi-tabs__tab');
      const panels = tabsRoot.querySelectorAll('.pi-tabs__panel');

      function activate(tabName) {
        tabs.forEach((t) => t.setAttribute('aria-selected', t.dataset.tab === tabName ? 'true' : 'false'));
        panels.forEach((p) => {
          const active = p.dataset.panel === tabName;
          p.toggleAttribute('hidden', !active);
        });
      }

      tabsRoot.addEventListener('click', (e) => {
        const btn = e.target.closest('.pi-tabs__tab');
        if (!btn) return;
        activate(btn.dataset.tab);
      });
    });

    function moveJudgeMeIntoReviewsTab() {
      const reviewsSlot = document.querySelector('[data-pi-reviews-slot]');
      if (!reviewsSlot) return false;

      // Prefer the FULL Judge.me review widget (with review form), not the preview badge.
      const fullWidget =
        document.querySelector('#judgeme_product_reviews') ||
        document.querySelector('.jdgm-widget.jdgm-review-widget') ||
        document.querySelector('.jdgm-review-widget');

      // Fallback to any Judge.me container if needed
      const anyWidget =
        document.querySelector('.shopify-app-block.jdgm-horizon-widget') ||
        document.querySelector('.jdgm-horizon-widget') ||
        document.querySelector('.jdgm-widget');

      const target = fullWidget || anyWidget;
      if (!target) return false;

      // If it's inside a Shopify app block wrapper, move the wrapper for correct spacing/settings.
      const preferred = target.closest('.shopify-app-block') || target;
      reviewsSlot.appendChild(preferred);

      // Remove duplicates (but don't remove the one we just moved).
      document
        .querySelectorAll(
          '.shopify-app-block.jdgm-horizon-widget, .jdgm-horizon-widget, #judgeme_product_reviews, .jdgm-widget.jdgm-review-widget'
        )
        .forEach((el) => {
          const wrapper = el.closest('.shopify-app-block') || el;
          if (wrapper !== preferred && wrapper.parentNode) wrapper.remove();
        });

      return true;
    }

    // Try immediately (in case it's already in DOM)
    if (!moveJudgeMeIntoReviewsTab()) {
      // Judge.me often injects later; observe DOM until widget appears.
      const observer = new MutationObserver(() => {
        if (moveJudgeMeIntoReviewsTab()) observer.disconnect();
      });
      observer.observe(document.body, { childList: true, subtree: true });
    }
  });

  async function copyText(text) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch (e) {
      try {
        const input = document.createElement('input');
        input.value = text;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        input.remove();
        return true;
      } catch (e2) {
        return false;
      }
    }
  }

  document.addEventListener('click', async (event) => {
    const shareEl = event.target.closest('.product-information__share-link');
    if (!shareEl) return;

    const shareUrl = shareEl.getAttribute('data-share-url');
    if (!shareUrl) return;

    const shareTitle =
      shareEl.getAttribute('data-share-title') ||
      document.title ||
      'Share product';

    event.preventDefault();
    await copyText(shareUrl);

    /**
     * Best possible "inbox + choose recipient" behavior:
     * - On mobile (and some desktop browsers), Web Share API opens the system share sheet
     *   where the user can pick a person/app (WhatsApp, Messages, Instagram, etc).
     * - If not supported, we fall back to platform URLs (these usually do NOT let you pick a person).
     */
    if (navigator.share) {
      try {
        await navigator.share({ title: shareTitle, text: shareTitle, url: shareUrl });
        return;
      } catch (e) {
        // user cancelled or share failed; fall back to platform links below
      }
    }

    // Fallbacks
    if (shareEl.dataset.platform === 'twitter') {
      window.open(
        `https://twitter.com/messages/compose?text=${encodeURIComponent(`${shareTitle} ${shareUrl}`)}`,
        '_blank',
        'noopener,noreferrer'
      );
      return;
    }

    if (shareEl.dataset.platform === 'facebook') {
      // Facebook DM chooser requires app_id; fall back to share dialog.
      const href = shareEl.getAttribute('href');
      if (href) window.open(href, '_blank', 'noopener,noreferrer');
      return;
    }

    if (shareEl.dataset.platform === 'instagram') {
      window.open('https://www.instagram.com/', '_blank', 'noopener,noreferrer');
    }
  });
</script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="product-information section section--{{ content_width }} spacing-style color-{{ section.settings.color_scheme }} relative"
  style="{% render 'spacing-style', settings: section.settings %} --gap: {{ section.settings.gap }}px;"
>
  {% if section.settings.desktop_media_position == 'left' and product_has_media %}
    {% assign product_href = '#ProductInformation-' | append: section.id %}
    {% render 'skip-to-content-link', href: product_href, text: 'accessibility.skip_to_product_info' %}
  {% endif %}
  <nav
    class="product-information__breadcrumb"
    role="navigation"
    aria-label="breadcrumbs"
  >
    <a href="{{ routes.root_url }}" title="Home">Home</a>
    <span class="product-information__breadcrumb-separator">/</span>
    {%- if collection.url -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="product-information__breadcrumb-separator">/</span>
    {%- endif -%}
    <span class="product-information__breadcrumb-current">{{ closest.product.title }}</span>
  </nav>
  <div class="product-information__share" aria-label="Share this product">
    {%- assign share_url = canonical_url | default: shop.url | append: closest.product.url -%}
    <a
      class="product-information__share-link"
      data-share-url="{{ share_url | escape }}"
      data-share-title="{{ closest.product.title | escape }}"
      data-platform="facebook"
      href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Facebook"
    >
      <span class="product-information__share-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
      </span>
      <span class="product-information__share-text">FACEBOOK</span>
    </a>

    <a
      class="product-information__share-link"
      data-share-url="{{ share_url | escape }}"
      data-share-title="{{ closest.product.title | escape }}"
      data-platform="twitter"
      href="https://twitter.com/intent/tweet?url={{ share_url | url_encode }}&text={{ closest.product.title | url_encode }}"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Twitter"
    >
      <span class="product-information__share-icon" aria-hidden="true">
        <svg width="14" height="13" viewBox="0 0 14 13" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M11.025 0H13.172L8.482 5.374L14 12.688H9.68L6.294 8.253L2.424 12.688H0.275L5.291 6.938L0 0.000999987H4.43L7.486 4.054L11.025 0ZM10.27 11.4H11.46L3.78 1.221H2.504L10.27 11.4Z" fill="currentColor"/>
        </svg>
      </span>
      <span class="product-information__share-text">TWITTER</span>
    </a>

    <button
      type="button"
      class="product-information__share-link product-information__share-copy"
      data-share-url="{{ share_url | escape }}"
      data-share-title="{{ closest.product.title | escape }}"
      data-platform="instagram"
      aria-label="Share on Instagram"
    >
      <span class="product-information__share-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0.75 9.75C0.75 5.507 0.75 3.386 2.068 2.068C3.386 0.75 5.508 0.75 9.75 0.75C13.992 0.75 16.114 0.75 17.432 2.068C18.75 3.386 18.75 5.508 18.75 9.75C18.75 13.992 18.75 16.114 17.432 17.432C16.114 18.75 13.992 18.75 9.75 18.75C5.508 18.75 3.386 18.75 2.068 17.432C0.75 16.114 0.75 13.992 0.75 9.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M15.125 4.5H15M13.75 9.75C13.75 10.8109 13.3286 11.8283 12.5784 12.5784C11.8283 13.3286 10.8109 13.75 9.75 13.75C8.68913 13.75 7.67172 13.3286 6.92157 12.5784C6.17143 11.8283 5.75 10.8109 5.75 9.75C5.75 8.68913 6.17143 7.67172 6.92157 6.92157C7.67172 6.17143 8.68913 5.75 9.75 5.75C10.8109 5.75 11.8283 6.17143 12.5784 6.92157C13.3286 7.67172 13.75 8.68913 13.75 9.75ZM15.25 4.5C15.25 4.5663 15.2237 4.62989 15.1768 4.67678C15.1299 4.72366 15.0663 4.75 15 4.75C14.9337 4.75 14.8701 4.72366 14.8232 4.67678C14.7763 4.62989 14.75 4.5663 14.75 4.5C14.75 4.4337 14.7763 4.37011 14.8232 4.32322C14.8701 4.27634 14.9337 4.25 15 4.25C15.0663 4.25 15.1299 4.27634 15.1768 4.32322C15.2237 4.37011 15.25 4.4337 15.25 4.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="product-information__share-text">INSTAGRAM</span>
    </button>
  </div>
  <div
    class="{{ product_grid_class }}"
    data-product-grid-content
  >
    {% assign render_order_array = render_order | split: ',' %}
    {% capture media %}
      <div
        class="product-information__media"
        data-testid="product-information-media"
      >
        {%- content_for 'block',
          type: '_product-media-gallery',
          id: 'media-gallery',
          closest.product: closest.product
        -%}
      </div>
    {% endcapture %}

    {% capture details %}
      {% content_for 'block',
        type: '_product-details',
        id: 'product-details',
        closest.product: closest.product
      %}
    {% endcapture %}

    {% for block in render_order_array %}
      {% if block == 'media' and product_has_media %}
        {{ media }}
      {% elsif block == 'product-details' %}
        {{ details }}
      {% endif %}
    {% endfor %}
  </div>

  <section class="product-information__tabs-related" aria-label="Product details tabs and related products">
    <div class="product-information__tabs-related-inner">
      <div class="pi-tabs" data-pi-tabs>
        <div class="pi-tabs__tabs" role="tablist" aria-label="Product information tabs">
          <button class="pi-tabs__tab" type="button" role="tab" aria-selected="true" data-tab="description">
            Description
          </button>
          <button class="pi-tabs__tab" type="button" role="tab" aria-selected="false" data-tab="shipping">
            Shipping &amp; Returns
          </button>
          <button class="pi-tabs__tab" type="button" role="tab" aria-selected="false" data-tab="reviews">
            Reviews
          </button>
        </div>

        <div class="pi-tabs__panels">
          <div class="pi-tabs__panel" role="tabpanel" data-panel="description">
            {{ closest.product.description }}
          </div>
          <div class="pi-tabs__panel" role="tabpanel" hidden data-panel="shipping">
            {%- if closest.product.metafields.custom.shipping_return != blank -%}
              {{ closest.product.metafields.custom.shipping_return | metafield_tag }}
            {%- else -%}
              <p>Shipping &amp; returns information is not available.</p>
            {%- endif -%}
          </div>
          <div class="pi-tabs__panel" role="tabpanel" hidden data-panel="reviews">
            <div class="pi-tabs__reviews-slot" data-pi-reviews-slot>
              <!-- Judge.me app block will be moved here -->
            </div>
          </div>
        </div>
      </div>

      <aside class="pi-related" aria-label="Related products">
        <h3 class="pi-related__title">Related products</h3>
        <div class="pi-related__grid resource-list resource-list--grid">
          {%- liquid
            assign rel_collection = collection
            if rel_collection == blank
              for c in closest.product.collections
                unless c.handle == 'all'
                  assign rel_collection = c
                  break
                endunless
              endfor
            endif
          -%}

          {%- if rel_collection != blank -%}
            {%- assign shown = 0 -%}
            {%- for p in rel_collection.products -%}
              {%- if p.id == closest.product.id -%}
                {%- continue -%}
              {%- endif -%}
              <div class="resource-list__item">
                {%- capture related_gallery_children -%}
                  {% if settings.quick_add and p.available %}
                    {% render 'quick-add', product: p, section_id: section.id %}
                  {% endif %}
                {%- endcapture -%}

                {%- capture related_children -%}
                  {% render 'card-gallery', product: p, children: related_gallery_children %}
                  <product-title class="text-block">
                    <h3>{{ p.title }}</h3>
                  </product-title>
                  <product-price class="text-block">
                    {% render 'price', product_resource: p, show_unit_price: true %}
                  </product-price>
                {%- endcapture -%}
                {% render 'product-card', product: p, children: related_children, product_card_gap: 8 %}
              </div>
              {%- assign shown = shown | plus: 1 -%}
              {%- if shown == 2 -%}{%- break -%}{%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <p>No related products found.</p>
          {%- endif -%}
        </div>
      </aside>
    </div>
  </section>

  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .product-information {
    gap: 24px 0;
  }

  .product-information__breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 12px;
    color: currentColor;
    padding:25px 0 15px 0;
    position: relative;
  }

  /* Full-width border (spans viewport, not section width) */
  /*.product-information__breadcrumb::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 100vw;
    border-bottom: 1px solid #e5e5e5;
    pointer-events: none;
  }*/

  /* Force product-details stack spacing only (avoid affecting product cards, etc.) */
  .product-information .product-details .group-block-content.layout-panel-flex {
    --gap: 20px !important;
  }

  .product-information__breadcrumb a {
    color: #676464cf;
    text-decoration: none;
  }

  .product-information__breadcrumb-separator {
    color: #676464cf;
  }

  .product-information__breadcrumb-current {
    color: #000000;
  }

  .product-information__breadcrumb a:hover {
    color: #000000;
    opacity:1;
  }

  .product-information__share {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 24px 0;
  }

  /* Size swatch (variant buttons) styling to match design */
  .product-information .variant-option--buttons:not(.variant-option--swatches) {
    gap: 16px !important;
  }

  .product-information
    .variant-option--buttons:not(.variant-option--swatches)
    .variant-option__button-label:not(.variant-option__button-label--has-swatch) {
    border: 1px solid #e3e3e3 !important;
    background: transparent !important;
    border-radius: 0 !important;
    padding: 18px 26px !important;
    min-width: 80px !important;
    min-height: 40px !important;
    box-shadow: none !important;
    flex: 0 0 auto !important;
  }

  .product-information
    .variant-option--buttons:not(.variant-option--swatches)
    .variant-option__button-label:not(.variant-option__button-label--has-swatch)::before,
  .product-information
    .variant-option--buttons:not(.variant-option--swatches)
    .variant-option__button-label:not(.variant-option__button-label--has-swatch)::after {
    content: none !important;
  }

  .product-information
    .variant-option--buttons:not(.variant-option--swatches)
    .variant-option__button-label__pill {
    display: none !important;
  }
  .jdgm-rev-widg {
    padding:24px 0px !important;
  }
  .product-information
    .variant-option--buttons:not(.variant-option--swatches)
    .variant-option__button-label:not(.variant-option__button-label--has-swatch):has(:checked) {
    border-color: #000000 !important;
    color: #000000 !important;
    border-width: 1px !important;
  }

  .product-information__share-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    color: #000000;
    text-decoration: none;
    cursor: pointer;
    font: inherit;
  }

  /* Wishlist button next to Add to cart */
  .product-information .product-form-buttons__main-row {
    display: flex;
    gap: 16px;
    align-items: stretch;
    width: 100%;
  }

  .product-information .product-form-buttons__main-row > :first-child {
    flex: 1 1 auto;
    min-width: 0;
  }

  .product-information .product-form-buttons__wishlist {
    width: 52px;
    height: 52px;
    aspect-ratio: 1 / 1;
    border: 1px solid #d7d7d7;
    background: transparent;
    color: #000000;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
  }

  .product-information .product-form-buttons__wishlist svg {
    width: 22px;
    height: 22px;
  }

  .product-information .product-form-buttons__wishlist.is-active {
    border-color: #000000;
    background-color: #000000;
    color:#ffffff;
  }

  .product-information__tabs-related {
    margin-top: 48px;
  }

  .product-information__tabs-related-inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
    align-items: start;
  }

  @media screen and (max-width: 989px) {
    .product-information__tabs-related-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .pi-tabs__tabs {
    display: flex;
    gap: 28px;
    border-bottom: 1px solid #e6e6e6;
    padding-bottom: 12px;
    margin-bottom: 18px;
  }

  .pi-tabs__tab {
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: #000;
    position: relative;
  }

  .pi-tabs__tab[aria-selected='true']::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -13px;
    height: 2px;
    background: #000;
  }

  .pi-tabs__panel {
    color: #333;
    line-height: 1.75;
  }

  .pi-related__title {
    margin: 0 0 16px;
    font-size: 18px;
    font-weight: 600;
    color: #000;
  }

  .pi-related__grid {
    --resource-list-columns: repeat(2, minmax(0, 1fr));
    --resource-list-columns-mobile: repeat(2, minmax(0, 1fr));
    display: grid;
    grid-template-columns: var(--resource-list-columns);
    gap: 18px;
  }

  /* Related products: reduce media gallery height */
  .pi-related .product-card slideshow-slides {
    min-height: 320px !important;
  }

  .pi-related .product-card .card-gallery img {
    height: 320px !important;
    object-fit: cover !important;
  }

  @media screen and (max-width: 749px) {
    .pi-related__grid {
      grid-template-columns: var(--resource-list-columns-mobile);
    }
  }

  .product-information__share-icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .product-information__share-icon svg {
    width: 18px;
    height: 18px;
  }

  .product-information__share-text {
    letter-spacing: 2px;
    text-transform: uppercase;
    font-size: 16px;
    line-height: 1;
  }

  @media screen and (max-width: 749px) {
    .product-information__share {
      gap: 22px;
      flex-wrap: wrap;
    }

    .product-information__share-text {
      font-size: 14px;
    }
  }

  /* Header is fixed; push breadcrumbs below it */
  body:has(#header-group #header-component) .product-information__breadcrumb {
    padding-top: calc(var(--header-height, 0px) + var(--padding-sm));
  }

  /* Product media gallery is sticky: keep it below fixed header */
  .product-information media-gallery.sticky-content {
    --section-top-offset: 80px;
    --sticky-header-offset: 80px;
  }

  /* Base grid layout */
  .product-information__grid {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
  }

  /* Default column positions */
  .product-details {
    order: 1;
  }

  .product-information__media {
    order: 0;
    width: 0;
    min-width: 100%;
  }

  /* Mobile styles */
  @media screen and (max-width: 749px) {
    .product-information__media {
      grid-column: 1 / -1;
    }

    .product-details {
      grid-column: 2 / 3;
    }
  }

  /* Desktop styles */
  @media screen and (min-width: 750px) {
    .product-information__grid {
      grid-column: 2;
    }

    /* Position when there is no media */
    .product-information__grid.product-information--media-none,
    .product-information__grid:has(.product-information__media:empty) {
      .product-details {
        width: var(--narrow-content-width);
        margin: 0 auto;
      }
    }

    /* Position when there is media */
    .product-information__grid:not(:has(.product-information__media:empty)) {
      /* Media on the left side */
      &.product-information--media-left {
        grid-template-columns: 55fr 45fr;

        .product-information__media {
          padding-right: calc(var(--gap, 0) / 2);
        }

        .product-details {
          padding-left: calc(var(--gap, 0) / 2);
        }

        &:has(.media-gallery--extend) {
          grid-column: 1 / 3;
        }
      }

      /* Media on the right side */
      &.product-information--media-right {
        grid-template-columns: 45fr 55fr;

        .product-information__media {
          padding-left: calc(var(--gap, 0) / 2);
          order: 1;
        }

        .product-details {
          padding-right: calc(var(--gap, 0) / 2);
          order: 0;
        }

        &:has(.media-gallery--extend) {
          grid-column: 2 / -1;
        }
      }

      /* Equal width columns */
      &.product-information__grid--half,
      &.product-information__grid--half:has(.media-gallery--extend) {
        grid-column: 1 / -1;
        grid-template-columns:
          var(--full-page-grid-margin) 55fr 45fr
          var(--full-page-grid-margin);

        &.product-information--media-left {
          .product-information__media {
            grid-column: 2 / 3;

            &:has(.media-gallery--extend) {
              grid-column: 1 / 3;
            }
          }

          .product-details {
            grid-column: 3 / 4;
          }
        }

        &.product-information--media-right {
          .product-information__media {
            grid-column: 3 / 4;

            &:has(.media-gallery--extend) {
              grid-column: 3 / -1;
            }
          }

          .product-details {
            grid-column: 2 / 3;
          }
        }
      }
    }

    /* Handle full width section */
    .section--full-width {
      .product-information__grid:not(:has(.product-information__media:empty)),
      .product-information__grid:not(:has(.product-information__media:empty)) {
        &.product-information--media-left,
        &.product-information--media-right {
          grid-column: 1 / -1;
        }

        &.product-information--media-left .product-details {
          padding-inline-end: var(--padding-lg);
        }

        &.product-information--media-right .product-details {
          padding-inline-start: var(--padding-lg);
        }

        &.product-information__grid--half.product-information--media-left {
          .product-information__media {
            grid-column: 1 / 3;
          }

          .product-details {
            grid-column: 3 / -1;
          }
        }

        &.product-information__grid--half.product-information--media-right {
          .product-information__media {
            grid-column: 3 / -1;
          }

          .product-details {
            grid-column: 1 / 3;
          }
        }
      }
    }
  }

  /* Wider sidebar for large screens */
  @media screen and (min-width: 1200px) {
    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-left {
      grid-template-columns: 1.5fr 1fr;
      gap:0 !important;
    }

    .product-information__grid:not(
        .product-information__grid--half,
        :has(.product-information__media:empty)
      ).product-information--media-right {
      grid-template-columns: 1fr 2fr;
    }
  }

  .product-information__grid--limit-details .product-details > .group-block {
    max-width: var(--sidebar-width);
  }

  /* Design overrides matching the requested image */
  @media screen and (min-width: 750px) {
    .product-information__grid {
      gap: var(--gap, 2rem) !important;
    }

    .slideshow-controls__thumbnails-container {
      display: block !important;
      width: 100% !important;
      height: 100% !important;
      max-height: 500px !important;
      overflow-y: auto !important;
      scrollbar-width: none !important;
    }

    .slideshow-controls__thumbnails-container::-webkit-scrollbar {
      display: none !important;
    }

    /* Position arrows on the main image */
    slideshow-arrows {
      position: absolute !important;
      top: 50% !important;
      left: 0 !important;
      
      display: flex !important;
      justify-content: space-between !important;
      transform: translateY(-50%) !important;
      padding: 0 10px !important;
      pointer-events: none !important;
      z-index: 5 !important;
    }

    slideshow-arrows .slideshow-control {
      pointer-events: auto !important;
    }
  }

  @media screen and (max-width: 749px) {
    .slideshow-controls__thumbnails {
      display: flex !important;
      flex-direction: row !important;
      gap: 0.5rem !important;
      justify-content: center !important;
      padding: 1rem 0 !important;
      width: 100% !important;
      overflow-x: auto !important;
    }

    .slideshow-controls__thumbnail {
      width: 50px !important;
      height: 50px !important;
      border: 1px solid #e5e5e5 !important;
      padding: 2px !important;
      flex-shrink: 0 !important;
    }

    .media-gallery__mobile-controls .slideshow-controls__thumbnail[aria-selected="true"] {
      border-color: #000 !important;
    }
  }

  /* Thumbnails: remove outline, keep border-color feedback only */
  .slideshow-controls__thumbnails .slideshow-control[aria-selected='true'] {
    outline: none !important;
    border-color: #000 !important;
  }

  .slideshow-controls__thumbnail:focus,
  .slideshow-controls__thumbnail:focus-visible {
    outline: none !important;
    border-color: #000 !important;
  }

  /* Product details is sticky on desktop; keep it below fixed header */
  .product-details.sticky-content--desktop {
    --sticky-header-offset: 80px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_information",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "content-center-aligned",
          "label": "t:options.page"
        },
        {
          "value": "content-full-width",
          "label": "t:options.full"
        }
      ],
      "default": "content-center-aligned"
    },
    {
      "type": "select",
      "id": "desktop_media_position",
      "label": "t:settings.media_position",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "equal_columns",
      "label": "t:settings.equal_columns",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "limit_details_width",
      "label": "t:settings.limit_product_details_width",
      "default": false,
      "visible_if": "{{ section.settings.equal_columns }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}

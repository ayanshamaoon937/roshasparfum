{%- style -%}
  .collections-slider-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    position: relative;
    overflow: hidden;
    min-height: 550px;
    display: flex;
    align-items: center;
    background-color: #000;
  }

  @media screen and (min-width: 750px) {
    .collections-slider-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      min-height: 700px;
    }
  }

  .col-slider-bg-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .col-slider-bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1), transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    transform: scale(1.1);
  }

  .col-slider-bg-image.active {
    opacity: 1;
    z-index: 2;
    transform: scale(1);
  }

  .col-slider-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.8) 100%);
    z-index: 3;
  }

  .col-slider-content-slider {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }
  @media (max-width: 768px) {
    .col-slider-content-slider {
      padding: 0 16px;
    }
  }

  .col-slider-slide-content {
    display: none;
    max-width: 650px;
    animation: slideUpFade 1s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .col-slider-slide-content.active {
    display: block;
  }

  @keyframes slideUpFade {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .col-slider-subtitle {
     font-family: var(--font-body--family), sans-serif;
     font-size: 11px;
     letter-spacing: 4px;
     text-transform: uppercase;
     color: {{ section.settings.subtitle_color }};
     margin-bottom: 30px;
     display: block;
     font-weight: 600;
  }

  .col-slider-heading {
    font-family: var(--font-heading--family), serif;
    line-height: 1.1;
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_font_weight }};
    font-size: {{ section.settings.heading_font_size_mobile }}px;
  }

  .col-slider-description {
    font-family: var(--font-body--family), sans-serif;
    line-height: var(--line-height--body-loose);
    margin-bottom: {{ section.settings.desc_margin_bottom }}px;
    max-width: 450px;
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_font_weight }};
    font-size: {{ section.settings.desc_font_size }}px;
    opacity: 0.8;
  }

  .col-slider-button {
    font-family: var(--font-body--family), sans-serif;
    display: inline-block;
    padding: 16px 45px;
    background-color: #808080;
    color: #ffffff;
    text-decoration: none;
    text-transform: capitalize;
    font-size: 12px;
    letter-spacing: 0.2em;
    font-weight: 500;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: none;
  }

  .col-slider-button:hover {
    background-color: #ffffff;
    transform: translateY(-3px);
    color: #000000;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  @media screen and (min-width: 750px) {
    .col-slider-heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .col-slider-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  /* Right Side Navigation Bars */
  .col-slider-nav-bars {
    position: absolute;
    top: 50%;
    right: 5%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 10;
    align-items: flex-end;
  }
  

  .col-slider-bar {
    width: 25px;
    height: 5px;
    border-radius: 5px;
    background: rgba(255,255,255,0.3);
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .col-slider-bar:hover {
    background: rgba(255,255,255,0.6);
    width: 35px;
  }

  .col-slider-bar.active {
    width: 65px;
    background: #ffffff;
  }

  /* Big Slide Number Backdrop */
  .col-slider-number-backdrop {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-size: 25vw;
    font-family: var(--font-heading--family);
    color: rgba(255,255,255,0.03);
    z-index: 4;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    font-weight: 700;
  }

  @media screen and (max-width: 749px) {
    .col-slider-nav-bars {
      right: 20px;
      bottom:0;
      top:unset;
    }
    .col-slider-number-backdrop {
        display: none;
    }
  }
{%- endstyle -%}

<section class="collections-slider-{{ section.id }}" id="CollectionsSlider-{{ section.id }}">
  <div class="col-slider-bg-container">
    {%- for block in section.blocks -%}
      {%- assign bg_image = block.settings.image | default: block.settings.collection.featured_image -%}
      {%- if bg_image != blank -%}
        {%- liquid
          assign image_class = 'col-slider-bg-image'
          if forloop.first
            assign image_class = image_class | append: ' active'
          endif
        -%}
        {{ bg_image 
           | image_url: width: 3840 
           | image_tag: 
             loading: 'eager', 
             class: image_class,
             data-index: forloop.index0
        }}
      {%- else -%}
        <div class="col-slider-bg-image {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
           {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="col-slider-overlay"></div>
  
  <div class="col-slider-number-backdrop" id="BackdropText-{{ section.id }}">01</div>

  <div class="col-slider-content-slider">
    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = collections[block.settings.collection]
        assign heading = block.settings.heading | default: collection.title
        assign description = block.settings.description | default: collection.description | strip_html | truncate: 150
      -%}
      <div 
        class="col-slider-slide-content {% if forloop.first %}active{% endif %}" 
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.subtitle != blank -%}
          <span class="col-slider-subtitle">{{ block.settings.subtitle }}</span>
        {%- endif -%}
        
        <h2 class="col-slider-heading">{{ heading }}</h2>

        {%- if description != blank -%}
          <p class="col-slider-description">{{ description }}</p>
        {%- endif -%}

        <a href="{{ collection.url | default: '#' }}" class="col-slider-button">
          {{ block.settings.button_label | default: 'Explore Collection' }}
        </a>
      </div>
    {%- endfor -%}
  </div>

  <div class="col-slider-nav-bars">
    {%- for block in section.blocks -%}
      <div 
        class="col-slider-bar {% if forloop.first %}active{% endif %}" 
        data-index="{{ forloop.index0 }}"
        title="Go to slide {{ forloop.index }}"
      ></div>
    {%- endfor -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#CollectionsSlider-{{ section.id }}');
    if (!section) return;

    const bars = section.querySelectorAll('.col-slider-bar');
    const bgImages = section.querySelectorAll('.col-slider-bg-image');
    const contents = section.querySelectorAll('.col-slider-slide-content');
    const backdropText = section.querySelector('#BackdropText-{{ section.id }}');
    
    let currentIndex = 0;
    const totalSlides = bars.length;
    const autoplay = {{ section.settings.autoplay | default: false }};
    const autoplaySpeed = {{ section.settings.autoplay_speed | default: 5000 }};
    let autoplayInterval;

    function goToSlide(index) {
        currentIndex = parseInt(index);
        const slideNum = (currentIndex + 1).toString().padStart(2, '0');

        // Update Nav Bars
        bars.forEach(b => b.classList.remove('active'));
        if (bars[currentIndex]) bars[currentIndex].classList.add('active');

        // Update Backdrop Number
        if (backdropText) {
          backdropText.innerText = slideNum;
        }

        // Update Background Images
        bgImages.forEach(img => img.classList.remove('active'));
        const activeImg = section.querySelector(`.col-slider-bg-image[data-index="${currentIndex}"]`);
        if (activeImg) {
          activeImg.classList.add('active');
        }

        // Update Text Content
        contents.forEach(c => c.classList.remove('active'));
        const activeContent = section.querySelector(`.col-slider-slide-content[data-index="${currentIndex}"]`);
        if (activeContent) {
          activeContent.classList.add('active');
        }
    }

    bars.forEach(bar => {
      bar.addEventListener('click', function() {
        const index = this.getAttribute('data-index');
        goToSlide(index);
        resetAutoplay();
      });
    });

    function startAutoplay() {
        if (!autoplay) return;
        autoplayInterval = setInterval(() => {
            let nextIndex = (currentIndex + 1) % totalSlides;
            goToSlide(nextIndex);
        }, autoplaySpeed);
    }

    function resetAutoplay() {
        if (autoplayInterval) {
            clearInterval(autoplayInterval);
            startAutoplay();
        }
    }

    startAutoplay();
  });
</script>


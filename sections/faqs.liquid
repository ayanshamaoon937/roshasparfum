{%- style -%}
  .faq-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .faq-container-{{ section.id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px 80px;
    align-items: flex-start;
  }

  .faq-category-title {
    font-family: 'Playfair Display', serif !important;
    font-size: 28px;
    font-weight: 500;
    margin-bottom: 30px;
    color: #000;
  }

  .faq-item {
    border-bottom: 1px solid #ebebeb;
    margin-bottom: 0px;
  }

  .faq-question-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    padding: 18px 0;
    cursor: pointer;
    text-align: left;
    color: {{ section.settings.question_color }};
    font-weight: {{ section.settings.question_font_weight }};
    margin-bottom: {{ section.settings.question_margin_bottom }}px;
    font-family: 'Jost', sans-serif !important;
    transition: color 0.3s ease;
    font-size: {{ section.settings.question_font_size_mobile }}px;
  }

  .faq-icon {
    position: relative;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-left: 20px;
  }

  .faq-icon::before, .faq-icon::after {
    content: '';
    position: absolute;
    background-color: currentColor;
    transition: transform 0.3s ease;
  }

  /* Horizontal bar */
  .faq-icon::before {
    width: 100%;
    height: 1px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  /* Vertical bar */
  .faq-icon::after {
    width: 1px;
    height: 100%;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .faq-item.is-open .faq-icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq-answer-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-answer {
    padding-bottom: 20px;
    color: {{ section.settings.answer_color }};
    font-weight: {{ section.settings.answer_font_weight }};
    margin-bottom: {{ section.settings.answer_margin_bottom }}px;
    font-family: 'Jost', sans-serif !important;
    line-height: 1.6;
    font-size: {{ section.settings.answer_font_size_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .faq-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
    .faq-question-btn {
      font-size: {{ section.settings.question_font_size_tablet }}px;
    }
    .faq-answer {
      font-size: {{ section.settings.answer_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .faq-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
    .faq-question-btn {
      font-size: {{ section.settings.question_font_size_desktop }}px;
    }
    .faq-answer {
      font-size: {{ section.settings.answer_font_size_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .faq-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .faq-container-{{ section.id }} {
      padding: 0 20px;
    }
  }
{%- endstyle -%}

<section class="faq-section-{{ section.id }}">
  <div class="faq-container-{{ section.id }}">
    <div class="faq-grid">
      
      {%- liquid
         assign left_column_blocks = ""
         assign right_column_blocks = ""
         
         assign block_count = 0
         for block in section.blocks
            if block.type == 'category'
               assign block_count = block_count | plus: 1
            endif
         endfor
         
         assign category_index = 0
      -%}

      {%- comment -%}
        In order to support a two-column layout where each category contains its questions,
        we group them. Since blocks are flat, we just iterate and track which category we're in.
      {%- endcomment -%}
      
      <div class="faq-column-left">
        {%- assign current_cat_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            {%- assign current_cat_index = current_cat_index | plus: 1 -%}
          {%- endif -%}
          
          {%- assign column_side = current_cat_index | modulo: 2 -%}
          {%- if column_side == 1 -%}
             {%- if block.type == 'category' -%}
                <h3 class="faq-category-title">{{ block.settings.title }}</h3>
             {%- elsif block.type == 'faq_item' -%}
                <div class="faq-item" {{ block.shopify_attributes }}>
                  <button class="faq-question-btn" aria-expanded="false">
                    <span>{{ block.settings.question }}</span>
                    <span class="faq-icon"></span>
                  </button>
                  <div class="faq-answer-wrap">
                    <div class="faq-answer">
                      {{ block.settings.answer }}
                    </div>
                  </div>
                </div>
             {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="faq-column-right">
        {%- assign current_cat_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            {%- assign current_cat_index = current_cat_index | plus: 1 -%}
          {%- endif -%}
          
          {%- assign column_side = current_cat_index | modulo: 2 -%}
          {%- if column_side == 0 and current_cat_index > 0 -%}
             {%- if block.type == 'category' -%}
                <h3 class="faq-category-title">{{ block.settings.title }}</h3>
             {%- elsif block.type == 'faq_item' -%}
                <div class="faq-item" {{ block.shopify_attributes }}>
                  <button class="faq-question-btn" aria-expanded="false">
                    <span>{{ block.settings.question }}</span>
                    <span class="faq-icon"></span>
                  </button>
                  <div class="faq-answer-wrap">
                    <div class="faq-answer">
                      {{ block.settings.answer }}
                    </div>
                  </div>
                </div>
             {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<script>
  function initFaqAccordion() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const btn = item.querySelector('.faq-question-btn');
      const wrap = item.querySelector('.faq-answer-wrap');
      const answer = item.querySelector('.faq-answer');

      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');
        
        // Close other items if needed (optional)
        // faqItems.forEach(otherItem => {
        //   if (otherItem !== item) {
        //     otherItem.classList.remove('is-open');
        //     otherItem.querySelector('.faq-answer-wrap').style.maxHeight = null;
        //     otherItem.querySelector('.faq-question-btn').setAttribute('aria-expanded', 'false');
        //   }
        // });

        if (isOpen) {
          item.classList.remove('is-open');
          wrap.style.maxHeight = null;
          btn.setAttribute('aria-expanded', 'false');
        } else {
          item.classList.add('is-open');
          wrap.style.maxHeight = answer.scrollHeight + 20 + 'px';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initFaqAccordion);
  document.addEventListener('shopify:section:load', initFaqAccordion);
</script>


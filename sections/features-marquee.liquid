    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 10
    },
    {
      "type": "select",
      "id": "desc_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Font Color",
      "default": "#999999"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image"
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG (Alternative)"
        },
        {

{%- liquid
  assign speed = section.settings.speed | default: 30
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign border_color = section.settings.border_color | default: '#f0f0f0'
-%}

{% style %}
  .features-marquee-wrapper {
    background-color: {{ bg_color }};
    border-top: 1px solid {{ border_color }};
    border-bottom: 1px solid {{ border_color }};
    overflow: hidden;
    padding: 30px 0;
    position: relative;
    user-select: none;
  }

  .features-marquee-content {
    display: flex;
    white-space: nowrap;
    width: fit-content;
    animation: featuresMarquee {{ speed }}s linear infinite;
  }

  .features-marquee-wrapper:hover .features-marquee-content {
    animation-play-state: paused;
  }

  @keyframes featuresMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 0 40px;
    flex-shrink: 0;
  }

  .feature-icon-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-icon-wrap img, 
  .feature-icon-wrap svg {
    max-width: {{ section.settings.icon_max_width }}px;
    height: auto;
    object-fit: contain;
    color: {{ section.settings.icon_color | default: '#b59b61' }};
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-heading {
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }

  .feature-description {
    font-family: 'Jost', sans-serif;
    font-size: {{ section.settings.desc_size }}px;
    font-weight: {{ section.settings.desc_weight }};
    color: {{ section.settings.desc_color }};
    margin: 4px 0 0 0;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .feature-separator {
    width: 30px;
    height: 1px;
    background-color: {{ border_color }};
    margin: 0 40px;
    align-self: center;
  }

{% endstyle %}

<div class="features-marquee-wrapper">
  <div class="features-marquee-content">
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        <div class="feature-item" {{ block.shopify_attributes }}>
          <div class="feature-icon-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | img_url: '100x' }}" alt="{{ block.settings.heading }}">
            {%- elsif block.settings.icon_svg != blank -%}
              <div class="svg-wrap" style="width: {{ section.settings.icon_max_width }}px;">
                {{ block.settings.icon_svg }}
              </div>
            {%- endif -%}
          </div>
          <div class="feature-text">
            <h3 class="feature-heading">{{ block.settings.heading }}</h3>
            <p class="feature-description">{{ block.settings.description }}</p>
          </div>
        </div>
        <div class="feature-separator"></div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Features Marquee",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Animation Speed",
      "default": 30
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border/Separator Color",
      "default": "#f0f0f0"
    },
    {
      "type": "header",
      "content": "Icon Styles"
    },
    {
      "type": "range",
      "id": "icon_max_width",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Icon Max Width",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color (for SVG)",
      "default": "#b59b61"
    },
    {
      "type": "header",
      "content": "Heading Styles"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 18
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Font Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Description Styles"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 10
    },
    {
      "type": "select",
      "id": "desc_weight",
      "label": "Font Weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Font Color",
      "default": "#999999"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image"
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG (Alternative)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Guaranteed"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Small Description",
          "default": "QUALITY CONTROL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Marquee",
      "blocks": [
        { "type": "feature", "settings": { "heading": "Guaranteed", "description": "QUALITY CONTROL" } },
        { "type": "feature", "settings": { "heading": "Sourcing", "description": "GLOBAL NETWORK" } },
        { "type": "feature", "settings": { "heading": "Secure", "description": "ENCRYPTED PAY" } },
        { "type": "feature", "settings": { "heading": "Returns", "description": "EASY EXCHANGE" } },
        { "type": "feature", "settings": { "heading": "Authentic", "description": "OFFICIAL PARTNERS" } }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign speed = section.settings.speed | default: 30
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign border_color = section.settings.border_color | default: '#f0f0f0'
-%}

{% style %}
  .features-marquee-wrapper {
    background-color: {{ bg_color }};
    border-top: 1px solid {{ border_color }};
    border-bottom: 1px solid {{ border_color }};
    overflow: hidden;
    padding: 30px 0;
    position: relative;
    user-select: none;
  }

  .features-marquee-content {
    display: flex;
    white-space: nowrap;
    width: fit-content;
    animation: featuresMarquee {{ speed }}s linear infinite;
  }

  .features-marquee-wrapper:hover .features-marquee-content {
    animation-play-state: paused;
  }

  @keyframes featuresMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 0 40px;
    flex-shrink: 0;
  }

  .feature-icon-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .feature-icon-wrap img, 
  .feature-icon-wrap svg {
    width: {{ section.settings.icon_width }}px !important;
    height: {{ section.settings.icon_height }}px !important;
    max-width: none !important;
    object-fit: contain;
    color: {{ section.settings.icon_color | default: '#b59b61' }};
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-heading {
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }

  .feature-description {
    font-family: 'Jost', sans-serif;
    font-size: {{ section.settings.desc_size }}px;
    font-weight: {{ section.settings.desc_weight }};
    color: {{ section.settings.desc_color }};
    margin: 4px 0 0 0;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .feature-separator {
    width: 30px;
    height: 1px;
    background-color: {{ border_color }};
    margin: 0 40px;
    align-self: center;
  }

{% endstyle %}

<div class="features-marquee-wrapper">
  <div class="features-marquee-content">
    {%- for i in (1..2) -%}
      {%- for block in section.blocks -%}
        <div class="feature-item" {{ block.shopify_attributes }}>
          <div class="feature-icon-wrap">
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | img_url: '100x' }}" 
                alt="{{ block.settings.heading }}"
                width="{{ section.settings.icon_width }}"
                height="{{ section.settings.icon_height }}"
              >
            {%- elsif block.settings.icon_svg != blank -%}
              <div class="svg-wrap" style="width: {{ section.settings.icon_width }}px; height: {{ section.settings.icon_height }}px;">
                {{ block.settings.icon_svg }}
              </div>
            {%- endif -%}
          </div>
          <div class="feature-text">
            <h3 class="feature-heading">{{ block.settings.heading }}</h3>
            <p class="feature-description">{{ block.settings.description }}</p>
          </div>
        </div>
        <div class="feature-separator"></div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}

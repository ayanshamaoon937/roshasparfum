      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Icon Width",
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_height",
      "min": 10,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Icon Height",
      "default": 30
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color (for SVG)",
      "default": "#b59b61"
    },
    {
      "type": "header",
      "content": "Heading Styles"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 18
    },
    {
      "type": "select",
      "id": "heading_weight",

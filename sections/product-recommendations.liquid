{%- liquid
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign limit = section.settings.limit
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: #f2f2f4 !important;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .product-recommendations__wrapper {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .product-recommendations__header {
    text-align: center;
    margin-bottom: 50px;
  }

  .product-recommendations__subtitle {
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: {{ section.settings.text_color | opacity: 0.6 }};
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    font-weight: {{ section.settings.subtitle_font_weight | default: 500 }};
  }

  .product-recommendations__subtitle::before,
  .product-recommendations__subtitle::after {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: {{ section.settings.text_color | opacity: 0.6 }};
  }

  .product-recommendations__title {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat({{ columns_mobile }}, 1fr);
    gap: 20px;
  }

  @media screen and (min-width: 750px) {
    .product-recommendations__grid {
      grid-template-columns: repeat({{ columns_desktop }}, 1fr);
      gap: 30px;
    }
    
  }
  @media screen and (max-width: 750px) {
  .product-recommendations__title {
      font-size: 30px !important;
    }
  }

  .product-recommendations__item {
    transition: transform 0.3s ease;
  }
  
  /* Section logic to handle hidden state until API loads */
  .product-recommendations--hidden {
    visibility: hidden;
    height: 0;
    overflow: hidden;
    min-height: 1px;
  }

  .product-recommendations .product-card {
    background: transparent;
    padding-bottom: 0;
    height: 100%;
  }

  .product-recommendations .product-card__content {
    padding-top: 15px !important;
    gap: 12px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .product-recommendations .product-card__meta {
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
    flex: 1;
  }

  .product-recommendations .product-card__info-wrapper,
  .product-recommendations .product-card__atc-wrapper {
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
  }

  .product-recommendations__media {
    position: relative;
  }
  
{%- endstyle -%}

<div class="product-recommendations section-{{ section.id }}-padding product-recommendations--hidden" 
     data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}&intent=related">
  
  {%- if recommendations.performed -%}
    {%- if recommendations.products_count > 0 -%}
      <div class="product-recommendations__wrapper">
        <div class="product-recommendations__header">
          {%- if section.settings.subtitle != blank -%}
            <span class="product-recommendations__subtitle">{{ section.settings.subtitle }}</span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="product-recommendations__title">{{ section.settings.title }}</h2>
          {%- endif -%}
        </div>

        <div class="product-recommendations__grid">
          {%- for product in recommendations.products -%}
            <div class="product-recommendations__item">
              {%- capture card_children -%}
                <div class="product-recommendations__media">
                  {%- render 'card-gallery', product: product -%}
                </div>
                <product-title>
                  <a href="{{ product.url }}" class="product-card__link-title">
                    {{ product.title }}
                  </a>
                </product-title>
                <product-price>
                  {%- render 'price', product_resource: product -%}
                </product-price>
              {%- endcapture -%}
              {%- render 'product-card', product: product, children: card_children -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

<script>
  (function() {
    const sectionContainer = document.querySelector('.product-recommendations');
    if (!sectionContainer) return;

    const handleIntersection = (entries, observer) => {
      if (!entries[0].isIntersecting) return;
      observer.unobserve(sectionContainer);

      const url = sectionContainer.dataset.url;

      fetch(url)
        .then(response => response.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const content = doc.querySelector('.product-recommendations');

          if (content && content.innerHTML.trim().length > 0) {
            sectionContainer.innerHTML = content.innerHTML;
            sectionContainer.classList.remove('product-recommendations--hidden');
            
            if (window.wishlist && typeof window.wishlist.updateAllButtons === 'function') {
              window.wishlist.updateAllButtons();
            }
          }
        })
        .catch(e => {
          console.error('Recommendations Error:', e);
        });
    };

    const observer = new IntersectionObserver(handleIntersection, {rootMargin: '0px 0px 400px 0px'});
    observer.observe(sectionContainer);
  })();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "COMPLETE YOUR RITUAL"
    },
    {
      "type": "range",
      "id": "subtitle_font_weight",
      "min": 300,
      "max": 700,
      "step": 100,
      "label": "Subtitle Font Weight",
      "default": 500
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Number of products",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columns on Mobile",
      "default": 2
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}

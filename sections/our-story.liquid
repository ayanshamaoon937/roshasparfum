{%- style -%}
  #OurStory-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    #OurStory-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    #OurStory-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .our-story__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media screen and (max-width: 749px) {
    .our-story__container {
      padding: 0 16px;
    }
  }

  @media screen and (min-width: 990px) {
    .our-story__container {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }

  .our-story__image-wrapper {
    overflow: hidden;/* Optional: adds a premium feel */
  }

  .our-story__image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .our-story__image-wrapper:hover .our-story__image {
    transform: scale(1.05);
  }

  .our-story__content {
    text-align: left;
  }

  .our-story__subheading-wrapper {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
  }

  .our-story__subheading-line {
    width: 40px;
    height: 1px;
    background-color: #333333;
    display: inline-block;
  }

  .our-story__subheading {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #5e5e5e;
  }

  .our-story__heading {
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_font_weight }};
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    margin-top: 0;
    line-height: 1.2;
  }

  .our-story__description {
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_font_weight }};
    margin-bottom: {{ section.settings.desc_margin_bottom }}px;
    line-height: 1.6;
  }

  .our-story__description p {
    margin-bottom: 20px;
  }

  .our-story__description p:last-child {
    margin-bottom: 0;
  }

  /* Heading Responsive Font Sizes */
  @media screen and (max-width: 749px) {
    .our-story__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
    .our-story__description {
      font-size: {{ section.settings.desc_font_size_mobile }}px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .our-story__heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
    .our-story__description {
      font-size: {{ section.settings.desc_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .our-story__heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
    .our-story__description {
      font-size: {{ section.settings.desc_font_size_desktop }}px;
    }
  }
  .our-story__image-column {
    position: relative;
  }

  .our-story__stats-box {
    position: absolute;
    bottom: -70px;
    right: -45px;
    background: #ffffff;
    padding: 14px;
    width: 100%;
    max-width: 270px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    z-index: 2;
    border-radius: 0;
  }

  @media screen and (max-width: 749px) {
    .our-story__stats-box {
      position: relative;
      bottom: 0;
      right: 0;
      margin-top: 20px;
      max-width: 100%;
      padding: 20px;
    }
  }

  .our-story__stat-item {
    margin-bottom: 10px;
  }

  .our-story__stat-item:last-child {
    margin-bottom: 0;
  }
  
  

  .our-story__stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
.our-story__stat-item:last-child .our-story__stat-header{
    margin-bottom: 0;
  }
  .our-story__stat-bubble {
    background: #000000; /* Branded color */
    color: #ffffff;
    padding: 5px 10px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 12px;
    min-width: 55px;
    text-align: center;
  }

  .our-story__stat-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: capitalize !important;
    letter-spacing: 0.05em;
    color: #333333;
  }

  .our-story__progress-container {
    height: 6px;
    background: #f0f0f0;
    border-radius: 3px;
    overflow: hidden;
  }

  .our-story__progress-bar {
    height: 100%;
    background: #000000;
    border-radius: 3px;
    transition: width 1.5s ease-out;
  }
{%- endstyle -%}

<section id="OurStory-{{ section.id }}" class="our-story">
  <div class="our-story__container">
    <div class="our-story__image-column">
      <div class="our-story__image-wrapper">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1000 | image_tag: 
            class: 'our-story__image',
            loading: 'lazy',
            widths: '400, 600, 800, 1000'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="our-story__stats-box">
          {%- for block in section.blocks -%}
            {%- if block.type == 'progress_bar' -%}
              <div class="our-story__stat-item" {{ block.shopify_attributes }}>
                <div class="our-story__stat-header">
                  <div class="our-story__stat-bubble">
                    {{ block.settings.percentage }}%
                  </div>
                  <div class="our-story__stat-label">
                    {{ block.settings.label | downcase }}
                  </div>
                </div>
                <div class="our-story__progress-container">
                  <div class="our-story__progress-bar" style="width: {{ block.settings.percentage }}%;"></div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          {%- if section.settings.experience_label != blank -%}
            <div class="our-story__stat-item"our-story__stat-header>
              <div class="our-story__stat-header">
                <div class="our-story__stat-bubble">
                  {{ section.settings.experience_value }}
                </div>
                <div class="our-story__stat-label">
                  {{ section.settings.experience_label | downcase }}
                </div>
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
    
    <div class="our-story__content-column">
      <div class="our-story__content">
        {%- if section.settings.subheading != blank -%}
          <div class="our-story__subheading-wrapper">
            <span class="our-story__subheading-line"></span>
            <span class="our-story__subheading">{{ section.settings.subheading }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="our-story__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="our-story__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>


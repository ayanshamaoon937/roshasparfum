{%- liquid
  assign columns_desktop = section.settings.columns_desktop | default: 4
  assign columns_mobile = section.settings.columns_mobile | default: 1
  assign gap_desktop = section.settings.gap_desktop | default: 20
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background: {{ section.settings.bg_color | default: '#ffffff' }};
  }

  .brand-grid-wrapper {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .brand-group {
    margin-bottom: var(--group-margin-mobile, 20px);
  }

  @media screen and (min-width: 750px) {
    .brand-group {
      margin-bottom: var(--group-margin, 60px);
    }
  }

  .alphabet-header {
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.alphabet_header_font_size }}px;
    font-weight: 500;
    margin-bottom: {{ section.settings.alphabet_header_margin_bottom }}px;
    color: {{ section.settings.alphabet_header_color }};
    {% if section.settings.show_alphabet_border %}
    padding-bottom: 15px;
    border-bottom: 1px solid {{ section.settings.border_color }};
    {% endif %}
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat({{ columns_desktop }}, 1fr);
    gap: {{ gap_desktop }}px;
  }

  .brand-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    border: 1px solid {{ section.settings.border_color | default: '#f0f0f0' }};
    background: #fff;
    text-decoration: none !important;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    height: 100%;
    position: relative;
    text-align: center;
    box-sizing: border-box;
    opacity: 1;
    @media (max-width: 768px) {
      padding:10px;
    }
  }

  .brand-logo-wrap {
    margin-bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 120px;
    width: 100%;
  }

  .brand-logo-wrap img {
    max-width: {{ section.settings.logo_max_width | default: 120 }}px;
    height: auto;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .brand-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }

  .brand-location {
    font-size: 10px;
    font-weight: 600;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1;
  }

  .brand-name {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.2;
  }

  .brand-description {
    font-size: 9px;
    font-weight: 400;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.4;
    max-width: 180px;
  }

  .brand-card:hover {
    border-color: #000000;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    z-index: 10;
  }

  .brand-card:hover .brand-logo-wrap img {
    transform: scale(1.05);
  }


  .brands-header {
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
    display: flex;
    justify-content: center;
    text-align: center;
    width: 100%;
  }

  .brands-header-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
  }

  .brands-subtitle {
    display: flex;
    align-items: center;
    gap: 15px;
    color: {{ section.settings.header_subtitle_color | default: '#5e5e5e' }};
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .brands-subtitle .line {
    width: 30px;
    height: 1px;
    background: {{ section.settings.header_subtitle_color | default: '#5e5e5e' }};
  }

  .brands-main-title {
    font-family: 'Playfair Display', serif;
    font-size: {{ section.settings.title_font_size | default: 64 }}px;
    color: {{ section.settings.header_title_color | default: '#1a1a1a' }};
    margin: 0 0 25px 0;
    line-height: 1.1;
    font-weight: 500;
  }

  .brands-main-desc {
    font-family: 'Jost', sans-serif;
    font-size: {{ section.settings.desc_font_size | default: 18 }}px;
    color: {{ section.settings.header_desc_color | default: '#666666' }};
    max-width: 650px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .brands-main-title { font-size: calc({{ section.settings.title_font_size | default: 64 }}px * 0.7); }
    .brands-main-desc { font-size: calc({{ section.settings.desc_font_size | default: 18 }}px * 0.9); }
    .brands-header { margin-bottom: 50px; }
  }

  @media screen and (max-width: 989px) {
    .brand-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 2 }}, 1fr);
    }
    .brand-grid-wrapper {
      padding: 0 16px;
    }
    .alphabet-header {
      font-size: calc({{ section.settings.alphabet_header_font_size }}px * 0.75);
    }
  }

  @media screen and (max-width: 749px) {
    .brand-grid {
      grid-template-columns: repeat({{ columns_mobile }}, 1fr);
    }
    .section-{{ section.id }}-padding {
       padding-top: {{ section.settings.padding_top_mobile }}px;
       padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

<main class="brands-main section-{{ section.id }}-padding">
  <div class="brand-grid-wrapper">
    
    <div class="brands-header">
      <div class="brands-header-content">
        {%- if section.settings.subtitle != blank -%}
          <div class="brands-subtitle">
            <span class="line"></span>
            {{ section.settings.subtitle }}
            <span class="line"></span>
          </div>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h1 class="brands-main-title">{{ section.settings.title }}</h1>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="brands-main-desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    </div>
    {%- assign in_grid = false -%}
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          {%- if in_grid -%}
            </div></div> <!-- Close previous grid and group wrapper -->
          {%- endif -%}
          
          <div class="brand-group" 
               {{ block.shopify_attributes }}
               style="--group-margin: {{ block.settings.margin_bottom | default: section.settings.alphabet_group_margin_bottom }}px; --group-margin-mobile: {{ block.settings.margin_bottom_mobile | default: section.settings.alphabet_group_margin_bottom_mobile | default: 20 }}px;"
          >
            <h2 class="alphabet-header">{{ block.settings.title }}</h2>
            <div class="brand-grid">
            {%- assign in_grid = true -%}
            
        {%- when 'brand' -%}
          {%- if in_grid == false -%}
            {%- comment -%} Open a default grid if brands are added before a heading {%- endcomment -%}
            <div class="brand-group">
              <div class="brand-grid">
              {%- assign in_grid = true -%}
          {%- endif -%}
          
          <div class="brand-card-item" {{ block.shopify_attributes }}>
            {%- render 'brand-card-item', block: block, section: section -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
    
    {%- if in_grid -%}
      </div></div> <!-- Final closing -->
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <div class="brand-empty-state" style="text-align: center; padding: 40px;">
        <p>Add a <strong>Heading</strong> block to start a group, then add <strong>Brand Card</strong> blocks below it.</p>
      </div>
    {%- endif -%}
  </div>
</main>


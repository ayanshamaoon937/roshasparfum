{% style %}
  .testimonials-section {
    background-color: #ffffff;
    background-image: radial-gradient(#d1d1d1 1px, transparent 1px);
    background-size: 30px 30px;
    padding: 100px 0;
    overflow: hidden;
    font-family: 'Jost', sans-serif;
  }

  .testimonials-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .testimonials-subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #b59b61;
    margin-bottom: 20px;
  }

  .testimonials-subtitle::before,
  .testimonials-subtitle::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background-color: #b59b61;
    opacity: 0.5;
  }

  .testimonials-title {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    color: #1a1a1a;
    margin: 0;
    font-weight: 400;
  }

  /* Judge.me Overrides to match the design */
  .jdgm-carousel-wrapper {
    background: transparent !important;
    padding: 0 !important;
  }

  .jdgm-carousel-title {
    display: none !important; /* We use our own title */
  }

  .jdgm-carousel {
    margin: 0 !important;
  }

  .jdgm-carousel-item {
    background: #fff !important;
    border: 1px solid #eeeeee !important;
    padding: 60px 40px 40px !important;
    margin: 0 15px !important;
    transition: all 0.3s ease !important;
    display: flex !important;
    flex-direction: column !important;
    min-height: 400px !important;
  }

  .jdgm-carousel-item:hover {
    border-color: #b59b61 !important;
  }

  /* Add quotation mark via pseudo-element for Judge.me */
  .jdgm-carousel-item::before {
    content: '“';
    position: absolute;
    top: 30px;
    left: 40px;
    color: #fcefdc;
    font-family: serif;
    font-size: 80px;
    line-height: 1;
    pointer-events: none;
  }

  .jdgm-carousel-item__review-rating {
    margin-bottom: 25px !important;
    color: #b59b61 !important;
  }

  .jdgm-carousel-item__review-body {
    font-family: 'Playfair Display', serif !important;
    font-style: italic !important;
    font-size: 18px !important;
    line-height: 1.8 !important;
    color: #444 !important;
    margin-bottom: 40px !important;
    flex-grow: 1 !important;
    border: none !important;
    padding: 0 !important;
  }

  .jdgm-carousel-item__reviewer-name {
    font-family: 'Jost', sans-serif !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 1.5px !important;
    color: #1a1a1a !important;
    display: block !important;
  }

  .jdgm-carousel-item__reviewer-avatar {
    width: 50px !important;
    height: 50px !important;
    border-radius: 50% !important;
    background-color: #f2e1bb !important;
    margin-right: 15px !important;
  }

  .jdgm-carousel__left-arrow, 
  .jdgm-carousel__right-arrow {
    width: 44px !important;
    height: 44px !important;
    border-radius: 50% !important;
    border: 1px solid #eeeeee !important;
    background: #fff !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    color: #1a1a1a !important;
  }

  .jdgm-carousel__left-arrow:hover, 
  .jdgm-carousel__right-arrow:hover {
    background: #1a1a1a !important;
    color: #fff !important;
    border-color: #1a1a1a !important;
  }

  /* Manual Block Stylings (Fallback) */
  .testimonials-slider {
    position: relative;
    display: flex;
    gap: 30px;
    transition: transform 0.5s ease;
  }

  .testimonial-card {
    background: #fff;
    border: 1px solid #eeeeee;
    padding: 60px 40px 40px;
    flex: 0 0 calc(33.333% - 20px);
    display: flex;
    flex-direction: column;
    min-height: 400px;
    position: relative;
    transition: all 0.3s ease;
  }

  .testimonial-card.is-featured {
    border-color: #b59b61;
  }

  .testimonial-quote-icon {
    position: absolute;
    top: 30px;
    left: 40px;
    color: #fcefdc;
    font-family: serif;
    font-size: 80px;
    line-height: 1;
    pointer-events: none;
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
    margin-top: 20px;
    margin-bottom: 20px;
    color: #FFD700;
  }

  .testimonial-stars svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .testimonial-content {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 18px;
    line-height: 1.8;
    color: #444;
    margin-bottom: 40px;
    flex-grow: 1;
  }

  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .testimonial-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: #f2e1bb;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonial-info {
    display: flex;
    flex-direction: column;
  }

  .testimonial-author {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #1a1a1a;
  }

  .testimonial-location {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #888;
    margin-top: 4px;
  }

  @media (max-width: 1024px) {
    .testimonial-card, .jdgm-carousel-item {
      flex: 0 0 calc(50% - 15px);
    }
  }

  @media (max-width: 768px) {
    .testimonial-card, .jdgm-carousel-item {
      flex: 0 0 100%;
    }
  }
{% endstyle %}

<section class="testimonials-section section-id-{{ section.id }}">
  <div class="testimonials-container">
    <div class="testimonials-header">
      <div class="testimonials-subtitle">{{ section.settings.subtitle }}</div>
      <h2 class="testimonials-title">{{ section.settings.title }}</h2>
    </div>

    <div class="testimonials-wrapper">
      {% if section.blocks.size > 0 %}
        <div class="testimonials-slider" id="TestimonialSlider-{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'testimonial' %}
              <div class="testimonial-card {% if block.settings.is_featured %}is-featured{% endif %}" {{ block.shopify_attributes }}>
                <span class="testimonial-quote-icon">“</span>
                <div class="testimonial-stars">
                  {% for i in (1..5) %}
                    <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                  {% endfor %}
                </div>
                <div class="testimonial-content">{{ block.settings.content }}</div>
                <div class="testimonial-footer">
                  <div class="testimonial-avatar">
                    {% if block.settings.avatar != blank %}<img src="{{ block.settings.avatar | img_url: '100x100' }}" alt="{{ block.settings.author }}">{% endif %}
                  </div>
                  <div class="testimonial-info">
                    <span class="testimonial-author">{{ block.settings.author }}</span>
                    <span class="testimonial-location">{{ block.settings.location }}</span>
                  </div>
                </div>
              </div>
            {% elsif block.type == 'judgeme' %}
              <div class="judgeme-wrapper" {{ block.shopify_attributes }}>
                {{ block.settings.widget_code }}
              </div>
            {% elsif block.type == '@app' %}
              {% render block %}
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <!-- Default App Block support if no blocks added -->
        <div class="judgeme-default-wrapper">
          <div class='jdgm-carousel-wrapper'>
            {%- render 'judgeme_widgets', widget_type: 'judgeme_review_carousel', concierge_install: false -%}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "TESTIMONIALS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What Our Clients Say"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "testimonial",
      "name": "Testimonial (Manual)",
      "settings": [
        {
          "type": "checkbox",
          "id": "is_featured",
          "label": "Highlight Card (Gold Border)",
          "default": false
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Testimonial Content",
          "default": "<p>\"Finally found a trustworthy store for luxury fragrances in the region. Express delivery was fast and the Dior Sauvage smells exactly like the one I tested in-store.\"</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Mohammad K."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Author Location",
          "default": "DUBAI"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author Avatar"
        }
      ]
    },
    {
      "type": "judgeme",
      "name": "Judge.me Widget Code",
      "settings": [
        {
          "type": "html",
          "id": "widget_code",
          "label": "HTML code",
          "default": "<div class='jdgm-carousel-wrapper'></div>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial", "settings": { "is_featured": true } },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}

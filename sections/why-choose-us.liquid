{%- style -%}
  #WhyChooseUs-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    #WhyChooseUs-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    #WhyChooseUs-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .why-choose-us__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media screen and (min-width: 990px) {
    .why-choose-us__container {
      flex-direction: row;
      align-items: center;
      gap: 60px;
    }
  }

  .why-choose-us__content {
    flex: 1;
    text-align: left;
  }

  .why-choose-us__images {
    flex: 1.2;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  @media screen and (max-width: 749px) {
    .why-choose-us__images {
      flex-direction: column;
    }
  }

  .why-choose-us__subheading {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 15px;
    font-size: 14px;
    font-weight: {{ section.settings.subtitle_font_weight | default: 500 }};
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #5e5e5e;
  }

  .why-choose-us__subheading::before,
  .why-choose-us__subheading::after {
    content: '';
    display: inline-block;
    width: 40px;
    height: 1px;
    background-color: #333333;
  }

  .why-choose-us__heading {
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_font_weight }};
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    margin-top: 0;
    line-height: 1.2;
  }

  .why-choose-us__description {
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_font_weight }};
    margin-bottom: {{ section.settings.desc_margin_bottom }}px;
    line-height: 1.6;
  }

  .why-choose-us__button-wrapper {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .why-choose-us__button {
    display: inline-block;
    padding: 15px 40px;
    background-color: #000000;
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid #000000;
    border-radius: 0; /* Sharp edges */
    transition: all 0.3s ease;
  }

  .why-choose-us__button:hover {
    background-color: transparent;
    color: #000000;
  }

  .why-choose-us__play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background: #000;
    color: #fff;
    border-radius: 50%;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .why-choose-us__play-btn:hover {
    transform: scale(1.1);
  }

  .why-choose-us__image-wrapper {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .why-choose-us__image-wrapper.image-1 {
    margin-top: 40px; /* Offset to match the asymmetric design */
  }

  .why-choose-us__image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .why-choose-us__image-wrapper:hover .why-choose-us__image {
    transform: scale(1.05);
  }

  /* Responsive Font Sizes */
  @media screen and (max-width: 749px) {
    .why-choose-us__heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
    .why-choose-us__description {
      font-size: {{ section.settings.desc_font_size_mobile }}px;
    }
    .why-choose-us__image-wrapper.image-1 {
      margin-top: 0;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .why-choose-us__heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
    .why-choose-us__description {
      font-size: {{ section.settings.desc_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .why-choose-us__heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
    .why-choose-us__description {
      font-size: {{ section.settings.desc_font_size_desktop }}px;
    }
  }
{%- endstyle -%}

<section id="WhyChooseUs-{{ section.id }}" class="why-choose-us">
  <div class="why-choose-us__container">
    <div class="why-choose-us__content">
      {%- if section.settings.subheading != blank -%}
        <div class="why-choose-us__subheading">
          {{ section.settings.subheading }}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="why-choose-us__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="why-choose-us__description rte">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      <div class="why-choose-us__button-wrapper">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="why-choose-us__button">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        
        {%- if section.settings.video_link != blank -%}
          <a href="{{ section.settings.video_link }}" class="why-choose-us__play-btn">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="why-choose-us__images">
      <div class="why-choose-us__image-wrapper image-1">
        {%- if section.settings.image_1 != blank -%}
          {{ section.settings.image_1 | image_url: width: 800 | image_tag: 
            class: 'why-choose-us__image',
            loading: 'lazy'
          }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="why-choose-us__image-wrapper image-2">
        {%- if section.settings.image_2 != blank -%}
          {{ section.settings.image_2 | image_url: width: 800 | image_tag: 
            class: 'why-choose-us__image',
            loading: 'lazy'
          }}
        {%- else -%}
          {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>


            "custom_liquid_xy6fDc": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{% comment %}\nSocial icons — Facebook / Instagram / Pinterest\nروابط Roshas Perfume (نهائي)\n{% endcomment %}\n\n<style>\n  .onhow-social-container{display:flex;justify-content:center;align-items:center;gap:2rem;padding:2rem 0;flex-wrap:wrap;max-width:100%}\n  .onhow-social-icon{display:inline-flex;align-items:center;justify-content:center;width:3.5rem;height:3.5rem;border-radius:50%;background:linear-gradient(135deg,rgba(255,255,255,.1) 0%,rgba(255,255,255,.05) 100%);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.2);color:#000;text-decoration:none;position:relative;overflow:hidden;transition:all .4s cubic-bezier(.175,.885,.32,1.275);transform:translateY(0);box-shadow:0 4px 15px rgba(0,0,0,.1)}\n  .onhow-social-icon:hover{transform:translateY(-8px) scale(1.1);box-shadow:0 12px 35px rgba(0,0,0,.2);border-color:rgba(255,255,255,.4)}\n  .onhow-social-icon::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,.4) 50%,transparent 100%);transition:left .6s ease}\n  .onhow-social-icon:hover::before{left:100%}\n  .onhow-social-icon svg{width:1.5rem;height:1.5rem;transition:all .3s ease;position:relative;z-index:2}\n  .onhow-social-icon:hover svg{transform:scale(1.2)}\n\n  .onhow-facebook:hover{background:linear-gradient(135deg,#1877f2 0%,#42a5f5 100%);color:#fff}\n  .onhow-instagram:hover{background:linear-gradient(135deg,#e1306c 0%,#f56040 50%,#fcaf45 100%);color:#fff}\n  .onhow-pinterest:hover{background:linear-gradient(135deg,#e60023 0%,#b3001b 100%);color:#fff}\n\n  @media (max-width:749px){.onhow-social-container{gap:1.5rem;padding:1.5rem 0}.onhow-social-icon{width:3rem;height:3rem}.onhow-social-icon svg{width:1.25rem;height:1.25rem}}\n  @media (max-width:550px){.onhow-social-container{gap:1rem}.onhow-social-icon{width:2.75rem;height:2.75rem}}\n</style>\n\n<div class=\"onhow-social-container\">\n  {%- assign facebook_url  = 'https://web.facebook.com/profile.php?id=61553709003627' -%}\n  {%- assign instagram_url = 'https://www.instagram.com/roshas_perfume/' -%}\n  {%- assign pinterest_url = 'https://www.pinterest.com/RoshasPerfume/' -%}\n\n  {%- if facebook_url != blank -%}\n    <a href=\"{{ facebook_url }}\" class=\"onhow-social-icon onhow-facebook\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Visit our Facebook page\">\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" fill=\"currentColor\">\n        <path d=\"M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z\"/>\n      </svg>\n    </a>\n  {%- endif -%}\n\n  {%- if instagram_url != blank -%}\n    <a href=\"{{ instagram_url }}\" class=\"onhow-social-icon onhow-instagram\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Visit our Instagram page\">\n      <!-- لماذا outline: لضبط الشكل كما طلبت والتلوّن تلقائياً -->\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"5\" ry=\"5\"/>\n        <circle cx=\"12\" cy=\"12\" r=\"4\"/>\n        <circle cx=\"17.5\" cy=\"6.5\" r=\"1.2\"/>\n      </svg>\n    </a>\n  {%- endif -%}\n\n  {%- if pinterest_url != blank -%}\n    <a href=\"{{ pinterest_url }}\" class=\"onhow-social-icon onhow-pinterest\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Visit our Pinterest page\">\n      <!-- Pinterest circle \"P\" -->\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" fill=\"currentColor\">\n        <path d=\"M12 0C5.373 0 0 5.373 0 12c0 4.991 3.657 9.128 8.438 10.125-.117-.86-.217-2.187.05-3.141.24-.86 1.604-5.77 1.604-5.77s-.41-.83-.41-2.055c0-1.93 1.12-3.37 2.51-3.37 1.18 0 1.75.885 1.75 1.945 0 1.185-.755 2.958-1.145 4.596-.33 1.406.703 2.55 2.09 2.55 2.507 0 4.207-2.645 4.207-6.201 0-3.24-2.327-5.506-5.648-5.506-3.85 0-6.11 2.888-6.11 5.876 0 1.16.45 2.404 1.01 3.08.11.13.12.24.09.37-.1.41-.33 1.31-.38 1.5-.06.24-.19.29-.44.18-1.65-.77-2.68-3.11-2.68-5.01 0-4.07 2.96-7.82 8.56-7.82 4.55 0 7.86 3.26 7.86 7.63 0 4.9-3.08 8.85-7.37 8.85-1.44 0-2.79-.75-3.25-1.63 0 0-.78 2.97-.97 3.7-.29 1.09-1.07 2.41-1.59 3.23C10.71 23.84 11.35 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z\"/>\n      </svg>\n    </a>\n  {%- endif -%}\n</div>"

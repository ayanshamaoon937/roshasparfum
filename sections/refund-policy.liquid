{%- style -%}
  #RefundPolicySection-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .refund-policy__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media screen and (max-width: 749px) {
    #RefundPolicySection-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .refund-policy__container {
      padding-left: {{ section.settings.container_padding_mobile }}px;
      padding-right: {{ section.settings.container_padding_mobile }}px;
    }
  }

  .refund-policy__main-heading {
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_font_weight }};
    margin-bottom: {{ section.settings.heading_margin_bottom }}px;
    line-height: 1.2;
    text-align: {{ section.settings.text_alignment }};
    margin-top: 0;
  }

  .refund-policy__main-description {
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_font_weight }};
    margin-bottom: {{ section.settings.desc_margin_bottom }}px;
    line-height: 1.6;
    text-align: {{ section.settings.text_alignment }};
  }

  /* Desktop Font Sizes */
  @media screen and (min-width: 990px) {
    .refund-policy__main-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
    .refund-policy__main-description {
      font-size: {{ section.settings.desc_font_size_desktop }}px;
    }
  }

  /* Tablet Font Sizes */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .refund-policy__main-heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
    .refund-policy__main-description {
      font-size: {{ section.settings.desc_font_size_tablet }}px;
    }
  }

  /* Mobile Font Sizes & Spacing */
  @media screen and (max-width: 749px) {
    .refund-policy__main-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
    .refund-policy__main-description {
      font-size: {{ section.settings.desc_font_size_mobile }}px;
      margin-bottom: {{ section.settings.desc_margin_bottom_mobile }}px;
    }
  }

  .refund-policy__blocks {
    margin-top: {{ section.settings.grid_margin_top }}px;
  }

  .refund-policy__block {
    break-inside: avoid;
    margin-bottom: {{ section.settings.grid_gap }}px;
    display: block;
    width: 100%;
  }

  /* Desktop Masonry/Multi-column */
  @media screen and (min-width: 990px) {
    .refund-policy__blocks {
      column-count: 2;
      column-gap: {{ section.settings.grid_gap }}px;
    }
  }

  {%- for block in section.blocks -%}
    .refund-policy__block-{{ block.id }} {
      {% if block.settings.start_new_column %}
        break-before: column;
      {% endif %}
    }

    .refund-policy__block-{{ block.id }} .refund-policy__block-heading {
      font-size: {{ block.settings.heading_font_size }}px;
      color: {{ block.settings.heading_color }};
      margin-bottom: {{ block.settings.heading_margin_bottom }}px;
      font-weight: {{ block.settings.heading_font_weight }};
      line-height: 1.3;
    }

    .refund-policy__block-{{ block.id }} .refund-policy__block-content {
      font-size: {{ block.settings.content_font_size }}px;
      color: {{ block.settings.content_color }};
      font-weight: {{ block.settings.content_font_weight }};
      line-height: 1.6;
    }
  {%- endfor -%}

  .refund-policy__footer-contact {
    text-align: {{ section.settings.text_alignment }};
    margin-top: {{ section.settings.footer_margin_top }}px;
  }

  .refund-policy__footer-heading {
    color: {{ section.settings.heading_color }};
    font-weight: {{ section.settings.heading_font_weight }};
    margin-bottom: 20px;
    line-height: 1.2;
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 749px) {
    .refund-policy__footer-contact {
      margin-top: {{ section.settings.footer_margin_top_mobile }}px;
    }
  }

  .refund-policy__footer-content {
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_font_weight }};
    font-size: {{ section.settings.desc_font_size_desktop }}px;
    line-height: 1.6;
  }

  .refund-policy__main-description a,
  .refund-policy__block-content a,
  .refund-policy__footer-content a {
    text-decoration: underline !important;
    text-decoration-color: #4a4a4a !important;
    transition: opacity 0.3s ease;
  }

  .refund-policy__main-description a:hover,
  .refund-policy__block-content a:hover,
  .refund-policy__footer-content a:hover {
    opacity: 0.8;
    text-decoration: underline !important;
    text-decoration-color: #4a4a4a !important;
  }

  /* Footer Heading Responsive Sizes */
  @media screen and (max-width: 749px) {
    .refund-policy__footer-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .refund-policy__footer-heading {
      font-size: {{ section.settings.heading_font_size_tablet }}px;
    }
  }
  @media screen and (min-width: 990px) {
    .refund-policy__footer-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }
{%- endstyle -%}

<section id="RefundPolicySection-{{ section.id }}" class="refund-policy">
  <div class="refund-policy__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="refund-policy__main-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="refund-policy__main-description rte">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    <div class="refund-policy__blocks">
      {%- for block in section.blocks -%}
        <div class="refund-policy__block refund-policy__block-{{ block.id }}" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="refund-policy__block-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          
          {%- if block.settings.content != blank -%}
            <div class="refund-policy__block-content rte">
              {{ block.settings.content }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_contact_heading != blank or section.settings.footer_contact_content != blank -%}
      <div class="refund-policy__footer-contact">
        {%- if section.settings.footer_contact_heading != blank -%}
          <h3 class="refund-policy__footer-heading">{{ section.settings.footer_contact_heading }}</h3>
        {%- endif -%}
        {%- if section.settings.footer_contact_content != blank -%}
          <div class="refund-policy__footer-content rte">
            {{ section.settings.footer_contact_content }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>


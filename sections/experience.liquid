{%- liquid
  assign s = section.settings
-%}

<section class="experience experience-{{ section.id }}" aria-label="{{ s.heading | escape }}">
  <div class="experience__container">
    <header class="experience__header">
      {%- if s.subheading != blank -%}
        <div class="experience__subheading">{{ s.subheading }}</div>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <h2 class="experience__heading">{{ s.heading }}</h2>
      {%- endif -%}
    </header>

    <div class="experience__grid">
      {%- for block in section.blocks -%}
        {%- if block.type != 'card' -%}{%- continue -%}{%- endif -%}
        {%- assign b = block.settings -%}

        <article class="experience-card" {{ block.shopify_attributes }}>
          {%- if b.svg_icon != blank -%}
            <div class="experience-card__icon" aria-hidden="true">
              {{ b.svg_icon }}
            </div>
          {%- endif -%}

          {%- if b.card_heading != blank -%}
            <h3 class="experience-card__heading">{{ b.card_heading }}</h3>
          {%- endif -%}

          {%- if b.card_subheading != blank -%}
            <div class="experience-card__description">{{ b.card_subheading }}</div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% style %}
  .experience-{{ section.id }} {
    background-color: {{ s.background_color }};
    padding-top: {{ s.padding_top_mobile }}px;
    padding-bottom: {{ s.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .experience-{{ section.id }} {
      padding-top: {{ s.padding_top_tablet }}px;
      padding-bottom: {{ s.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .experience-{{ section.id }} {
      padding-top: {{ s.padding_top_desktop }}px;
      padding-bottom: {{ s.padding_bottom_desktop }}px;
    }
  }

  .experience-{{ section.id }} .experience__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  @media screen and (max-width: 768px) {
    .experience-{{ section.id }} .experience__container {
      padding: 0 20px;
    }
  }

  .experience-{{ section.id }} .experience__header {
    text-align: center;
    margin-bottom: {{ s.header_spacing }}px;
  }

  .experience-{{ section.id }} .experience__subheading {
    font-family: var(--font-body--family), sans-serif;
    font-size: {{ s.subheading_font_size }}px;
    letter-spacing: {{ s.subheading_letter_spacing }}px;
    text-transform: uppercase;
    color: {{ s.subheading_color }};
    margin-bottom: {{ s.subheading_margin_bottom }}px;
  }

  .experience-{{ section.id }} .experience__heading {
    font-family: var(--font-heading--family), serif;
    font-size: {{ s.heading_font_size_mobile }}px;
    line-height: 1.2;
    color: {{ s.heading_color }};
    margin: 0;
    font-weight: 500;
  }

  @media screen and (min-width: 750px) {
    .experience-{{ section.id }} .experience__heading {
      font-size: {{ s.heading_font_size_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .experience-{{ section.id }} .experience__heading {
      font-size: {{ s.heading_font_size_desktop }}px;
    }
  }

  .experience-{{ section.id }} .experience__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ s.card_gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .experience-{{ section.id }} .experience__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: {{ s.card_gap_tablet }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .experience-{{ section.id }} .experience__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: {{ s.card_gap_desktop }}px;
    }
  }

  .experience-{{ section.id }} .experience-card {
    text-align: center;
    padding: {{ s.card_padding_y }}px {{ s.card_padding_x }}px;
  }

  .experience-{{ section.id }} .experience-card__icon {
    width: {{ s.icon_size }}px;
    height: {{ s.icon_size }}px;
    margin: 0 auto {{ s.icon_margin_bottom }}px;
    color: {{ s.icon_color }};
    border-radius:50%;
    background-color:rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .experience-{{ section.id }} .experience-card__icon svg {
    width: 30px;
    height: 30px;
    display: block;
  }

  .experience-{{ section.id }} .experience-card__heading {
    font-family: var(--font-body--family), sans-serif;
    font-size: {{ s.card_heading_font_size }}px;
    color: {{ s.card_heading_color }};
    margin: 0 0 {{ s.card_heading_margin_bottom }}px;
    font-weight: 600;
  }

  .experience-{{ section.id }} .experience-card__description {
    font-family: var(--font-body--family), sans-serif;
    font-size: {{ s.card_description_font_size }}px;
    color: {{ s.card_description_color }};
    line-height: 1.7;
    margin: 0;
  }

  /* Subtitle with lines (like "MOST WANTED") */
  .experience-{{ section.id }} .experience__subheading {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
  }
  .experience-{{ section.id }} .experience__subheading{
    font-weight: 500;
  }

  .experience-{{ section.id }} .experience__subheading::before,
  .experience-{{ section.id }} .experience__subheading::after {
    content: '';
    display: inline-block;
    width: {{ s.subheading_line_width }}px;
    height: 1px;
    background: currentColor;
    opacity: {{ s.subheading_line_opacity | divided_by: 100.0 }};
  }
{% endstyle %}


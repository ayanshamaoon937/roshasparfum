

{%- assign block_settings = block.settings -%}

{% capture title %}
  {% content_for 'block', id: 'heading', type: '_heading', text: article.title %}
{% endcapture %}

{% capture details %}
  {% content_for 'block',
    id: 'blog-post-details',
    type: '_blog-post-info-text',
    alignment: block_settings.alignment,
    article: article
  %}
{% endcapture %}

{% capture description %}
  {% content_for 'block', id: 'content', type: '_blog-post-description', article: article, show_read_more: true %}
{% endcapture %}

<div
  class="blog-post-card"
  style="--text-align: {{ block_settings.alignment }}"
>
  {%- if article.image -%}
    <div class="blog-post-card__image-container">
      <a href="{{ article.url }}">
        {% content_for 'block', id: 'image', type: '_blog-post-image', image: article.image %}
      </a>
    </div>
  {%- endif -%}

  <div class="blog-post-card__content">
    <div class="blog-post-card__info">
      <a href="{{ article.url }}" class="blog-post-card__title-link">{{ title }}</a>
      {{ details }}
      {{ description }}
    </div>
    
    <a href="{{ article.url }}" class="blog-post-card__read-more">Read More</a>
  </div>
</div>

{%- style -%}
  .blog-post-card {
    display: flex;
    flex-direction: row;
    text-align: var(--text-align);
    background-color: var(--card-bg-color, #ffffff);
    padding: 0;
    margin: 0;
    overflow: hidden;
    border: none;
    border-radius: 0;

    @media screen and (max-width: 749px) {
      flex-direction: column;
    }
  }

  .blog-post-card__image-container {
    width: 40%;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;

    @media screen and (max-width: 749px) {
      width: 100%;
    }
  }

  .blog-post-card__image-container a, 
  .blog-post-card__image-container .shopify-block {
    display: block;
    height: 100%;
    width: 100%;
  }

  .blog-post-card__image-container img {
    width: 100%;
    height: 100% !important;
    object-fit: cover;
    display: block;
    border-radius: 0 !important;
  }

  .blog-post-card__content {
    width: 60%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px;

    @media screen and (max-width: 989px) {
      padding: 25px;
    }

    @media screen and (max-width: 749px) {
      width: 100%;
      padding: 20px;
    }
  }

  .blog-post-card__info {
    display: flex;
    flex-direction: column;
  }

  .blog-post-card__content a {
    text-decoration: none;
    color: inherit;
  }

  .blog-post-card__content h1,
  .blog-post-card__content h2, 
  .blog-post-card__content h3, 
  .blog-post-card__content h4,
  .blog-post-card__title-link * {
    margin-top: 0;
    margin-bottom: 5px;
    line-height: 1.4 !important;
    font-weight: 500;
  }
 

  /* Force underline on hover by overriding theme's default transparent decoration on headings */
  .blog-post-card:hover h1,
  .blog-post-card:hover h2, 
  .blog-post-card:hover h3, 
  .blog-post-card:hover h4,
  .blog-post-card:hover .blog-post-card__title-link {
    text-decoration: underline !important;
    text-decoration-color: currentColor !important;
    text-underline-offset: 5px;
  }

  .blog-post-card__read-more {
    display: inline-block;
    padding: 12px 20px;
    background-color: #000000;
    color: #ffffff !important;
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    text-transform: capitalize;
    letter-spacing: 0.1em;
    border: 1px solid #000000;
    transition: all 0.3s ease;
    width: fit-content;
    margin-top: 15px;
  }

  .blog-post-card__read-more:hover {
    background-color: transparent;
    color: #000000 !important;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "t:names.blog_post",
  "settings": [
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    }
  ]
}
{% endschema %}

<div class="cart__summary-totals">
  {% # Keep this node for morphing # %}
  <div class="cart__original-total-container cart-primary-typography">
    {%- if cart.cart_level_discount_applications.size > 0 -%}
      {%- for discount in cart.cart_level_discount_applications -%}
        <div class="cart__summary-item cart__discount">
          <span class="cart__discount-label">Discount ({{ discount.title }})</span>
          <span class="cart__discount-value">-{{ discount.total_allocated_amount | money }}</span>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="cart-discount-toggle">
    {% render 'cart-discount', section_id: section.id %}
  </div>

  {%- liquid
    if settings.currency_code_enabled_cart_total
      assign total_price = cart.total_price | money_with_currency
    else
      assign total_price = cart.total_price | money
    endif
  -%}

  <div class="cart-footer__totals">
    <div class="cart-footer__total-row">
      <span class="cart-footer__total-label">ESTIMATED TOTAL</span>
      <span class="cart-footer__total-value" ref="cartTotal">{{ total_price }}</span>
    </div>
    
    <p class="cart-footer__tax-note">
      DUTIES AND TAXES INCLUDED. SHIPPING IS CALCULATED AT CHECKOUT.
    </p>

    <div class="cart-footer__actions">
      <button
        type="submit"
        id="checkout"
        class="cart-footer__checkout-button button"
        name="checkout"
        {% if cart == empty %}
          disabled
        {% endif %}
        form="cart-form"
      >
        <span class="checkout-text">Check Out</span>
        <span class="checkout-price">{{ total_price }}</span>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
  .cart-footer__totals {
    border-top: 1px solid #f0f0f0;
    padding-top: 30px;
    margin-top: 20px;
  }

  .cart-footer__total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .cart-footer__total-label {
    font-size: 14px;
    letter-spacing: 0.5px;
    color: #333;
    font-weight: 500;
  }

  .cart-footer__total-value {
    font-size: 18px;
    color: #000;
    font-weight: 500;
  }

  .cart-footer__tax-note {
    font-size: 11px;
    color: #999;
    line-height: 1.6;
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .cart-footer__checkout-button {
    background: #000 !important;
    color: #fff !important;
    width: 100%;
    height: 64px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 20px !important;
    border-radius: 0 !important;
    font-size: 18px;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .cart-footer__checkout-button:hover {
    opacity: 0.9;
  }

  .cart-footer__checkout-button:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .cart-discount-toggle {
    margin-bottom: 25px;
  }

  /* Override disclosure trigger if needed */
  .cart-discount .disclosure-trigger {
    border-bottom: 1px solid #f0f0f0;
    padding: 15px 0;
    justify-content: space-between;
    color: #333;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-radius: 0 !important;
  }
{% endstylesheet %}

{% assign block_settings = block.settings %}

<script
  src="{{ 'component-cart-items.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
<script
  src="{{ 'component-cart-quantity-selector.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div
  {{ block.shopify_attributes }}
  class="cart-items__wrapper"
  {% if settings.product_title_case == 'uppercase' %}
    style="--product-title-case: uppercase;"
  {% endif %}
>
  {% if cart.empty? %}
    {%- if shop.customer_accounts_enabled and customer == null -%}
      <p class="cart-items__login">
        {{ 'actions.log_in_html' | t: link: routes.account_login_url }}
      </p>
    {%- endif -%}

    <div class="cart-items__empty-container">
      <h2 class="cart-items__empty-title">Your cart is empty</h2>
      <a
        class="button cart-items__empty-button"
        href="{{ settings.empty_cart_button_link | default: routes.all_products_collection_url }}"
      >
        CONTINUE SHOPPING
      </a>
    </div>
  {%- else -%}
    <span
      class="visually-hidden"
      ref="cartItemCount"
      aria-hidden="true"
    >
      {{- cart.item_count -}}
    </span>
    <form
      action="{{ routes.cart_url }}"
      class="cart-form"
      id="cart-form"
      method="post"
    >
      <div class="cart-items-list" id="cart-items-list">
        {% for item in cart.items %}
          <div
            class="cart-item-card"
            ref="cartItemRows[]"
            data-key="{{ item.key }}"
            data-index="{{ item.index | plus: 1 }}"
          >
            <div class="cart-item-card__media">
              {% if item.image -%}
                <a href="{{ item.url }}" class="cart-item-card__image-link">
                  {{ item.image | image_url: width: 200 | image_tag: class: 'cart-item-card__image' }}
                </a>
              {%- endif %}
            </div>

            <div class="cart-item-card__info">
              <div class="cart-item-card__header">
                <a href="{{ item.url }}" class="cart-item-card__title">{{ item.product.title }}</a>
                <button
                  class="cart-item-card__remove button-unstyled"
                  type="button"
                  aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
                  on:click="/onLineItemRemove/{{ item.index | plus: 1 }}"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"></path></svg>
                </button>
              </div>

              <div class="cart-item-card__meta">
                {%- unless item.product.has_only_default_variant -%}
                  {%- for option in item.options_with_values -%}
                    <span class="cart-item-card__option">{{ option.value }}{% unless forloop.last %}, {% endunless %}</span>
                  {%- endfor -%}
                {%- endunless -%}
              </div>

              <div class="cart-item-card__price-row">
                <div class="cart-item-card__price">
                  {% if item.original_price != item.final_price %}
                    <span class="final-price">{{ item.final_price | money }}</span>
                    <s class="original-price">{{ item.original_price | money }}</s>
                  {% else %}
                    <span class="price">{{ item.original_price | money }}</span>
                  {% endif %}
                </div>
              </div>

              <div class="cart-item-card__bottom">
                {% render 'quantity-selector',
                  product: item.product,
                  variant: item.variant,
                  in_cart_quantity: item.quantity,
                  line_index: item.index,
                  class: 'cart-item-card__quantity'
                %}
                
                <div class="cart-item-card__total-price">
                  {{ item.final_line_price | money }}
                </div>
              </div>
              
              <div class="cart-item-card__error-msg hidden" ref="cartItemErrorContainer-{{ item.index | plus: 1 }}">
                 <small class="error-text" ref="cartItemError-{{ item.index | plus: 1 }}"></small>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </form>
  {%- endif -%}
</div>

{% stylesheet %}
  .cart-item-card {
    display: flex;
    gap: 15px;
    padding: 15px;
    border: 1px solid #f0f0f0;
    margin-bottom: 15px;
    border-radius: 0 !important;
    position: relative;
    background: #fff;
  }

  .cart-item-card__media {
    flex: 0 0 90px;
    border-radius: 0 !important;
  }

  .cart-item-card__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0 !important;
  }

  .cart-item-card__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-width: 0;
  }

  .cart-item-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2px;
  }

  .cart-item-card__title {
    font-size: 15px;
    font-weight: 500;
    color: #000;
    text-decoration: none;
    line-height: 1.2;
    padding-right: 15px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cart-item-card__remove {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #999;
    flex-shrink: 0;
  }

  .cart-item-card__meta {
    font-size: 11px;
    color: #999;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .cart-item-card__price {
    font-size: 14px;
    margin-bottom: 15px;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .cart-item-card__price .original-price {
    color: #999;
    text-decoration: line-through;
    font-size: 12px;
  }

  .cart-item-card__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .cart-item-card__total-price {
    font-size: 14px;
    font-weight: 500;
    color: #000;
  }

  .cart-item-card__quantity .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid #f0f0f0;
    height: 30px;
    border-radius: 0 !important;
  }

  .cart-items__empty-container {
    padding: 60px 20px;
    text-align: center;
  }

  .cart-items__empty-title {
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 20px;
    color: #333;
  }

  .cart-items__empty-button {
    background: #000;
    color: #fff;
    padding: 12px 30px;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 1px;
    font-weight: 600;
    border-radius: 0 !important;
  }

  .cart-items__login {
    font-size: 11px;
    color: #666;
    margin-bottom: 15px;
    text-align: center;
  }
{% endstylesheet %}
